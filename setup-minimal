#!/usr/bin/env bash
# setup-minimal — painless theme-only install. Equivalent to:
#   ./install.sh FoxML_Classic --deps --yes
#
# Theme + Hyprland + system packages. No Ollama models, no GitHub
# workspace clone, no AI stack. Use this when you want the look but
# not the full workstation tooling.

set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
exec "$SCRIPT_DIR/install.sh" FoxML_Classic --deps --yes "$@"
