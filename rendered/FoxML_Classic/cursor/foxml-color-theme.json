  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#7a7a7a",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["keyword", "storage.type", "storage.modifier"],
      "settings": {
        "foreground": "#8a9a7a",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["keyword.control", "keyword.operator"],
      "settings": {
        "foreground": "#8a9a7a"
      }
    },
    {
      "scope": ["variable", "meta.definition.variable"],
      "settings": {
        "foreground": "#d5c4b0"
      }
    },
    {
      "scope": ["variable.parameter"],
      "settings": {
        "foreground": "#b8967a"
      }
    },
    {
      "scope": ["entity.name.function", "support.function", "meta.function-call"],
      "settings": {
        "foreground": "#d4985a"
      }
    },
    {
      "scope": ["string", "string.quoted"],
      "settings": {
        "foreground": "#6b9a7a"
      }
    },
    {
      "scope": ["constant.numeric"],
      "settings": {
        "foreground": "#c4b48a"
      }
    },
    {
      "scope": ["constant.language", "variable.language"],
      "settings": {
        "foreground": "#7a9ab4"
      }
    },
    {
      "scope": ["entity.name.type", "support.type", "entity.name.class", "support.class"],
      "settings": {
        "foreground": "#7a9ab4"
      }
    },
    {
      "scope": ["entity.name.tag"],
      "settings": {
        "foreground": "#b8967a"
      }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#d4985a"
      }
    },
    {
      "scope": ["punctuation"],
      "settings": {
        "foreground": "#7a7a7a"
      }
    },
    {
      "scope": ["meta.brace"],
      "settings": {
        "foreground": "#d5c4b0"
      }
    },
    {
      "scope": ["invalid", "invalid.illegal"],
      "settings": {
        "foreground": "#d5d5d5",
        "background": "#b05555"
      }
    },
    {
      "scope": ["markup.heading"],
      "settings": {
        "foreground": "#d4985a",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.bold"],
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.italic"],
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["markup.inline.raw"],
      "settings": {
        "foreground": "#6b9a7a"
      }
    }
  ]
}
