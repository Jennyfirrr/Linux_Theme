font={{FONT_FAMILY}} 10
background-color=#{{BG}}E6
text-color=#{{FG}}
border-color=#{{PRIMARY}}
# OSD progress bar (volume / brightness) — mako defaults to blue,
# which breaks theme cohesion. `over <color>` overlays the bar onto
# the bubble background using the peach primary at 50% opacity.
progress-color=over #{{PRIMARY}}80
border-size=2
border-radius={{ROUNDING}}
padding=12
margin=12
width=350
# 6 lanes (was 3) so multi-pane agent bursts don't queue behind a long
# critical popup. With max-visible=3 + critical timeout=15s, a single
# "Claude needs input" notification holds a slot for 15s while subsequent
# turn-completes and subagent-done events queue invisibly — they then
# drip onto the screen seconds-to-minutes after the actual event.
max-visible=6
default-timeout=4000
ignore-timeout=1
icon-path=/usr/share/icons/{{MAKO_ICON_THEME}}

[urgency=low]
background-color=#{{BG}}E6
text-color=#{{FG_DIM}}
border-color=#{{SURFACE}}
default-timeout=2000

[urgency=critical]
background-color=#{{BG}}E6
text-color=#{{FG}}
border-color=#{{RED}}
default-timeout=15000

[app-name=Spotify]
border-color=#{{ACCENT}}
default-timeout=4000

[app-name="com.spotify.Client"]
border-color=#{{ACCENT}}
default-timeout=4000

# AI agents — primary accent for Claude, secondary for Gemini, so a glance
# tells you which agent is asking. Critical urgency (Notification hook,
# i.e. permission/input prompts) still gets the red border from the
# urgency=critical block above.
[app-name=Claude]
border-color=#{{PRIMARY}}
default-timeout=6000

[app-name=Gemini]
border-color=#{{ACCENT}}
default-timeout=6000
