{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "bg": "#{{BG}}",
    "bgDark": "#{{BG_DARK}}",
    "bgAlt": "#{{BG_ALT}}",
    "bgHighlight": "#{{BG_HIGHLIGHT}}",
    "bgInput": "#{{TMUX_ACTIVE_BG}}",
    "selection": "#{{SELECTION}}",
    "fg": "#{{FG}}",
    "fgPastel": "#{{FG_PASTEL}}",
    "fgDim": "#{{FG_DIM}}",
    "comment": "#{{COMMENT}}",
    "primary": "#{{PRIMARY}}",
    "secondary": "#{{SECONDARY}}",
    "accent": "#{{ACCENT}}",
    "surface": "#{{SURFACE}}",
    "red": "#{{RED}}",
    "redBright": "#{{RED_BRIGHT}}",
    "green": "#{{GREEN}}",
    "greenBright": "#{{GREEN_BRIGHT}}",
    "yellow": "#{{YELLOW}}",
    "yellowBright": "#{{YELLOW_BRIGHT}}",
    "blue": "#{{BLUE}}",
    "blueBright": "#{{BLUE_BRIGHT}}",
    "cyan": "#{{CYAN}}",
    "cyanBright": "#{{CYAN_BRIGHT}}",
    "white": "#{{WHITE}}",
    "ok": "#{{GREEN_BRIGHT}}",
    "warn": "#{{YELLOW}}",
    "diffAdd": "#{{DIFF_ADD}}",
    "diffDelete": "#{{DIFF_DELETE}}",
    "diffChange": "#{{DIFF_CHANGE}}",
    "diffText": "#{{DIFF_TEXT}}",
    "wheat": "#{{WHEAT}}",
    "clay": "#{{CLAY}}"
  },
  "theme": {
    "primary":            { "{{THEME_TYPE}}": "primary",      "light": "primary" },
    "secondary":          { "{{THEME_TYPE}}": "secondary",    "light": "secondary" },
    "accent":             { "{{THEME_TYPE}}": "accent",       "light": "accent" },
    "error":              { "{{THEME_TYPE}}": "red",          "light": "red" },
    "warning":            { "{{THEME_TYPE}}": "warn",         "light": "warn" },
    "success":            { "{{THEME_TYPE}}": "ok",           "light": "ok" },
    "info":               { "{{THEME_TYPE}}": "blue",         "light": "blue" },
    "text":               { "{{THEME_TYPE}}": "fg",           "light": "fg" },
    "textMuted":          { "{{THEME_TYPE}}": "wheat",        "light": "wheat" },
    "background":         { "{{THEME_TYPE}}": "bg",           "light": "bg" },
    "backgroundPanel":    { "{{THEME_TYPE}}": "bgDark",       "light": "bgDark" },
    "backgroundElement":  { "{{THEME_TYPE}}": "bgInput",      "light": "bgInput" },
    "border":             { "{{THEME_TYPE}}": "surface",      "light": "surface" },
    "borderActive":       { "{{THEME_TYPE}}": "primary",      "light": "primary" },
    "borderSubtle":       { "{{THEME_TYPE}}": "comment",      "light": "comment" },

    "diffAdded":               { "{{THEME_TYPE}}": "ok",         "light": "ok" },
    "diffRemoved":             { "{{THEME_TYPE}}": "red",        "light": "red" },
    "diffContext":             { "{{THEME_TYPE}}": "wheat",      "light": "wheat" },
    "diffHunkHeader":          { "{{THEME_TYPE}}": "primary",    "light": "primary" },
    "diffHighlightAdded":      { "{{THEME_TYPE}}": "greenBright","light": "greenBright" },
    "diffHighlightRemoved":    { "{{THEME_TYPE}}": "redBright",  "light": "redBright" },
    "diffAddedBg":             { "{{THEME_TYPE}}": "diffAdd",    "light": "diffAdd" },
    "diffRemovedBg":           { "{{THEME_TYPE}}": "diffDelete", "light": "diffDelete" },
    "diffContextBg":           { "{{THEME_TYPE}}": "bgDark",     "light": "bgDark" },
    "diffLineNumber":          { "{{THEME_TYPE}}": "wheat",      "light": "wheat" },
    "diffAddedLineNumberBg":   { "{{THEME_TYPE}}": "diffAdd",    "light": "diffAdd" },
    "diffRemovedLineNumberBg": { "{{THEME_TYPE}}": "diffDelete", "light": "diffDelete" },

    "markdownText":            { "{{THEME_TYPE}}": "fg",         "light": "fg" },
    "markdownHeading":         { "{{THEME_TYPE}}": "primary",    "light": "primary" },
    "markdownLink":            { "{{THEME_TYPE}}": "blue",       "light": "blue" },
    "markdownLinkText":        { "{{THEME_TYPE}}": "blueBright", "light": "blueBright" },
    "markdownCode":            { "{{THEME_TYPE}}": "cyan",       "light": "cyan" },
    "markdownCodeBlock":       { "{{THEME_TYPE}}": "fg",         "light": "fg" },
    "markdownBlockQuote":      { "{{THEME_TYPE}}": "comment",    "light": "comment" },
    "markdownEmph":            { "{{THEME_TYPE}}": "wheat",      "light": "wheat" },
    "markdownStrong":          { "{{THEME_TYPE}}": "yellow",     "light": "yellow" },
    "markdownHorizontalRule":  { "{{THEME_TYPE}}": "surface",    "light": "surface" },
    "markdownListItem":        { "{{THEME_TYPE}}": "primary",    "light": "primary" },
    "markdownListEnumeration": { "{{THEME_TYPE}}": "secondary",  "light": "secondary" },
    "markdownImage":           { "{{THEME_TYPE}}": "blue",       "light": "blue" },
    "markdownImageText":       { "{{THEME_TYPE}}": "blueBright", "light": "blueBright" },

    "syntaxComment":     { "{{THEME_TYPE}}": "comment",     "light": "comment" },
    "syntaxKeyword":     { "{{THEME_TYPE}}": "primary",     "light": "primary" },
    "syntaxFunction":    { "{{THEME_TYPE}}": "yellow",      "light": "yellow" },
    "syntaxVariable":    { "{{THEME_TYPE}}": "fg",          "light": "fg" },
    "syntaxString":      { "{{THEME_TYPE}}": "ok",          "light": "ok" },
    "syntaxNumber":      { "{{THEME_TYPE}}": "clay",        "light": "clay" },
    "syntaxType":        { "{{THEME_TYPE}}": "cyan",        "light": "cyan" },
    "syntaxOperator":    { "{{THEME_TYPE}}": "secondary",   "light": "secondary" },
    "syntaxPunctuation": { "{{THEME_TYPE}}": "fgPastel",    "light": "fgPastel" }
  }
}
