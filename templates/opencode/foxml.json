{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "bg": "#{{BG}}",
    "bgDark": "#{{BG_DARK}}",
    "bgAlt": "#{{BG_ALT}}",
    "bgHighlight": "#{{BG_HIGHLIGHT}}",
    "bgInput": "#{{NVIM_BG_HL}}",
    "selection": "#{{SELECTION}}",
    "fg": "#{{FG}}",
    "fgPastel": "#{{FG_PASTEL}}",
    "fgDim": "#{{FG_DIM}}",
    "comment": "#{{COMMENT}}",
    "primary": "#{{PRIMARY}}",
    "secondary": "#{{SECONDARY}}",
    "accent": "#{{ACCENT}}",
    "surface": "#{{SURFACE}}",
    "red": "#{{RED}}",
    "redBright": "#{{RED_BRIGHT}}",
    "green": "#{{GREEN}}",
    "greenBright": "#{{GREEN_BRIGHT}}",
    "yellow": "#{{YELLOW}}",
    "yellowBright": "#{{YELLOW_BRIGHT}}",
    "blue": "#{{BLUE}}",
    "blueBright": "#{{BLUE_BRIGHT}}",
    "cyan": "#{{CYAN}}",
    "cyanBright": "#{{CYAN_BRIGHT}}",
    "white": "#{{WHITE}}",
    "ok": "#{{OK}}",
    "warn": "#{{WARN}}",
    "diffAdd": "#{{DIFF_ADD}}",
    "diffDelete": "#{{DIFF_DELETE}}",
    "diffChange": "#{{DIFF_CHANGE}}",
    "diffText": "#{{DIFF_TEXT}}",
    "wheat": "#{{WHEAT}}",
    "clay": "#{{CLAY}}"
  },
  "theme": {
    "primary":            { "dark": "primary",      "light": "primary" },
    "secondary":          { "dark": "secondary",    "light": "secondary" },
    "accent":             { "dark": "accent",       "light": "accent" },
    "error":              { "dark": "red",          "light": "red" },
    "warning":            { "dark": "warn",         "light": "warn" },
    "success":            { "dark": "ok",           "light": "ok" },
    "info":               { "dark": "blue",         "light": "blue" },
    "text":               { "dark": "fg",           "light": "fg" },
    "textMuted":          { "dark": "wheat",        "light": "wheat" },
    "background":         { "dark": "bg",           "light": "bg" },
    "backgroundPanel":    { "dark": "bgDark",       "light": "bgDark" },
    "backgroundElement":  { "dark": "bgInput",      "light": "bgInput" },
    "border":             { "dark": "surface",      "light": "surface" },
    "borderActive":       { "dark": "primary",      "light": "primary" },
    "borderSubtle":       { "dark": "comment",      "light": "comment" },

    "diffAdded":               { "dark": "ok",         "light": "ok" },
    "diffRemoved":             { "dark": "red",        "light": "red" },
    "diffContext":             { "dark": "wheat",      "light": "wheat" },
    "diffHunkHeader":          { "dark": "primary",    "light": "primary" },
    "diffHighlightAdded":      { "dark": "greenBright","light": "greenBright" },
    "diffHighlightRemoved":    { "dark": "redBright",  "light": "redBright" },
    "diffAddedBg":             { "dark": "diffAdd",    "light": "diffAdd" },
    "diffRemovedBg":           { "dark": "diffDelete", "light": "diffDelete" },
    "diffContextBg":           { "dark": "bgDark",     "light": "bgDark" },
    "diffLineNumber":          { "dark": "wheat",      "light": "wheat" },
    "diffAddedLineNumberBg":   { "dark": "diffAdd",    "light": "diffAdd" },
    "diffRemovedLineNumberBg": { "dark": "diffDelete", "light": "diffDelete" },

    "markdownText":            { "dark": "fg",         "light": "fg" },
    "markdownHeading":         { "dark": "primary",    "light": "primary" },
    "markdownLink":            { "dark": "blue",       "light": "blue" },
    "markdownLinkText":        { "dark": "blueBright", "light": "blueBright" },
    "markdownCode":            { "dark": "cyan",       "light": "cyan" },
    "markdownCodeBlock":       { "dark": "fg",         "light": "fg" },
    "markdownBlockQuote":      { "dark": "comment",    "light": "comment" },
    "markdownEmph":            { "dark": "wheat",      "light": "wheat" },
    "markdownStrong":          { "dark": "yellow",     "light": "yellow" },
    "markdownHorizontalRule":  { "dark": "surface",    "light": "surface" },
    "markdownListItem":        { "dark": "primary",    "light": "primary" },
    "markdownListEnumeration": { "dark": "secondary",  "light": "secondary" },
    "markdownImage":           { "dark": "blue",       "light": "blue" },
    "markdownImageText":       { "dark": "blueBright", "light": "blueBright" },

    "syntaxComment":     { "dark": "comment",     "light": "comment" },
    "syntaxKeyword":     { "dark": "primary",     "light": "primary" },
    "syntaxFunction":    { "dark": "yellow",      "light": "yellow" },
    "syntaxVariable":    { "dark": "fg",          "light": "fg" },
    "syntaxString":      { "dark": "ok",          "light": "ok" },
    "syntaxNumber":      { "dark": "clay",        "light": "clay" },
    "syntaxType":        { "dark": "cyan",        "light": "cyan" },
    "syntaxOperator":    { "dark": "secondary",   "light": "secondary" },
    "syntaxPunctuation": { "dark": "fgPastel",    "light": "fgPastel" }
  }
}
