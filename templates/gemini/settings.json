{
  "ui": {
    "customThemes": {
      "FoxML": {
        "background": {
          "diff": {
            "added": "#{{DIFF_ADD}}",
            "removed": "#{{DIFF_DELETE}}"
          },
          "primary": "#{{BG}}"
        },
        "border": {
          "default": "#{{SURFACE}}",
          "focused": "#{{PRIMARY}}"
        },
        "name": "FoxML",
        "status": {
          "error": "#{{RED}}",
          "success": "#{{GREEN_BRIGHT}}",
          "warning": "#{{YELLOW}}"
        },
        "text": {
          "accent": "#{{PRIMARY}}",
          "link": "#{{BLUE}}",
          "primary": "#{{FG}}",
          "response": "#{{FG}}",
          "secondary": "#{{YELLOW}}"
        },
        "type": "custom",
        "ui": {
          "comment": "#{{COMMENT}}",
          "gradient": [
            "#{{YELLOW}}",
            "#{{PRIMARY}}"
          ],
          "symbol": "#{{PRIMARY}}"
        }
      }
    },
    "theme": "FoxML"
  },
  "hooks": {
    "AfterAgent": [
      {
        "hooks": [
          {
            "command": "~/.config/hypr/scripts/agent_notify.sh gemini stop",
            "name": "foxml-turn-complete",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "AfterTool": [
      {
        "hooks": [
          {
            "command": "~/.config/hypr/scripts/agent_notify.sh gemini subagent",
            "name": "foxml-subagent-stop",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "command": "~/.config/hypr/scripts/agent_notify.sh gemini notification",
            "name": "foxml-needs-input",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  },
  "hooksConfig": {
    "enabled": {{SHOW_WELCOME}}
  },
  "general": {
    "enableNotifications": {{SHOW_WELCOME}}
  }
}
