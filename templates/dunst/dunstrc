[global]
    # Display
    monitor = 0
    follow = mouse

    # Geometry
    width = (300, 500)
    height = 300
    origin = top-right
    offset = 20x50

    # Progress bar
    progress_bar = {{SHOW_WELCOME}}
    progress_bar_height = 10
    progress_bar_frame_width = 1
    progress_bar_min_width = 150
    progress_bar_max_width = 300
    progress_bar_corner_radius = 0

    # Appearance - crisp, no rounded corners
    transparency = 0
    separator_height = 2
    padding = 12
    horizontal_padding = 12
    text_icon_padding = 12
    frame_width = 2
    gap_size = 6
    separator_color = frame
    sort = yes
    corner_radius = 0

    # Text
    font = {{FONT_FAMILY}} 10
    line_height = 0
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = center
    show_age_threshold = 60
    word_wrap = yes
    ellipsize = middle
    ignore_newline = no
    stack_duplicates = {{SHOW_WELCOME}}
    hide_duplicate_count = false
    show_indicators = yes

    # Icons
    icon_position = left
    min_icon_size = 32
    max_icon_size = 64

    # History
    sticky_history = yes
    history_length = 20

    # Misc
    dmenu = /usr/bin/dmenu -p dunst:
    browser = /usr/bin/xdg-open
    always_run_script = {{SHOW_WELCOME}}
    title = Dunst
    class = Dunst
    ignore_dbusclose = false

    # Mouse
    mouse_left_click = do_action, close_current
    mouse_middle_click = close_current
    mouse_right_click = close_all

[urgency_low]
    background = "#{{BG_DUNST}}E6"
    foreground = "#{{FG_DIM}}"
    frame_color = "#{{SURFACE}}66"
    highlight = "#{{PRIMARY}}"
    timeout = 5

[urgency_normal]
    background = "#{{BG_DUNST}}E6"
    foreground = "#{{FG}}"
    frame_color = "#{{PRIMARY}}66"
    highlight = "#{{PRIMARY}}"
    timeout = 8

[urgency_critical]
    background = "#{{BG_DUNST}}E6"
    foreground = "#{{FG}}"
    frame_color = "#{{RED}}66"
    highlight = "#{{RED}}"
    timeout = 0

# Spotify notifications - lavender accent
[spotify]
    appname = Spotify
    background = "#{{BG_DUNST}}E6"
    foreground = "#{{FG}}"
    frame_color = "#{{ACCENT}}66"
    highlight = "#{{ACCENT}}"
    format = "<b>%s</b>\n%b"
    timeout = 5

# Spotify (flatpak)
[spotify-flatpak]
    appname = "com.spotify.Client"
    background = "#{{BG_DUNST}}E6"
    foreground = "#{{FG}}"
    frame_color = "#{{ACCENT}}66"
    highlight = "#{{ACCENT}}"
    format = "<b>%s</b>\n%b"
    timeout = 5

# AI agents — primary accent for Claude, secondary for Gemini.
# Critical-urgency entries (Notification hook = permission/input prompt)
# still get the red border from urgency_critical above.
[claude]
    appname = Claude
    background = "#{{BG_DUNST}}E6"
    foreground = "#{{FG}}"
    frame_color = "#{{PRIMARY}}99"
    highlight = "#{{PRIMARY}}"
    format = "<b>%s</b>\n%b"
    timeout = 6

[gemini]
    appname = Gemini
    background = "#{{BG_DUNST}}E6"
    foreground = "#{{FG}}"
    frame_color = "#{{ACCENT}}99"
    highlight = "#{{ACCENT}}"
    format = "<b>%s</b>\n%b"
    timeout = 6
