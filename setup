#!/usr/bin/env bash
# setup — painless full install. Equivalent to running:
#   ./install.sh FoxML_Classic --deps --ai --models --github --yes
#
# Use this after cloning the repo when you want the full Fox ML
# workstation: theme + system deps + Ollama AI stack + GitHub workspace
# clone, all non-interactive.
#
# For just the theme (no AI, no GitHub clone), use ./setup-minimal.
# For the interactive walkthrough with prompts, use ./install.sh directly.

set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
exec "$SCRIPT_DIR/install.sh" FoxML_Classic --deps --ai --models --github --yes "$@"
