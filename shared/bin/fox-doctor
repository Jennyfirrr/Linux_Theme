#!/usr/bin/env bash
# fox-doctor — diagnose nvim/Hyprland/Waybar config breakage, suggest fixes
#
# Usage: fox-doctor          # diagnose only
#        fox-doctor --fix    # diagnose + offer to auto-fix detected issues
#        fox-doctor --ai     # AI-powered explanation of findings (via fox-ai-doctor)
#        fox-doctor --help

set -u

FIX_MODE=0
UFW_NEEDS_BASELINE=0
for arg in "$@"; do
    case "$arg" in
        --fix)  FIX_MODE=1 ;;
        --ai)   exec fox-ai-doctor ;;
        --help|-h)
            sed -n '2,6p' "$0" | sed 's/^# \?//'
            exit 0
            ;;
        *) echo "unknown arg: $arg" >&2; exit 2 ;;
    esac
done

red()    { printf '\033[31m%s\033[0m' "$1"; }
yellow() { printf '\033[33m%s\033[0m' "$1"; }
green()  { printf '\033[32m%s\033[0m' "$1"; }
dim()    { printf '\033[2m%s\033[0m' "$1"; }

FAILED=0
WARNED=0
FIX_NVIM_TS_MASTER=0  # set by check_nvim when the master-branch-on-0.12 pattern is detected

section() { printf '\n%s\n' "$(dim "── $1 ──")"; }
ok()   { printf '  %s %s\n' "$(green '+')" "$1"; }
warn() { printf '  %s %s\n' "$(yellow '!')" "$1"; WARNED=$((WARNED+1)); }
fail() { printf '  %s %s\n' "$(red 'X')" "$1"; FAILED=$((FAILED+1)); }
hint() { printf '    %s\n' "$(dim "→ $1")"; }

# Compare two dotted versions: returns 0 if $1 >= $2.
version_ge() {
    [[ "$(printf '%s\n%s\n' "$2" "$1" | sort -V | head -1)" == "$2" ]]
}

# Detect: lazy.nvim spec pins nvim-treesitter to the archived master branch.
# Looks in the live config (~/.config/nvim) since that's what actually runs.
treesitter_pinned_to_master() {
    local cfg_dir="$HOME/.config/nvim"
    [[ -d "$cfg_dir" ]] || return 1
    grep -RqE 'nvim-treesitter[^"]*"[[:space:]]*,[[:space:]]*branch[[:space:]]*=[[:space:]]*"master"' "$cfg_dir" 2>/dev/null ||
    grep -RqE '"nvim-treesitter/nvim-treesitter".*branch[[:space:]]*=[[:space:]]*"master"' "$cfg_dir" 2>/dev/null
}

check_nvim() {
    section "Neovim"
    if ! command -v nvim &>/dev/null; then
        warn "nvim not installed (skipping)"
        return
    fi

    local nvim_ver
    nvim_ver="$(nvim --version | head -1 | awk '{print $2}' | sed 's/^v//')"
    ok "nvim v$nvim_ver"

    # The smoking gun: nvim ≥0.12 with nvim-treesitter pinned to master.
    # master was archived; its injection queries break under 0.12's languagetree.
    if version_ge "$nvim_ver" "0.12.0" && treesitter_pinned_to_master; then
        fail "nvim ≥0.12 with nvim-treesitter pinned to archived master branch"
        hint "this causes the 'attempt to call method range (nil)' crash"
        if (( FIX_MODE )); then
            hint "will offer auto-fix below"
        else
            hint "auto-fix available: fox doctor --fix"
        fi
        FIX_NVIM_TS_MASTER=1
    fi

    # Capture checkhealth output for the other heuristics.
    local out
    out="$(timeout 30 nvim --headless "+checkhealth" "+%print" "+qa" 2>&1 || true)"

    if grep -q "attempt to call method 'range'" <<<"$out"; then
        fail "treesitter parsers are stale (range nil error)"
        hint "fix: nvim --headless '+TSUpdateSync' '+qa'"
    fi

    local err_count
    err_count="$(grep -cE '^[^[:alnum:]]*ERROR' <<<"$out" || true)"
    if [[ "$err_count" -gt 0 ]]; then
        warn "$err_count ERROR line(s) in :checkhealth"
        hint "run ':checkhealth' inside nvim for details"
    else
        ok ":checkhealth has no ERROR lines"
    fi

    local parser_dir="$HOME/.local/share/nvim/lazy/nvim-treesitter/parser"
    if [[ -d "$parser_dir" ]]; then
        local nvim_bin parser_count stale_count
        nvim_bin="$(command -v nvim)"
        parser_count="$(find "$parser_dir" -name '*.so' | wc -l)"
        stale_count="$(find "$parser_dir" -name '*.so' ! -newer "$nvim_bin" | wc -l)"
        if [[ "$parser_count" -gt 0 && "$stale_count" -eq "$parser_count" ]]; then
            warn "all $parser_count treesitter parsers predate the nvim binary"
            hint "fix: nvim --headless '+TSUpdateSync' '+qa'"
        fi
    fi
}

check_hyprland() {
    section "Hyprland"
    if ! command -v hyprctl &>/dev/null; then
        warn "hyprctl not installed (skipping)"
        return
    fi
    if [[ -z "${HYPRLAND_INSTANCE_SIGNATURE:-}" ]]; then
        warn "not inside an active Hyprland session (skipping config parse check)"
        return
    fi
    local out
    out="$(hyprctl reload 2>&1 || true)"
    if grep -qiE 'error|invalid|unknown' <<<"$out"; then
        fail "hyprctl reload reported issues"
        printf '%s\n' "$out" | sed 's/^/    /'
    else
        ok "hyprctl reload clean"
    fi
}

check_waybar() {
    section "Waybar"
    if ! command -v waybar &>/dev/null; then
        warn "waybar not installed (skipping)"
        return
    fi
    local cfg="$HOME/.config/waybar/config.jsonc"
    [[ -f "$cfg" ]] || cfg="$HOME/.config/waybar/config"
    if [[ ! -f "$cfg" ]]; then
        warn "no waybar config found"
        return
    fi
    local out
    out="$(timeout 2 waybar -c "$cfg" 2>&1 || true)"
    if grep -qiE 'error|parse' <<<"$out"; then
        fail "waybar config parse errors"
        printf '%s\n' "$out" | grep -iE 'error|parse' | head -5 | sed 's/^/    /'
    else
        ok "waybar config parses"
    fi
}

# Auto-fix: downgrade nvim to latest 0.11.x + matching tree-sitter, pin both
# in /etc/pacman.conf. Single sudo invocation. Bails on any failure.
fix_nvim_ts_master() {
    section "Auto-fix: downgrade nvim to 0.11.x + pin"

    if ! command -v curl &>/dev/null; then
        fail "curl required for auto-fix"
        return 1
    fi

    echo "  Finding latest 0.11.x in Arch archive..."
    local idx_nvim latest_nvim
    idx_nvim="$(curl -sSL --max-time 15 'https://archive.archlinux.org/packages/n/neovim/' || true)"
    latest_nvim="$(grep -oE 'neovim-0\.11\.[0-9]+-[0-9]+-x86_64\.pkg\.tar\.zst' <<<"$idx_nvim" | sort -V | tail -1)"
    if [[ -z "$latest_nvim" ]]; then
        fail "could not locate a 0.11.x nvim package in archive"
        return 1
    fi
    echo "    → $latest_nvim"

    echo "  Finding latest 0.25.x tree-sitter..."
    local idx_ts latest_ts
    idx_ts="$(curl -sSL --max-time 15 'https://archive.archlinux.org/packages/t/tree-sitter/' || true)"
    latest_ts="$(grep -oE 'tree-sitter-0\.25\.[0-9]+-[0-9]+-x86_64\.pkg\.tar\.zst' <<<"$idx_ts" | sort -V | tail -1)"
    if [[ -z "$latest_ts" ]]; then
        fail "could not locate a 0.25.x tree-sitter package in archive"
        return 1
    fi
    echo "    → $latest_ts"

    local nvim_path="/tmp/$latest_nvim"
    local ts_path="/tmp/$latest_ts"

    echo "  Downloading packages + signatures..."
    # Pull both the .pkg.tar.zst and its detached .sig from the archive.
    # pacman -U will refuse the package if the .sig doesn't validate
    # against the system's pacman-key trust DB — that's our gate
    # against a compromised archive mirror serving a malicious .pkg.
    curl -sSL --max-time 60 -o "$nvim_path"     "https://archive.archlinux.org/packages/n/neovim/$latest_nvim"     || { fail "download failed: $latest_nvim"; return 1; }
    curl -sSL --max-time 60 -o "$nvim_path.sig" "https://archive.archlinux.org/packages/n/neovim/$latest_nvim.sig" || { fail "download failed: $latest_nvim.sig"; return 1; }
    curl -sSL --max-time 60 -o "$ts_path"       "https://archive.archlinux.org/packages/t/tree-sitter/$latest_ts"     || { fail "download failed: $latest_ts"; return 1; }
    curl -sSL --max-time 60 -o "$ts_path.sig"   "https://archive.archlinux.org/packages/t/tree-sitter/$latest_ts.sig" || { fail "download failed: $latest_ts.sig"; return 1; }

    # Independent verification BEFORE we hand the file to pacman -U.
    # pacman-key --verify checks against the keyring at /etc/pacman.d/
    # gnupg, which is populated by archlinux-keyring on every Arch box.
    # If a mirror is compromised, the signature won't match the trusted
    # keys and we abort. This catches the package-substitution attack
    # gemini's audit flagged.
    echo "  Verifying signatures via pacman-key..."
    if ! sudo pacman-key --verify "$nvim_path.sig" "$nvim_path" >/dev/null 2>&1; then
        fail "signature verification FAILED for $latest_nvim — aborting (mirror may be compromised)"
        return 1
    fi
    if ! sudo pacman-key --verify "$ts_path.sig" "$ts_path" >/dev/null 2>&1; then
        fail "signature verification FAILED for $latest_ts — aborting"
        return 1
    fi
    ok "signatures verified against system keyring"

    echo
    echo "  About to (one sudo prompt):"
    echo "    - pacman -U $nvim_path"
    echo "    - pacman -U $ts_path"
    echo "    - add 'neovim' and 'tree-sitter' to IgnorePkg in /etc/pacman.conf"
    echo
    read -r -p "  Proceed? [y/N] " yn
    [[ "$yn" =~ ^[Yy]$ ]] || { echo "  aborted."; return 1; }

    sudo bash -s -- "$nvim_path" "$ts_path" <<'SUDO_SCRIPT' || { fail "sudo block failed"; return 1; }
set -e
pacman -U --noconfirm "$1" "$2"

conf=/etc/pacman.conf
if grep -qE '^IgnorePkg' "$conf"; then
    grep -qE '^IgnorePkg[^=]*=.*\bneovim\b'      "$conf" || sed -i '/^IgnorePkg[^=]*=/ s/$/ neovim/'      "$conf"
    grep -qE '^IgnorePkg[^=]*=.*\btree-sitter\b' "$conf" || sed -i '/^IgnorePkg[^=]*=/ s/$/ tree-sitter/' "$conf"
else
    sed -i 's/^#IgnorePkg.*$/IgnorePkg   = neovim tree-sitter/' "$conf"
fi
SUDO_SCRIPT

    ok "downgraded: $(nvim --version | head -1)"
    ok "pinned in /etc/pacman.conf: $(grep '^IgnorePkg' /etc/pacman.conf)"
}

check_multimonitor() {
    section "Multi-monitor + lock screen"
    local sidecar="$HOME/.config/foxml/monitor-layout.conf"
    if [[ ! -f "$sidecar" ]]; then
        warn "no monitor-layout sidecar"
        hint "fix: run ./install.sh to re-run configure_monitors"
        return
    fi
    # Parsed (not sourced) so a malicious monitor name can't run shell
    # code when fox-doctor inspects the sidecar.
    local PRIMARY="" PORTRAIT_OUTPUTS="" SECONDARY_OUTPUTS="" MONITOR_RESOLUTIONS=""
    while IFS='=' read -r _k _v; do
        _v="${_v#\"}"; _v="${_v%\"}"
        case "$_k" in
            PRIMARY)             PRIMARY="$_v" ;;
            PORTRAIT_OUTPUTS)    PORTRAIT_OUTPUTS="$_v" ;;
            SECONDARY_OUTPUTS)   SECONDARY_OUTPUTS="$_v" ;;
            MONITOR_RESOLUTIONS) MONITOR_RESOLUTIONS="$_v" ;;
        esac
    done < <(grep -E '^(PRIMARY|PORTRAIT_OUTPUTS|SECONDARY_OUTPUTS|MONITOR_RESOLUTIONS)=' "$sidecar")
    if [[ -z "$PRIMARY" ]]; then
        fail "sidecar has no PRIMARY"
        return
    fi
    ok "sidecar parses (PRIMARY=$PRIMARY)"

    if [[ -z "$MONITOR_RESOLUTIONS" ]]; then
        warn "sidecar missing MONITOR_RESOLUTIONS — per-monitor variants disabled"
        hint "fix: rerun ./install.sh; configure_monitors now emits this field"
    else
        ok "MONITOR_RESOLUTIONS: $MONITOR_RESOLUTIONS"
    fi

    # Pre-rendered wallpaper variants — verify every source has a variant
    # for every distinct resolution in the sidecar.
    local wall_dir="$HOME/.wallpapers"
    if [[ -d "$wall_dir" && -n "$MONITOR_RESOLUTIONS" ]]; then
        local -A seen_res=()
        local entry res
        for entry in $MONITOR_RESOLUTIONS; do
            res="${entry##*:}"
            [[ -n "$res" && "$res" != "$entry" ]] && seen_res[$res]=1
        done
        local missing=0 src base ext name
        shopt -s nullglob
        for src in "$wall_dir"/*.{jpg,jpeg,png}; do
            base="$(basename "$src")"
            ext="${base##*.}"
            name="${base%.*}"
            [[ "$name" == *_portrait ]]      && continue
            [[ "$name" =~ _[0-9]+x[0-9]+$ ]] && continue
            for res in "${!seen_res[@]}"; do
                [[ -f "$wall_dir/${name}_${res}.${ext}" ]] || missing=$((missing+1))
            done
        done
        shopt -u nullglob
        if (( missing > 0 )); then
            warn "$missing per-monitor wallpaper variant(s) missing"
            hint "fix: source mappings.sh && _generate_per_monitor_wallpapers"
        else
            ok "per-monitor wallpaper variants complete"
        fi
    fi

    # hyprlock.conf: one background block per monitor, all paths resolve.
    local hyprlock_conf="$HOME/.config/hypr/hyprlock.conf"
    if [[ -f "$hyprlock_conf" ]]; then
        if grep -q '^# foxml:hyprlock-backgrounds-begin' "$hyprlock_conf"; then
            local expected=0 found
            for entry in $MONITOR_RESOLUTIONS; do
                [[ -n "${entry%%:*}" ]] && expected=$((expected+1))
            done
            found=$(awk '
                /^# foxml:hyprlock-backgrounds-begin/ { inblk=1; next }
                /^# foxml:hyprlock-backgrounds-end/   { exit }
                inblk && /^background[[:space:]]*\{/  { n++ } END { print n+0 }
            ' "$hyprlock_conf")
            if (( found == expected )); then
                ok "hyprlock has $found background block(s) matching monitors"
            else
                warn "hyprlock has $found background block(s); expected $expected"
                hint "fix: source mappings.sh && _personalize_hyprlock"
            fi
            # Verify each path resolves
            local bad_paths=0 p
            while IFS= read -r p; do
                p="${p/#\~/$HOME}"
                [[ -f "$p" ]] || bad_paths=$((bad_paths+1))
            done < <(awk '
                /^# foxml:hyprlock-backgrounds-begin/ { inblk=1; next }
                /^# foxml:hyprlock-backgrounds-end/   { exit }
                inblk && /^[[:space:]]*path[[:space:]]*=/ {
                    sub(/^[[:space:]]*path[[:space:]]*=[[:space:]]*/, "")
                    print
                }
            ' "$hyprlock_conf")
            if (( bad_paths > 0 )); then
                fail "$bad_paths hyprlock background path(s) do not exist"
            fi
        else
            warn "hyprlock.conf missing foxml sentinels"
            hint "fix: rerun ./install.sh to redeploy the template"
        fi
    fi

    # rules.conf workspace pin
    local rules_conf="$HOME/.config/hypr/modules/rules.conf"
    if [[ -f "$rules_conf" ]]; then
        if grep -q '^# foxml:workspace-pin-begin' "$rules_conf"; then
            local pinned
            pinned=$(awk '
                /^# foxml:workspace-pin-begin/ { inblk=1; next }
                /^# foxml:workspace-pin-end/   { exit }
                inblk && /^workspace[[:space:]]*=.*monitor:/ {
                    match($0, /monitor:[^,]+/)
                    print substr($0, RSTART+8, RLENGTH-8)
                    exit
                }
            ' "$rules_conf")
            if [[ "$pinned" == "$PRIMARY" ]]; then
                ok "workspace 1 pinned to $PRIMARY"
            else
                warn "workspace 1 pinned to '$pinned' but PRIMARY is '$PRIMARY'"
                hint "fix: source mappings.sh && _personalize_workspace_rules"
            fi
        else
            warn "rules.conf missing foxml workspace-pin sentinel"
        fi
    fi

    # Hot-swap watcher prerequisites
    if ! command -v socat &>/dev/null; then
        warn "socat not installed — fox-monitor-watch.sh will not run"
        hint "fix: sudo pacman -S socat"
    else
        ok "socat present"
    fi
    if [[ -x "$HOME/.config/hypr/scripts/fox-monitor-watch.sh" ]]; then
        ok "fox-monitor-watch.sh deployed"
        if ! pgrep -f fox-monitor-watch.sh >/dev/null 2>&1; then
            warn "fox-monitor-watch.sh not running"
            hint "fix: relogin, or exec ~/.config/hypr/scripts/fox-monitor-watch.sh &"
        fi
    fi

    # chvt diagnostic binds
    local keybinds_conf="$HOME/.config/hypr/modules/keybinds.conf"
    if [[ -f "$keybinds_conf" ]] && grep -q 'exec, chvt 2' "$keybinds_conf"; then
        ok "chvt diagnostic binds present"
        if ! getcap /usr/bin/chvt 2>/dev/null | grep -q cap_sys_tty_config; then
            warn "/usr/bin/chvt lacks CAP_SYS_TTY_CONFIG — binds will fail silently"
            hint "fix: sudo setcap cap_sys_tty_config+ep /usr/bin/chvt"
        fi
    fi

    # awww-daemon reachable
    if command -v awww >/dev/null 2>&1; then
        if awww query &>/dev/null; then
            ok "awww-daemon reachable"
        else
            warn "awww-daemon not running"
            hint "fix: setsid awww-daemon &  (or relogin)"
        fi
    fi

    # hypridle config is the new logind-mediated style
    local hypridle_conf="$HOME/.config/hypr/hypridle-ac.conf"
    if [[ -f "$hypridle_conf" ]] && ! grep -q '^[[:space:]]*lock_cmd' "$hypridle_conf"; then
        warn "hypridle config still uses pre-loginctl pattern"
        hint "fix: rerun ./install.sh to redeploy hypridle configs"
    fi
}

check_known_interactions() {
    # Catalog of known multi-tool interaction bugs that bite when a
    # user is running this stack. Each entry: detect → explain → fix
    # hint. --fix mode offers to apply the fix automatically.
    section "Known-issue interactions"

    # 1. Firejail-wrapped Firefox + xdg-open collision
    # When Firefox is running AND /usr/local/bin/firefox → firejail,
    # any tool that calls `xdg-open <url>` (gh, mailto, links from chat
    # apps) hits a nested-sandbox failure. Fix: install an xdg-open
    # wrapper in ~/.local/bin that routes URLs to the existing Firefox
    # via -new-tab when one's already running.
    local firejail_wrap=/usr/local/bin/firefox
    local xdg_wrap="$HOME/.local/bin/xdg-open"
    if [[ -L "$firejail_wrap" ]] && readlink "$firejail_wrap" | grep -q firejail; then
        if [[ -x "$xdg_wrap" ]] && grep -q '^# xdg-open — smart wrapper' "$xdg_wrap" 2>/dev/null; then
            ok "Firejail-Firefox-xdg-open wrapper installed (~/.local/bin/xdg-open)"
        else
            warn "Firejail wraps Firefox but no smart xdg-open shim — URLs from gh / chat / etc. will fail when Firefox is already running"
            hint "fix:  install -m 0755 \"$SCRIPT_DIR/shared/bin/xdg-open\" \"$xdg_wrap\""
            hint "(or:  fox doctor --fix)"
            INTERACTIONS_NEED_FIX+=("xdg-open-wrapper")
        fi
    fi

    # 2. fail2ban action.d/foxml-dispatch.conf parsing
    # If fail2ban-client -t fails AND foxml-dispatch.conf is present,
    # most likely the dispatch action's bash subshell tripped fail2ban's
    # config parser. Detect + suggest revert.
    if systemctl is-active --quiet fail2ban 2>/dev/null; then
        :  # all good
    elif [[ -f /etc/fail2ban/jail.local ]]; then
        if sudo -n true 2>/dev/null && ! sudo fail2ban-client -t >/dev/null 2>&1; then
            warn "fail2ban inactive AND config test fails — likely our dispatch action drop-in"
            hint "diagnose: sudo fail2ban-client -t"
            hint "quick revert: sudo rm /etc/fail2ban/action.d/foxml-dispatch.conf \\"
            hint "              && sudo sed -i '/foxml-dispatch/d' /etc/fail2ban/jail.local \\"
            hint "              && sudo systemctl restart fail2ban"
            INTERACTIONS_NEED_FIX+=("fail2ban-dispatch")
        fi
    fi

    # 3. Sudo cache cold — surface this loudly because half the other
    # checks below silently skip when they can't ask root.
    if ! sudo -n true 2>/dev/null; then
        warn "sudo cache cold — several checks below will skip"
        hint "re-prime once: sudo -v   then re-run: fox doctor"
    fi
}

check_dev_security() {
    # Developer-side hardening that doesn't fit into host posture but
    # matters a lot when you maintain a public OSS repo (especially a
    # trading-software repo where code tampering is the real risk).
    section "Dev-side security (OSS-author posture)"

    # 1. GPG commit signing
    local gpgsign
    gpgsign=$(git config --global commit.gpgsign 2>/dev/null)
    if [[ "$gpgsign" == "true" ]]; then
        local key
        key=$(git config --global user.signingkey 2>/dev/null)
        ok "git commit.gpgsign = true (key: ${key:-?})"
    else
        warn "git commit.gpgsign is not true — commits aren't signed"
        hint "fix:  git config --global commit.gpgsign true && git config --global user.signingkey <KEYID>"
    fi

    # 2. GitHub 2FA — the /user endpoint's two_factor_authentication
    # field requires the `read:user` OAuth scope. The default `gh auth
    # login` scopes don't include it, so the field comes back null and
    # we used to call this "unknown". Detect the scope gap explicitly
    # and tell the user how to refresh.
    if command -v gh >/dev/null 2>&1; then
        local two_fa scopes
        two_fa=$(gh api /user --jq '.two_factor_authentication' 2>/dev/null)
        scopes=$(gh auth status 2>&1 | awk '/Token scopes:/{sub(/.*Token scopes: */, ""); print}')
        if [[ "$two_fa" == "true" ]]; then
            ok "GitHub 2FA enabled"
        elif [[ "$two_fa" == "false" ]]; then
            fail "GitHub 2FA is NOT enabled"
            hint "fix: https://github.com/settings/security  (TOTP minimum; FIDO2/passkey if you have one)"
        elif [[ -n "$scopes" && "$scopes" != *read:user* && "$scopes" != *user* ]]; then
            warn "GitHub 2FA: gh token missing 'read:user' scope — can't query state"
            hint "fix:  gh auth refresh -s read:user"
        else
            warn "GitHub 2FA: state couldn't be determined (gh API issue?)"
            hint "check manually:  https://github.com/settings/security"
        fi
    else
        warn "gh CLI not installed — can't probe GitHub 2FA state"
    fi

    # 3. Honeytokens in repo dirs. Patterns configurable via
    # ~/.config/foxml/honey-targets (one glob per line) or the
    # FOX_HONEY_TARGETS env var. Default: trading-related patterns
    # under ~/code/ with dedupe so a repo matched by multiple globs
    # only shows once.
    if [[ -d "$HOME/code" ]]; then
        local -a patterns=()
        if [[ -n "${FOX_HONEY_TARGETS:-}" ]]; then
            read -ra patterns <<<"$FOX_HONEY_TARGETS"
        elif [[ -f "$HOME/.config/foxml/honey-targets" ]]; then
            while IFS= read -r line; do
                [[ "$line" =~ ^[[:space:]]*# ]] && continue
                [[ -z "$line" ]] && continue
                patterns+=("$line")
            done < "$HOME/.config/foxml/honey-targets"
        else
            patterns=(
                "$HOME/code/"*[Tt]rader*
                "$HOME/code/"tick*
                "$HOME/code/"FoxML*
            )
        fi

        # Dedupe via associative array — repos matching multiple globs
        # showed up twice in the old output.
        declare -A _seen=()
        local honey_count=0 honey_missing=()
        for d in "${patterns[@]}"; do
            [[ -d "$d" && -d "$d/.git" ]] || continue
            local key
            key=$(readlink -f "$d")
            [[ -n "${_seen[$key]:-}" ]] && continue
            _seen[$key]=1
            if [[ -f "$d/prod_keys.txt" ]]; then
                honey_count=$((honey_count+1))
            else
                honey_missing+=("$(basename "$d")")
            fi
        done
        if (( honey_count > 0 )); then
            ok "honey planted in $honey_count repo dir(s)"
        fi
        if (( ${#honey_missing[@]} > 0 )); then
            warn "no honey in: ${honey_missing[*]}"
            hint "plant: fox honey plant-all-trading"
            hint "customise paths: ~/.config/foxml/honey-targets (one glob per line)"
        fi
    fi

    # 4. Branch protection on FoxML_Trader_v2 (best-effort, needs gh)
    if command -v gh >/dev/null 2>&1; then
        local protected
        protected=$(gh api repos/:owner/FoxML_Trader_v2/branches/main/protection --jq '.required_signatures.enabled' 2>/dev/null)
        if [[ "$protected" == "true" ]]; then
            ok "FoxML_Trader_v2 main: required signed commits enabled"
        elif [[ -n "$protected" ]]; then
            warn "FoxML_Trader_v2 main: branch protection exists but signed commits not required"
            hint "fix: https://github.com/<you>/FoxML_Trader_v2/settings/branches"
        else
            warn "FoxML_Trader_v2 main: no branch protection (or repo not found)"
            hint "fix: https://github.com/<you>/FoxML_Trader_v2/settings/branches → add rule for main"
        fi
    fi
}

check_fox_tools() {
    section "Fox security tools"
    if command -v fox-sec >/dev/null 2>&1; then
        ok "fox sec / fox arm --status available for full tool inventory"
        hint "snapshot:  fox sec"
        hint "gap list:  fox arm --status"
    fi
    if [[ -x "$HOME/.config/waybar/scripts/foxml_sentry.sh" ]]; then
        local widget
        widget=$("$HOME/.config/waybar/scripts/foxml_sentry.sh" 2>/dev/null)
        local class
        class=$(jq -r '.class' <<<"$widget" 2>/dev/null)
        local oks_count warns_count
        oks_count=$(jq -r '.tooltip' <<<"$widget" 2>/dev/null | grep -oE 'Active protections \([0-9]+\)' | grep -oE '[0-9]+')
        warns_count=$(jq -r '.tooltip' <<<"$widget" 2>/dev/null | grep -oE 'Warnings \([0-9]+\)' | grep -oE '[0-9]+')
        case "$class" in
            ok)       ok "sentry: ${oks_count:-?} active protections, no warnings" ;;
            warning)  warn "sentry: ${warns_count:-?} warning(s), ${oks_count:-?} active";
                      hint "details: fox arm --status" ;;
            critical) fail "sentry: critical alert active";
                      hint "details: fox sec --alerts" ;;
        esac
    fi
    # Gap summary for opt-in tools — same set the inline-fix offer
    # at the end of the script can configure.
    local missing=()
    [[ ! -f "$HOME/.config/foxml/dispatch.conf" ]] && missing+=("dispatch (phone alerts)")
    [[ ! -f "$HOME/.config/foxml/knock.conf" ]] && [[ ! -f "$HOME/.config/foxml/spa.conf" ]] \
        && missing+=("knock or spa (SSH gate)")
    [[ ! -f "$HOME/.config/foxml/cafe.conf" ]] && missing+=("cafe (untrusted wifi)")
    grep -q '^# foxml-shield BEGIN' /etc/hosts 2>/dev/null || missing+=("dns-shield")
    systemctl --user is-active --quiet fox-tripwire.service 2>/dev/null || missing+=("tripwire")
    if (( ${#missing[@]} > 0 )); then
        warn "${#missing[@]} opt-in tool(s) not configured: ${missing[*]}"
        hint "auto-fix offer: fox doctor --fix"
    fi
}

check_security() {
    section "Security baseline"

    # Probe sudo availability once. Many checks below need sudo to
    # query state (ufw status, fail2ban-client status, aa-status).
    # When sudo cache is cold, `sudo -n` fails silently and our
    # checks would otherwise misreport drift as "policy wrong" when
    # the real cause is just "we couldn't ask root". Distinguish
    # the two: warn once, skip the affected checks, don't fail them.
    local _have_sudo=0
    if sudo -n true 2>/dev/null; then
        _have_sudo=1
    fi
    if (( ! _have_sudo )); then
        warn "sudo cache cold — root-only checks (UFW policy, fail2ban jails, AppArmor enforce list) will be skipped"
        hint "re-prime with: sudo -v   then re-run: fox doctor"
    fi

    # UFW
    if command -v ufw >/dev/null 2>&1; then
        if systemctl is-active --quiet ufw 2>/dev/null; then
            ok "UFW active"
            if (( _have_sudo )); then
                if sudo -n ufw status verbose 2>/dev/null | grep -qE 'Default: deny.*incoming'; then
                    ok "UFW default deny incoming"
                else
                    warn "UFW default policy is NOT deny incoming"
                    hint "fix: fox doctor --fix   (or: sudo ufw default deny incoming)"
                    UFW_NEEDS_BASELINE=1
                fi
            else
                ok "UFW default policy — skipped (no sudo)"
            fi
        else
            fail "UFW service not active"
            hint "fix: sudo systemctl enable --now ufw"
        fi
    fi

    # fail2ban with active jails
    if command -v fail2ban-client >/dev/null 2>&1; then
        if systemctl is-active --quiet fail2ban 2>/dev/null; then
            ok "fail2ban service active"
            if (( _have_sudo )); then
                local jails
                jails=$(sudo -n fail2ban-client status 2>/dev/null | grep -oE 'Jail list:[[:space:]]*[^[:space:]].*' | head -1)
                if [[ -z "$jails" ]] || [[ "$jails" =~ Jail\ list:[[:space:]]*$ ]]; then
                    fail "fail2ban running but no jails enabled"
                    hint "fix: source mappings.sh && install_security  (writes jail.local)"
                else
                    ok "fail2ban jails enabled (${jails#*: })"
                fi
            else
                ok "fail2ban jail list — skipped (no sudo)"
            fi
        else
            warn "fail2ban package installed but service inactive"
        fi
    fi

    # auditd persistent rules
    if command -v auditctl >/dev/null 2>&1; then
        if systemctl is-active --quiet auditd 2>/dev/null; then
            if [[ -f /etc/audit/rules.d/99-foxml.rules ]]; then
                ok "auditd active with persistent foxml rules"
            else
                warn "auditd active but no /etc/audit/rules.d/99-foxml.rules"
                hint "watches won't survive reboot — fix: install.sh --secure"
            fi
        fi
    fi

    # Kernel hardening sysctls — spot-check a few load-bearing values.
    local sysctl_drift=0
    for kv in \
        "kernel.kptr_restrict=2" \
        "kernel.dmesg_restrict=1" \
        "kernel.yama.ptrace_scope=1" \
        "net.ipv4.tcp_syncookies=1" \
        "net.ipv4.conf.all.accept_redirects=0"; do
        local key="${kv%=*}" expected="${kv#*=}"
        local actual
        actual=$(sysctl -n "$key" 2>/dev/null)
        if [[ "$actual" != "$expected" ]]; then
            sysctl_drift=$((sysctl_drift + 1))
        fi
    done
    if (( sysctl_drift > 0 )); then
        warn "$sysctl_drift kernel hardening sysctl(s) drifted from foxml-hardening.conf"
        hint "fix: sudo sysctl --system   (reloads /etc/sysctl.d/99-foxml-hardening.conf)"
    else
        ok "kernel hardening sysctls applied"
    fi

    # Ollama sandbox drop-in
    if systemctl list-unit-files 2>/dev/null | grep -q '^ollama\.service'; then
        if [[ -f /etc/systemd/system/ollama.service.d/foxml-hardening.conf ]]; then
            ok "ollama systemd sandbox drop-in present"
        else
            warn "ollama.service present but no foxml hardening drop-in"
            hint "fix: source mappings.sh && install_ollama_hardening"
        fi
    fi

    # AppArmor enforcement (only checks if user asked for it).
    # Probe kernel directly via /sys when no sudo — distinguishes
    # "installed but cmdline-disabled" from "we can't ask root".
    if command -v aa-status >/dev/null 2>&1; then
        if [[ ! -d /sys/kernel/security/apparmor ]]; then
            warn "AppArmor installed but not enabled in kernel"
            hint "fix: install.sh --apparmor   (modifies kernel cmdline, requires reboot)"
        elif (( _have_sudo )); then
            if sudo -n aa-status --enabled 2>/dev/null; then
                local enforced
                enforced=$(sudo -n aa-status --enforced 2>/dev/null)
                ok "AppArmor enforcing ${enforced:-(unknown count of)} profile(s)"
            else
                warn "AppArmor installed but parser unhappy — sudo aa-status for details"
            fi
        else
            ok "AppArmor enabled in kernel — profile count skipped (no sudo)"
        fi
    fi

    # systemd timers / services we ship
    for svc in fox-monitor-watch.service foxml-focus-pulse.service foxml-arch-audit.timer; do
        if systemctl --user is-enabled --quiet "$svc" 2>/dev/null; then
            if systemctl --user is-active --quiet "$svc" 2>/dev/null \
               || [[ "$svc" == *.timer ]]; then
                ok "$svc enabled"
            else
                warn "$svc enabled but not active"
            fi
        fi
    done

    # USBGuard
    if command -v usbguard >/dev/null 2>&1; then
        if systemctl is-active --quiet usbguard 2>/dev/null; then
            ok "usbguard service active"
        else
            warn "usbguard installed but not enabled"
            hint "fix: sudo systemctl enable --now usbguard"
        fi
    fi

    # /proc hidepid — install_hidepid writes the fstab entry; runtime
    # state is /proc/sys/fs/proc/hide_pid or the mount option. Check
    # both: fstab pin so the setting survives reboot, runtime so we
    # know it's active now.
    if [[ -f /etc/fstab ]] && grep -qE '^[[:space:]]*proc[[:space:]].*hidepid' /etc/fstab; then
        local _hp
        _hp=$(awk '$2=="/proc"{print $4}' /proc/mounts | grep -oE 'hidepid=[^,]*' | head -1)
        if [[ -n "$_hp" ]]; then
            ok "hidepid pinned in fstab + active ($_hp)"
        else
            warn "hidepid in fstab but not active on running /proc"
            hint "fix: sudo mount -o remount,$(grep -oE 'hidepid=[^[:space:]]*' /etc/fstab | head -1) /proc"
        fi
    else
        : # not configured — install_hidepid is opt-in, don't nag
    fi

    # noexec on /tmp + /dev/shm — install_noexec_tmp pins both.
    local _noexec_drift=0
    for mp in /tmp /dev/shm; do
        if awk -v mp="$mp" '$2==mp' /proc/mounts | grep -q . \
           && ! awk -v mp="$mp" '$2==mp && $4 ~ /(^|,)noexec($|,)/' /proc/mounts | grep -q .; then
            _noexec_drift=$((_noexec_drift + 1))
        fi
    done
    if (( _noexec_drift > 0 )) && [[ -f /etc/fstab ]] \
       && grep -qE '(/tmp|/dev/shm).*noexec' /etc/fstab; then
        warn "noexec configured in fstab but $_noexec_drift mount(s) live without it"
        hint "fix: sudo mount -o remount,noexec /tmp /dev/shm"
    elif (( _noexec_drift == 0 )) && [[ -f /etc/fstab ]] \
         && grep -qE '(/tmp|/dev/shm).*noexec' /etc/fstab; then
        ok "noexec active on /tmp + /dev/shm"
    fi

    # IOMMU — kernel must be booted with intel_iommu=on or amd_iommu=on.
    # /sys/class/iommu/ being non-empty is the runtime ground truth.
    if [[ -f /proc/cmdline ]] && grep -qE 'intel_iommu=on|amd_iommu=on' /proc/cmdline; then
        if find /sys/class/iommu/ -mindepth 1 -maxdepth 1 -print -quit 2>/dev/null | grep -q .; then
            ok "IOMMU active (DMA isolation enabled)"
        else
            warn "IOMMU on kernel cmdline but no /sys/class/iommu/ devices"
            hint "VT-d/AMD-Vi may be disabled in firmware — check BIOS"
        fi
    fi

    # Core dump suppression — install_no_coredumps writes limits.d + coredump.conf.d.
    if [[ -f /etc/security/limits.d/99-foxml-no-coredumps.conf ]] \
       && [[ -f /etc/systemd/coredump.conf.d/foxml-no-coredumps.conf ]]; then
        ok "core dumps suppressed (limits.d + coredump.conf.d)"
    elif [[ -f /etc/security/limits.d/99-foxml-no-coredumps.conf ]] \
         || [[ -f /etc/systemd/coredump.conf.d/foxml-no-coredumps.conf ]]; then
        warn "core dump suppression partial — one of two drop-ins missing"
        hint "fix: source mappings.sh && install_no_coredumps"
    fi

    # etckeeper — install_etckeeper inits /etc as a git repo.
    if [[ -d /etc/.git ]]; then
        if (( _have_sudo )); then
            if sudo -n test -f /etc/.git/HEAD 2>/dev/null; then
                ok "etckeeper repo present at /etc/.git"
            fi
        else
            ok "etckeeper /etc/.git directory present (HEAD check skipped, no sudo)"
        fi
    fi

    # endlessh tarpit — runs on :22 to slow SSH probes. Optional.
    if systemctl list-unit-files 2>/dev/null | grep -q '^endlessh\.service'; then
        if systemctl is-active --quiet endlessh 2>/dev/null; then
            ok "endlessh tarpit active on :22"
        else
            warn "endlessh installed but not active"
            hint "fix: sudo systemctl enable --now endlessh"
        fi
    fi

    # Cowrie SSH honeypot — fully optional (`fox honeypot --enable`).
    if [[ -d /opt/cowrie ]] || systemctl list-unit-files 2>/dev/null | grep -q '^cowrie\.service'; then
        if systemctl is-active --quiet cowrie 2>/dev/null; then
            ok "cowrie SSH honeypot active"
        else
            warn "cowrie installed but not active"
            hint "fix: fox honeypot --enable"
        fi
    fi

    # fox-firewall lockdown — egress filtering. Optional; just report state.
    if command -v ufw >/dev/null 2>&1 && (( _have_sudo )); then
        if sudo -n ufw status verbose 2>/dev/null | grep -q 'deny (outgoing)'; then
            ok "fox-firewall lockdown active (egress default deny)"
        fi
    fi

    # SSH private key passphrase. A passphraseless ~/.ssh/id_ed25519 on an
    # unencrypted disk is a live GitHub credential — anyone who reads the
    # file gets push/delete access until the key is revoked. The probe:
    # `ssh-keygen -y -P "" -f <key>` succeeds iff the key has no passphrase.
    local _ssh_key="$HOME/.ssh/id_ed25519"
    if [[ -f "$_ssh_key" ]]; then
        if ssh-keygen -y -P "" -f "$_ssh_key" >/dev/null 2>&1; then
            warn "SSH key $_ssh_key has no passphrase"
            hint "fix: ssh-keygen -p -f $_ssh_key   (sets one without regenerating the key)"
        else
            ok "SSH key $_ssh_key passphrase-protected"
        fi
    fi

    # Stash file from --yes installs. The installer writes the auto-
    # generated SSH passphrase here so the user can move it into a
    # password manager. If it's still on disk, that means it wasn't
    # moved + shredded — and the plaintext lives next to the key it
    # protects.
    local _pp_stash="$HOME/.config/foxml/ssh-passphrase.txt"
    if [[ -f "$_pp_stash" ]]; then
        warn "SSH passphrase stash still on disk at $_pp_stash"
        hint "move to password manager (e.g. pass insert ssh/id_ed25519) and: shred -u $_pp_stash"
    fi
}

echo "FoxML Doctor — config sanity checks"
check_nvim
check_hyprland
check_waybar
check_multimonitor
check_security
check_fox_tools
check_dev_security
declare -a INTERACTIONS_NEED_FIX=()
check_known_interactions

echo
if (( FAILED > 0 )); then
    printf '%s %d failed, %d warning(s)\n' "$(red 'Result:')" "$FAILED" "$WARNED"
    status=1
elif (( WARNED > 0 )); then
    printf '%s %d warning(s)\n' "$(yellow 'Result:')" "$WARNED"
    status=0
else
    printf '%s all checks passed\n' "$(green 'Result:')"
    status=0
fi

if (( FIX_MODE )) && (( FIX_NVIM_TS_MASTER )); then
    fix_nvim_ts_master || status=1
fi

# Inline gap-fix offers for the security tools. Doctor's existing
# checks point at fox sec / fox arm --status; here we walk through
# the missing opt-ins and offer to configure each one inline (only
# when --fix is passed and stdin is a TTY).
if (( FIX_MODE )) && [[ -t 0 ]]; then
    echo
    section "Configure missing security tools"

    _offer() {
        # _offer "<short label>" "<setup cmd>" ["<skip-marker path>"]
        #
        # If a skip-marker is passed and exists → silently no-op (the
        # user already declined this in a prior run; don't re-prompt).
        # On decline → touch the marker so future doctor / install /
        # fox-arm runs all honour the decision. y → run cmd; marker
        # not touched so re-running re-prompts if the setup failed.
        local label="$1" cmd="$2" marker="${3:-}"
        if [[ -n "$marker" && -f "$marker" ]]; then
            return 0
        fi
        read -rp "  Configure $label now? [y/N] " -n 1 -r r; echo
        if [[ "$r" =~ ^[Yy]$ ]]; then
            eval "$cmd"
        elif [[ -n "$marker" ]]; then
            mkdir -p "$(dirname "$marker")" 2>/dev/null
            touch "$marker"
        fi
    }

    [[ ! -f "$HOME/.config/foxml/dispatch.conf" ]] \
        && _offer "fox dispatch (phone alerts)"    "fox-dispatch --setup" \
                  "$HOME/.config/foxml/.skipped-dispatch"

    [[ ! -f "$HOME/.config/foxml/knock.conf" ]] && [[ ! -f "$HOME/.config/foxml/spa.conf" ]] \
        && _offer "fox spa (SPA SSH gate)"         "fox-spa --setup" \
                  "$HOME/.config/foxml/.skipped-ssh-gating"

    [[ ! -f "$HOME/.config/foxml/cafe.conf" ]] \
        && _offer "fox cafe (untrusted-wifi auto-tighten)"  "fox-cafe --setup" \
                  "$HOME/.config/foxml/.skipped-cafe"

    grep -q '^# foxml-shield BEGIN' /etc/hosts 2>/dev/null \
        || _offer "fox dns-shield (StevenBlack blocklist)"  "fox-dns-shield --enable" \
                  "$HOME/.config/foxml/.skipped-dns-shield"

    systemctl --user is-active --quiet fox-tripwire.service 2>/dev/null \
        || _offer "fox tripwire (userspace honeypot)"       "fox-tripwire --install" \
                  "$HOME/.config/foxml/.skipped-tripwire"

    if (( UFW_NEEDS_BASELINE )); then
        # No marker — UFW baseline is REQUIRED, not opt-in. Keep re-prompting until fixed.
        _offer "UFW baseline (default deny incoming + allow outgoing)" \
            "sudo ufw default deny incoming && sudo ufw default allow outgoing && sudo ufw reload"
    fi

    sudo -n ufw status verbose 2>/dev/null | grep -q 'deny (outgoing)' \
        || _offer "fox firewall lockdown (egress filter)"   "fox-firewall lockdown" \
                  "$HOME/.config/foxml/.skipped-egress-lockdown"

    systemctl --user is-active --quiet fox-proximity.service 2>/dev/null \
        || _offer "fox proximity (Bluetooth auto-lock)"     "fox-proximity --setup" \
                  "$HOME/.config/foxml/.skipped-proximity"

    # Known-interaction auto-fixes.
    for item in "${INTERACTIONS_NEED_FIX[@]:-}"; do
        case "$item" in
            xdg-open-wrapper)
                _offer "xdg-open Firejail-Firefox wrapper" \
                    "install -m 0755 \"$SCRIPT_DIR/shared/bin/xdg-open\" \"$HOME/.local/bin/xdg-open\" 2>/dev/null \
                        || install -m 0755 \"$HOME/code/Linux_Theme/shared/bin/xdg-open\" \"$HOME/.local/bin/xdg-open\""
                ;;
            fail2ban-dispatch)
                _offer "remove fail2ban foxml-dispatch action (fixes config-test failure)" \
                    "sudo rm -f /etc/fail2ban/action.d/foxml-dispatch.conf \
                        && sudo sed -i '/foxml-dispatch/d' /etc/fail2ban/jail.local \
                        && sudo systemctl restart fail2ban"
                ;;
        esac
    done

    echo
    echo "  (other opt-ins need physical hardware:  fox deadman / fox vpn import)"
fi

exit "$status"
