#!/usr/bin/env bash
# fox-uninstall — remove FoxML binaries + state from $HOME.
#
# Different from `fox rollback` (which restores Hyprland/waybar configs
# from a timestamped backup). This script focuses on the FoxML-specific
# artifacts: binaries, systemd user services, state directories, marker
# files. Leaves the user's Hyprland/waybar/dotfiles alone — restore
# those via `fox rollback <timestamp>` if you want a pristine config.
#
# Doesn't touch:
#   - ~/.config/hypr, ~/.config/waybar, ~/.config/kitty, etc.  (user data)
#   - Wallpapers in ~/.wallpapers
#   - Packages installed via pacman (`sudo pacman -R foo` for those)
#   - The Linux_Theme repo itself
#
# Usage:
#   fox-uninstall          — show what would be removed, prompt
#   fox-uninstall --yes    — remove without prompting (scripts only)
#   fox-uninstall --help

set -u

ASSUME_YES=0
for arg in "$@"; do
    case "$arg" in
        --yes|-y) ASSUME_YES=1 ;;
        --help|-h) sed -n '2,17p' "$0" | sed 's/^# \?//'; exit 0 ;;
        *) echo "unknown: $arg" >&2; exit 2 ;;
    esac
done

red()    { printf '\033[31m%s\033[0m' "$1"; }
yellow() { printf '\033[33m%s\033[0m' "$1"; }
dim()    { printf '\033[2m%s\033[0m' "$1"; }
bold()   { printf '\033[1m%s\033[0m' "$1"; }

# Collect targets. Anything that exists is a candidate; we'll show the
# list and remove on confirmation.
declare -a TARGETS=()
declare -a SERVICES=()

# 1. ~/.local/bin/fox-* + fask/findex/fhelp.
shopt -s nullglob
for b in "$HOME/.local/bin/"fox-* "$HOME/.local/bin/"fox \
         "$HOME/.local/bin/"fask "$HOME/.local/bin/"findex "$HOME/.local/bin/"fhelp; do
    [[ -f "$b" ]] && TARGETS+=("$b")
done
shopt -u nullglob

# 2. Systemd user services we install.
for svc in fox-monitor-watch.service fox-workspace-color-watch.service \
           power-state-watcher.service wallpaper-rotate.service wallpaper-rotate.timer; do
    [[ -f "$HOME/.config/systemd/user/$svc" ]] || continue
    SERVICES+=("$svc")
    TARGETS+=("$HOME/.config/systemd/user/$svc")
done

# 3. FoxML state / marker / sidecar.
for d in "$HOME/.local/share/foxml" \
         "$HOME/.local/state/foxml" \
         "$HOME/.config/foxml"; do
    [[ -e "$d" ]] && TARGETS+=("$d")
done

if (( ${#TARGETS[@]} == 0 )); then
    echo "fox-uninstall: nothing to remove."
    exit 0
fi

# Show the plan.
printf '%s\n' "$(bold ':: fox-uninstall — files to remove')"
for t in "${TARGETS[@]}"; do
    printf '  %s %s\n' "$(red 'X')" "$t"
done
printf '\n%s\n' "$(yellow 'NOTE')"
printf '  %s\n' "$(dim 'Hyprland / waybar / kitty configs are not touched.')"
printf '  %s\n' "$(dim 'To restore your pre-install configs:  fox rollback')"
printf '  %s\n' "$(dim 'Packages installed via pacman stay too: sudo pacman -Rsn <pkg> to remove.')"
echo

if (( ! ASSUME_YES )); then
    read -p "Proceed with removal? [y/N] " -n 1 -r
    echo
    [[ ! "$REPLY" =~ ^[Yy]$ ]] && { echo "aborted."; exit 0; }
fi

# Disable services before deleting their unit files.
for svc in "${SERVICES[@]}"; do
    systemctl --user disable --now "$svc" >/dev/null 2>&1 || true
done

# Now delete everything.
for t in "${TARGETS[@]}"; do
    rm -rf "$t" 2>/dev/null || true
done

systemctl --user daemon-reload >/dev/null 2>&1 || true

printf '\n%s removed %d items\n' "$(bold 'Result:')" "${#TARGETS[@]}"
echo "  (config files in ~/.config/hypr etc. left in place. fox rollback restores pre-install state.)"
