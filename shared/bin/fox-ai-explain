#!/usr/bin/env bash
# fox-ai-explain — plain-English explanation of code, logs, or errors.
#
# Usage: fox-ai-explain path/to/file.cpp
#        cat foo.log | fox-ai-explain
#        wl-paste | fox-ai-explain        # explain clipboard contents
#        fox-ai-explain --about "what does the FoxML branchless bitmap do"
#
# Reads stdin or a file path; emits a focused explanation. The --about
# form lets you ask conceptual questions without piping code.

set -u

if ! command -v ollama >/dev/null 2>&1; then
    echo "fox-ai-explain: ollama not installed" >&2
    exit 1
fi

MODEL="${FOXAI_MODEL:-}"
if [[ -z "$MODEL" ]] && [[ -f "$HOME/.config/opencode/opencode.json" ]] && command -v jq >/dev/null 2>&1; then
    MODEL=$(jq -r '.model // empty' "$HOME/.config/opencode/opencode.json" 2>/dev/null | sed 's|^ollama/||')
fi
MODEL="${MODEL:-qwen2.5-coder:7b}"

content=""
about=""
while (( $# > 0 )); do
    case "$1" in
        --about) about="$2"; shift ;;
        --help|-h) sed -n '2,10p' "$0" | sed 's/^# \?//'; exit 0 ;;
        *)
            if [[ -f "$1" ]]; then
                content=$(cat "$1")
            else
                content="$1"
            fi
            ;;
    esac
    shift
done

if [[ -z "$content" && -z "$about" ]]; then
    if [[ ! -t 0 ]]; then
        content=$(cat)
    else
        echo "fox-ai-explain: nothing to explain (pass a file, pipe input, or --about)" >&2
        exit 2
    fi
fi

if [[ -n "$about" ]]; then
    prompt="Explain in plain English: $about

Be concrete and concise. If relevant, mention the trade-offs."
else
    prompt="Explain what the following content does, in plain English. Be concrete and concise. Skip line-by-line; focus on the intent, the invariants, and any non-obvious behaviour. If you spot likely bugs, flag them briefly.

CONTENT:
$content"
fi

ollama run "$MODEL" "$prompt" 2>/dev/null
