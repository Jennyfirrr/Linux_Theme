#!/usr/bin/env bash
# fox-sec — unified security dashboard.
#
# One-shot or --live view of every security signal foxml manages:
#   • recent alerts (shared ledger from fox-dispatch)
#   • hardening posture (UFW, fail2ban, auditd, AppArmor, USBGuard,
#     kernel sysctls, gnome-keyring components)
#   • running watchers (tripwire, bouncer)
#   • listening sockets
#   • current fail2ban bans
#   • last 10 failed sudo/SSH attempts from journalctl
#
# Usage:
#   fox sec              snapshot (default)
#   fox sec --live       refresh every 5s (Ctrl-C to exit)
#   fox sec --alerts     just the alert ledger
#   fox sec --bans       just fail2ban bans
#   fox sec --logs       relevant log paths + how to tail each
#   fox sec --json       machine-readable status (one JSON object)

set -u

LEDGER="${XDG_DATA_HOME:-$HOME/.local/share}/foxml/alerts.log"
LEDGER_WINDOW=300

C_BOLD=$'\e[1m'
C_DIM=$'\e[2m'
C_PEACH=$'\e[38;5;215m'
C_GRN=$'\e[38;5;108m'
C_YEL=$'\e[38;5;221m'
C_RED=$'\e[38;5;167m'
C_BLUE=$'\e[38;5;110m'
C_RST=$'\e[0m'

# ─── helpers ──────────────────────────────────────────────────────
_ok()    { printf '  %s✓%s %s\n' "$C_GRN" "$C_RST" "$1"; }
_warn()  { printf '  %s!%s %s\n' "$C_YEL" "$C_RST" "$1"; }
_err()   { printf '  %s✗%s %s\n' "$C_RED" "$C_RST" "$1"; }
_dim()   { printf '  %s• %s%s\n' "$C_DIM" "$1" "$C_RST"; }
_h()     { printf '\n%s── %s ──%s\n' "$C_BOLD" "$1" "$C_RST"; }

_svc_state() {
    # System service.
    local svc="$1"
    if systemctl is-active --quiet "$svc" 2>/dev/null; then
        _ok "$svc active"
    elif systemctl is-enabled --quiet "$svc" 2>/dev/null; then
        _warn "$svc enabled but not active"
    else
        _err "$svc not enabled"
    fi
}
_user_svc_state() {
    local svc="$1"
    if systemctl --user is-active --quiet "$svc" 2>/dev/null; then
        _ok "$svc (user) active"
    elif systemctl --user is-enabled --quiet "$svc" 2>/dev/null; then
        _warn "$svc (user) enabled but not active"
    else
        _dim "$svc (user) not installed"
    fi
}

# ─── sections ─────────────────────────────────────────────────────
sec_alerts() {
    _h "Recent alerts (last 5 min, shared ledger)"
    if [[ ! -f "$LEDGER" ]]; then
        _dim "no ledger yet — nothing has fired"
        return
    fi
    local cutoff
    cutoff=$(( $(date +%s) - LEDGER_WINDOW ))
    local count=0
    while IFS=$'\t' read -r ts source msg; do
        [[ "$ts" =~ ^[0-9]+$ ]] || continue
        if (( ts >= cutoff )); then
            printf '  %s%s%s  %-22s  %s\n' \
                "$C_PEACH" "$(date -d "@$ts" '+%m-%d %H:%M:%S' 2>/dev/null || echo "$ts")" "$C_RST" \
                "$source" "$msg"
            count=$((count+1))
        fi
    done < "$LEDGER"
    if (( count == 0 )); then
        _dim "no alerts in the last 5 min"
    fi
    echo "  ${C_DIM}(full history: fox dispatch --recent / fox dispatch --clear)${C_RST}"
}

sec_posture() {
    _h "Hardening posture"
    _svc_state ufw
    _svc_state fail2ban
    _svc_state auditd
    _svc_state usbguard
    _svc_state apparmor
    _svc_state systemd-resolved
    _svc_state chronyd
    # AppArmor: also check kernel cmdline (active state requires reboot)
    if [[ -d /sys/kernel/security/apparmor ]]; then
        _ok "AppArmor LSM active in current kernel"
    else
        _warn "AppArmor in kernel cmdline but NOT loaded — reboot pending"
    fi
    # Kernel hardening sysctls
    if [[ -f /etc/sysctl.d/99-foxml-hardening.conf ]]; then
        _ok "kernel hardening sysctls applied (/etc/sysctl.d/99-foxml-hardening.conf)"
    else
        _err "kernel hardening sysctls NOT applied"
    fi
    # Ollama sandbox
    if [[ -f /etc/systemd/system/ollama.service.d/foxml-hardening.conf ]]; then
        _ok "ollama systemd sandbox drop-in present"
    fi
    # SSH hardening
    if [[ -f /etc/ssh/sshd_config.d/50-foxml-hardening.conf ]]; then
        local port pa
        port=$(awk '/^Port /{print $2}' /etc/ssh/sshd_config.d/50-foxml-hardening.conf 2>/dev/null)
        pa=$(awk '/^PasswordAuthentication /{print $2}' /etc/ssh/sshd_config.d/50-foxml-hardening.conf 2>/dev/null)
        if [[ "$pa" == "no" ]]; then
            _ok "SSH keys-only on port ${port:-?} (PasswordAuthentication=no)"
        else
            _warn "SSH on port ${port:-?} — PasswordAuthentication=${pa:-?} (consider keys-only)"
        fi
    fi
    # gnome-keyring autostart components
    if [[ "$(systemctl --user is-enabled app-gnome-keyring-pkcs11@autostart.service 2>/dev/null)" == "masked" ]] && \
       [[ "$(systemctl --user is-enabled gnome-keyring-daemon.service 2>/dev/null)" == "masked" ]]; then
        _ok "gnome-keyring limited components masked (SSH+GPG agent works)"
    else
        _warn "gnome-keyring limited components active (breaks SSH/GPG agents)"
    fi
}

sec_watchers() {
    _h "Intrusion watchers"
    _user_svc_state fox-bouncer.service
    _user_svc_state fox-tripwire.service
    _user_svc_state fox-monitor-watch.service
    _user_svc_state foxml-focus-pulse.service
    if [[ -f "$HOME/.config/foxml/dispatch.conf" ]]; then
        _ok "fox-dispatch webhook configured"
    else
        _warn "fox-dispatch not configured — phone alerts disabled (run: fox dispatch --setup)"
    fi
}

sec_listeners() {
    _h "Non-loopback listening sockets"
    if sudo -n true 2>/dev/null; then
        sudo ss -tulnp 2>/dev/null \
            | awk 'NR==1 || $5 !~ /^(127\.|\[::1\])/' \
            | sed 's/^/  /'
    else
        ss -tuln 2>/dev/null \
            | awk 'NR==1 || $5 !~ /^(127\.|\[::1\])/' \
            | sed 's/^/  /'
        echo "  ${C_DIM}(re-prime sudo for process names: sudo -v)${C_RST}"
    fi
}

sec_bans() {
    _h "fail2ban — currently banned IPs"
    if ! systemctl is-active --quiet fail2ban; then
        _err "fail2ban not active"
        return
    fi
    if sudo -n true 2>/dev/null; then
        local status
        status=$(sudo fail2ban-client status 2>/dev/null)
        local jails
        jails=$(awk -F': ' '/Jail list/{print $2}' <<<"$status" | tr ',' '\n' | tr -d ' ')
        if [[ -z "$jails" ]]; then
            _dim "no active jails"
            return
        fi
        local any_bans=0
        for jail in $jails; do
            local banned
            banned=$(sudo fail2ban-client status "$jail" 2>/dev/null \
                | awk -F': ' '/Currently banned/{print $2}' | head -c 200)
            local count
            count=$(sudo fail2ban-client status "$jail" 2>/dev/null \
                | awk -F': ' '/Total banned/{print $2}')
            if [[ -n "$banned" && "$banned" != " " ]]; then
                printf '  %s%-8s%s currently: %s   total: %s\n' "$C_PEACH" "$jail" "$C_RST" "$banned" "${count:-?}"
                any_bans=1
            else
                printf '  %s%-8s%s currently: %s(none)%s   total: %s\n' "$C_PEACH" "$jail" "$C_RST" "$C_DIM" "$C_RST" "${count:-0}"
            fi
        done
        (( any_bans == 0 )) && _dim "no IPs currently banned"
    else
        _dim "sudo cache cold — re-prime with: sudo -v"
    fi
}

sec_failed_auth() {
    _h "Recent failed auth (sudo / sshd) — last 10"
    if sudo -n true 2>/dev/null; then
        sudo journalctl --no-pager --since "24 hours ago" \
            -u sshd.service _COMM=sudo 2>/dev/null \
            | grep -iE 'fail|invalid user|authentication failure' \
            | tail -n 10 \
            | sed 's/^/  /'
    else
        _dim "sudo cache cold — re-prime with: sudo -v"
    fi
}

sec_logs() {
    _h "Relevant logs"
    cat <<EOF
  ${C_DIM}sshd${C_RST}              sudo journalctl -u sshd -f
  ${C_DIM}fail2ban${C_RST}          sudo journalctl -u fail2ban -f
  ${C_DIM}auditd events${C_RST}     sudo ausearch -k passwd_changes
                    sudo ausearch -k sshd_config_changes
                    sudo ausearch -k sudoers_changes
  ${C_DIM}usbguard${C_RST}          sudo journalctl -u usbguard -f
  ${C_DIM}AppArmor denials${C_RST}  sudo journalctl -k --grep 'apparmor=.DENIED.'
  ${C_DIM}UFW drops${C_RST}         sudo journalctl -k --grep '\\[UFW BLOCK\\]'
  ${C_DIM}foxml ledger${C_RST}      tail -f $LEDGER
  ${C_DIM}fox-bouncer${C_RST}       journalctl --user -u fox-bouncer.service -f
  ${C_DIM}fox-tripwire${C_RST}      journalctl --user -u fox-tripwire.service -f
EOF
}

sec_snapshot() {
    sec_alerts
    sec_posture
    sec_watchers
    sec_bans
    sec_listeners
    sec_failed_auth
}

# ─── JSON output for waybar / scripts ─────────────────────────────
sec_json() {
    local count_recent=0
    if [[ -f "$LEDGER" ]]; then
        local cutoff
        cutoff=$(( $(date +%s) - LEDGER_WINDOW ))
        count_recent=$(awk -F'\t' -v c="$cutoff" '$1+0 >= c' "$LEDGER" 2>/dev/null | wc -l)
    fi
    local ufw_active=0 f2b_active=0 audit_active=0 apparmor_loaded=0 bouncer_active=0 tripwire_active=0
    systemctl is-active --quiet ufw       && ufw_active=1
    systemctl is-active --quiet fail2ban  && f2b_active=1
    systemctl is-active --quiet auditd    && audit_active=1
    [[ -d /sys/kernel/security/apparmor ]] && apparmor_loaded=1
    systemctl --user is-active --quiet fox-bouncer.service  && bouncer_active=1
    systemctl --user is-active --quiet fox-tripwire.service && tripwire_active=1
    cat <<EOF
{"recent_alerts": $count_recent, "ufw": $ufw_active, "fail2ban": $f2b_active, "auditd": $audit_active, "apparmor_loaded": $apparmor_loaded, "fox_bouncer": $bouncer_active, "fox_tripwire": $tripwire_active}
EOF
}

# ─── entry ────────────────────────────────────────────────────────
act_live() {
    while true; do
        clear
        printf '%sfox sec — live%s  (%s)  Ctrl-C to exit\n' "$C_PEACH" "$C_RST" "$(date)"
        sec_snapshot
        sleep 5
    done
}

case "${1:-}" in
    ""|snapshot) sec_snapshot ;;
    --live)      act_live ;;
    --alerts)    sec_alerts ;;
    --bans)      sec_bans ;;
    --logs)      sec_logs ;;
    --json)      sec_json ;;
    -h|--help)
        cat <<EOF
${C_BOLD}fox sec${C_RST} — unified security dashboard

  fox sec               full snapshot (alerts + posture + watchers + bans + listeners + failed auth)
  fox sec --live        refresh every 5s
  fox sec --alerts      just the alert ledger (last 5 min)
  fox sec --bans        fail2ban current bans
  fox sec --logs        relevant log files + how to tail each
  fox sec --json        machine-readable status object
EOF
    ;;
    *) echo "unknown: $1" >&2; exit 2 ;;
esac
