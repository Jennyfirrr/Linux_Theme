#!/usr/bin/env bash
# fox-sandbox — launch a disposable, sandboxed program.
#
# Wraps the chosen target in firejail with --private so it gets a
# fresh tmpfs $HOME that's wiped when the process exits. Anything the
# program reads / writes lives in that tmpfs and disappears on close.
# Network access stays intact (mostly the point — you can still hit
# the random site you needed to visit).
#
# Picker mode (no args): rofi menu with the common sandbox targets.
# Direct mode: fox-sandbox <command> [args...] runs that command
# directly under firejail --private. Pair with the $mod+SHIFT+Return
# keybind that opens this in rofi.
#
# Requires firejail. Falls back to bwrap (bubblewrap) if firejail is
# absent. Refuses to run unsandboxed — a leaky sandbox is worse than
# no sandbox because it gives false confidence.

set -u

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
    sed -n '2,17p' "$0" | sed 's/^# \?//'
    exit 0
fi

# Discover sandbox tool. firejail first (better defaults, includes
# bundled profiles for firefox / discord). bwrap as fallback.
SANDBOX=""
if command -v firejail >/dev/null 2>&1; then
    SANDBOX="firejail --private --quiet"
elif command -v bwrap >/dev/null 2>&1; then
    SANDBOX="bwrap --dev-bind / / --tmpfs /home --tmpfs /tmp --setenv HOME /home/sandbox"
else
    notify-send -u critical "fox-sandbox" "Neither firejail nor bwrap installed. \`sudo pacman -S firejail\`."
    exit 1
fi

# Direct mode — caller passed a command on the CLI.
if (( $# > 0 )); then
    notify-send -t 2000 "fox-sandbox" "Launching: $*"
    setsid -f $SANDBOX "$@" >/dev/null 2>&1 < /dev/null &
    exit 0
fi

# Picker mode — rofi menu of common sandbox targets. Format:
#   "Label\tCommand"
# We hide the command column from rofi via -display-cmd, falling
# back to showing both if that's not supported.
choices=(
    "Firefox (private session)|firefox"
    "Chromium (private session)|chromium --incognito"
    "Kitty (disposable terminal)|kitty"
    "Yazi (file browser, tmpfs home)|kitty -e yazi"
    "Pager (less /etc/passwd in sandbox)|kitty -e less"
)

label_lines=$(printf '%s\n' "${choices[@]}" | cut -d'|' -f1)
sel=$(printf '%s\n' "$label_lines" | rofi -dmenu -i -p "sandbox" \
        -kb-row-up "k,Up" -kb-row-down "j,Down" \
        -kb-accept-entry "l,Return" -kb-cancel "Escape,h" \
        -theme-str 'inputbar {enabled: true;}' 2>/dev/null)
[[ -z "$sel" ]] && exit 0

cmd=""
for entry in "${choices[@]}"; do
    if [[ "${entry%%|*}" == "$sel" ]]; then
        cmd="${entry#*|}"
        break
    fi
done
[[ -z "$cmd" ]] && exit 0

notify-send -t 2000 "fox-sandbox" "$sel"
# shellcheck disable=SC2086
setsid -f $SANDBOX $cmd >/dev/null 2>&1 < /dev/null &
