#!/bin/bash
# Refined pane info for tmux border
# Usage: tmux-pane-info <path> <command> <active_flag>

path="${1:-$PWD}"
cmd="${2:-}"
active="${3:-0}"

# 1. Shortened Path (just the last two segments if long)
# ~/code/Linux_Theme -> .../Linux_Theme
short_path=$(echo "$path" | sed "s|^$HOME|~|")
if [[ $(echo "$short_path" | tr -cd '/' | wc -c) -gt 2 ]]; then
    short_path=".../$(basename "$path")"
fi

# 2. Git Info (Minimalist)
git_info=""
git_dir=$(git -C "$path" rev-parse --git-dir 2>/dev/null)
if [[ -n "$git_dir" ]]; then
    branch=$(git -C "$path" symbolic-ref --quiet --short HEAD 2>/dev/null) \
        || branch=$(git -C "$path" rev-parse --short HEAD 2>/dev/null)
    
    if [[ -n "$branch" ]]; then
        # Just branch name + a simple indicator if dirty
        if [[ -n "$(git -C "$path" status --porcelain 2>/dev/null)" ]]; then
            git_info="⎇ $branch ●"
        else
            git_info="⎇ $branch"
        fi
    fi
fi

# 3. Env Info (Conda/Venv)
env_info=""
if [[ -n "$CONDA_DEFAULT_ENV" && "$CONDA_DEFAULT_ENV" != "base" ]]; then
    env_info=" $CONDA_DEFAULT_ENV"
elif [[ -n "$VIRTUAL_ENV" ]]; then
    env_info="󰟓 $(basename "$VIRTUAL_ENV")"
fi

# Build final string with better spacing
# Format: Path  │  Command  │  [Env]  │  [Git]
res="$short_path  │  $cmd"
[[ -n "$env_info" ]] && res="$res  │  $env_info"
[[ -n "$git_info" ]] && res="$res  │  $git_info"

echo " $res "
