#!/usr/bin/env bash
# fox-jail — firejail management.
set -u
C_GRN=$'\e[38;5;108m'; C_YEL=$'\e[38;5;221m'; C_RED=$'\e[38;5;167m'; C_DIM=$'\e[2m'; C_RST=$'\e[0m'

WRAP_BIN=/usr/local/bin

_list_sandboxed() {
    if command -v firejail >/dev/null 2>&1; then
        local out
        out=$(firejail --list 2>/dev/null)
        if [[ -z "$out" ]]; then
            echo "  ${C_DIM}no firejail sandboxes currently active${C_RST}"
        else
            echo "$out" | sed 's/^/  /'
        fi
    else
        echo "${C_RED}firejail not installed${C_RST}"; return 1
    fi
}

_list_wrapped() {
    echo "  Apps currently routed through firejail (symlinks in $WRAP_BIN):"
    local n=0
    for f in "$WRAP_BIN"/*; do
        if [[ -L "$f" ]] && readlink "$f" 2>/dev/null | grep -q firejail; then
            printf '    %s  →  %s\n' "$(basename "$f")" "$(readlink "$f")"
            n=$((n+1))
        fi
    done
    (( n == 0 )) && echo "    ${C_YEL}(none — run: sudo firecfg)${C_RST}"
}

_add() {
    local app="$1"
    sudo ln -sf /usr/bin/firejail "$WRAP_BIN/$app" \
        && echo "${C_GRN}✓ $app routed through firejail${C_RST}"
}

_rm() {
    local app="$1"
    if [[ -L "$WRAP_BIN/$app" ]] && readlink "$WRAP_BIN/$app" | grep -q firejail; then
        sudo rm "$WRAP_BIN/$app" && echo "${C_GRN}✓ $app de-jailed (running natively now)${C_RST}"
    else
        echo "${C_YEL}$app isn't currently jailed${C_RST}"
    fi
}

_allow() {
    local app="$1"
    local dir="${2:-}"
    if [[ -z "$dir" ]]; then
        echo "usage: fox jail allow <app> <dir>"
        return 1
    fi
    local override="$HOME/.config/firejail/${app}.local"
    mkdir -p "$(dirname "$override")"
    
    # Resolve absolute path (handles ~ and relative paths if provided)
    local abs_dir
    abs_dir="$(realpath -m "$dir")"
    
    if grep -q "^whitelist ${abs_dir}$" "$override" 2>/dev/null; then
        echo "${C_YEL}✓ $abs_dir is already allowed for $app${C_RST}"
        return 0
    fi
    
    echo "noblacklist ${abs_dir}" >> "$override"
    echo "whitelist ${abs_dir}" >> "$override"
    echo "${C_GRN}✓ Allowed $abs_dir for $app (restart $app to apply)${C_RST}"
}

_refresh_firefox() {
    pkill -SIGTERM -x firefox 2>/dev/null
    sleep 1
    pgrep -x firefox >/dev/null && pkill -KILL -x firefox 2>/dev/null
    setsid -f firefox >/dev/null 2>&1 &
    disown || true
    echo "${C_GRN}✓ firefox restarted (sandboxed if symlink active)${C_RST}"
}

case "${1:-}" in
    ""|status)
        echo "Active sandboxes:"; _list_sandboxed; echo
        _list_wrapped
        ;;
    add)        [[ -n "${2:-}" ]] && _add "$2" || { echo "usage: fox jail add <app>"; exit 2; } ;;
    rm|remove)  [[ -n "${2:-}" ]] && _rm  "$2" || { echo "usage: fox jail rm <app>"; exit 2; } ;;
    allow)      [[ -n "${2:-}" ]] && _allow "$2" "${3:-}" || { echo "usage: fox jail allow <app> <dir>"; exit 2; } ;;
    apply-all)  sudo firecfg && echo "${C_GRN}✓ firecfg applied (every supported app wrapped)${C_RST}" ;;
    restart-firefox) _refresh_firefox ;;
    log)        sudo tail -n 50 /var/log/firejail.log 2>/dev/null || sudo journalctl -t firejail --no-pager -n 50 ;;
    -h|--help|help) cat <<EOF
fox jail — firejail mgmt
  fox jail [status]      show active sandboxes + wrapped-app symlinks
  fox jail add <app>     route <app> through firejail (creates /usr/local/bin/<app>)
  fox jail rm  <app>     un-jail <app>
  fox jail allow <app> <dir>  whitelist a directory for a sandboxed app
  fox jail apply-all     run firecfg (wraps every supported app)
  fox jail restart-firefox  kill + relaunch firefox sandboxed
  fox jail log           recent firejail log
EOF
    ;;
    *) echo "unknown: $1" >&2; exit 2 ;;
esac
