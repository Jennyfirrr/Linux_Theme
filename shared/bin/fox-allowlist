#!/usr/bin/env bash
# fox-allowlist — fapolicyd wrapper (executable allowlist).
#
# fapolicyd enforces "only known executables can run" at the kernel-
# trace level. Default trust = every binary in pacman's database +
# user binaries under known paths. Anything else (dropped malware
# in /tmp, ~/.cache, etc.) gets EPERM at exec() time.
#
# Heavy: false-positive surface on a dev machine (npm-built scripts,
# pip-installed binaries, etc.). Opt-in. Once you turn it on you have
# to either build trust manually OR add `update` calls every time you
# install something via pip/npm/cargo/yay-AUR.
#
# Usage:
#   fox allowlist --enable      install + enable fapolicyd with default trust
#   fox allowlist --status      service state + trust db size
#   fox allowlist --learn       learn-mode for 1 hour (logs only, no blocks)
#   fox allowlist --enforce     leave learn mode, start blocking
#   fox allowlist --update      refresh trust db (run after pip/npm/cargo installs)
#   fox allowlist --disable     stop fapolicyd

set -u
C_GRN=$'\e[38;5;108m'; C_YEL=$'\e[38;5;221m'; C_RED=$'\e[38;5;167m'; C_DIM=$'\e[2m'; C_RST=$'\e[0m'

_check() {
    if ! command -v fapolicyd >/dev/null 2>&1; then
        echo "${C_YEL}fapolicyd not installed${C_RST}"
        local aur=""
        command -v yay  &>/dev/null && aur="yay"
        [[ -z "$aur" ]] && command -v paru &>/dev/null && aur="paru"
        if [[ -n "$aur" ]]; then
            echo "  installing from AUR (build ~30-60s)..."
            $aur -S --needed --noconfirm fapolicyd 2>&1 | tail -10 | sed 's/^/    /'
        else
            echo "${C_RED}no AUR helper — install fapolicyd manually${C_RST}" >&2
            return 1
        fi
    fi
    command -v fapolicyd >/dev/null 2>&1
}

_enable() {
    _check || return 1
    # Start in PERMISSIVE mode by default — logs would-be-blocks but
    # doesn't enforce. User opts into enforce mode later.
    local conf=/etc/fapolicyd/fapolicyd.conf
    if [[ -f "$conf" ]]; then
        # Set permissive=1 unless already managed by us.
        if ! sudo grep -q '^# foxml-managed' "$conf"; then
            sudo sed -i 's/^permissive[[:space:]]*=.*/permissive = 1/' "$conf"
            sudo sed -i '1i# foxml-managed — permissive mode by default; enforce via fox allowlist --enforce' "$conf"
        fi
    fi
    sudo systemctl enable --now fapolicyd
    if systemctl is-active --quiet fapolicyd; then
        echo "${C_GRN}✓ fapolicyd active in PERMISSIVE mode (logs would-be-blocks, doesn't enforce yet)${C_RST}"
        echo "  ${C_DIM}1. Run normally for a few days; check logs: journalctl -u fapolicyd${C_RST}"
        echo "  ${C_DIM}2. When ready: fox allowlist --enforce${C_RST}"
    fi
}

_enforce() {
    local conf=/etc/fapolicyd/fapolicyd.conf
    sudo sed -i 's/^permissive[[:space:]]*=.*/permissive = 0/' "$conf"
    sudo systemctl restart fapolicyd
    echo "${C_GRN}✓ fapolicyd now ENFORCING — unknown binaries are blocked${C_RST}"
    echo "  ${C_DIM}if something breaks, --learn or --disable to recover${C_RST}"
}

_learn() {
    local conf=/etc/fapolicyd/fapolicyd.conf
    sudo sed -i 's/^permissive[[:space:]]*=.*/permissive = 1/' "$conf"
    sudo systemctl restart fapolicyd
    echo "${C_YEL}↺ fapolicyd back in PERMISSIVE — observe logs, don't block${C_RST}"
}

_update() {
    sudo fapolicyd-cli --update >/dev/null 2>&1 || sudo fapolicyd-cli -u >/dev/null 2>&1
    echo "${C_GRN}✓ trust DB refreshed (re-run after pip/npm/cargo installs)${C_RST}"
}

_disable() {
    sudo systemctl disable --now fapolicyd 2>/dev/null
    echo "${C_GRN}✓ fapolicyd stopped${C_RST}"
}

_status() {
    if systemctl is-active --quiet fapolicyd 2>/dev/null; then
        echo "  service:  ${C_GRN}active${C_RST}"
        local mode
        mode=$(sudo -n grep '^permissive' /etc/fapolicyd/fapolicyd.conf 2>/dev/null | awk -F= '{print $2}' | tr -d ' ')
        [[ "$mode" == "1" ]] && echo "  mode:     ${C_YEL}PERMISSIVE (log only)${C_RST}" \
            || echo "  mode:     ${C_GRN}ENFORCE${C_RST}"
    else
        echo "  service:  ${C_RED}inactive${C_RST}"
    fi
}

case "${1:-}" in
    --enable)    _enable ;;
    --enforce)   _enforce ;;
    --learn)     _learn ;;
    --update)    _update ;;
    --disable)   _disable ;;
    --status|"") _status ;;
    -h|--help|help) cat <<EOF
fox allowlist — fapolicyd executable allowlist

  fox allowlist --enable     install + enable in PERMISSIVE mode (log only)
  fox allowlist --enforce    flip to enforcement (unknown binaries blocked)
  fox allowlist --learn      back to permissive mode (recover from breakage)
  fox allowlist --update     refresh trust DB (after pip/npm/cargo installs)
  fox allowlist --disable    stop the daemon
  fox allowlist --status     current state + mode

Typical adoption: enable in PERMISSIVE for a week, watch logs, then
--enforce when you've stopped seeing false positives.
EOF
    ;;
    *) echo "unknown: $1" >&2; exit 2 ;;
esac
