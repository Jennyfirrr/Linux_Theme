#!/usr/bin/env bash
# fox-audit — lynis wrapper for hardening posture.
#
# lynis runs ~300 checks across kernel sysctls, authentication,
# filesystem, network, malware, banners, file integrity, etc., and
# produces a 0-100 hardening_index. Different layer from auditd
# (kernel honeypot) and fox-doctor (drift-check on foxml-installed
# layers) — lynis is a one-shot "where do I stand right now"
# system audit. Runs sudo, never modifies the system, read-only.
#
#   fox audit              quick scan; score + top 5 suggestions
#   fox audit --full       full audit, stream output
#   fox audit --score      hardening_index from last run (no scan)
#   fox audit --suggestions   list suggestions from last run
#   fox audit --warnings   list warnings from last run
#   fox audit --install    install lynis (extra repo)
#   fox audit --status     last-scan timestamp + score
#   fox audit --ai         AI-powered explanation of findings

set -u
C_GRN=$'\e[38;5;108m'; C_YEL=$'\e[38;5;221m'; C_RED=$'\e[38;5;167m'
C_DIM=$'\e[2m'; C_BOLD=$'\e[1m'; C_RST=$'\e[0m'

REPORT=/var/log/lynis-report.dat
LOG=/var/log/lynis.log

_have() { command -v lynis >/dev/null 2>&1; }

_install() {
    if _have; then
        echo "${C_DIM}lynis already installed:${C_RST} $(lynis --version 2>/dev/null | head -1)"
        return 0
    fi
    if ! sudo -v 2>/dev/null; then
        echo "${C_RED}sudo required to install lynis${C_RST}" >&2
        return 1
    fi
    sudo pacman -S --needed --noconfirm lynis 2>&1 | tail -6 | sed 's/^/  /'
}

_score() {
    if ! sudo -n test -r "$REPORT" 2>/dev/null; then
        echo "${C_DIM}no prior scan — run: fox audit${C_RST}"
        return 1
    fi
    local idx
    idx=$(sudo -n grep '^hardening_index=' "$REPORT" 2>/dev/null | tail -1 | cut -d= -f2)
    if [[ -z "$idx" ]]; then
        echo "${C_DIM}no hardening_index in report${C_RST}"
        return 1
    fi
    local color="$C_RED"
    (( idx >= 70 )) && color="$C_YEL"
    (( idx >= 85 )) && color="$C_GRN"
    printf '%sHardening index: %s%d / 100%s\n' "$C_BOLD" "$color" "$idx" "$C_RST"
}

_suggestions() {
    if ! sudo -n test -r "$REPORT" 2>/dev/null; then
        echo "${C_DIM}no prior scan — run: fox audit${C_RST}"
        return 1
    fi
    local count
    count=$(sudo -n grep -c '^suggestion\[\]=' "$REPORT" 2>/dev/null || echo 0)
    echo "${C_BOLD}Suggestions (${count}):${C_RST}"
    sudo -n grep '^suggestion\[\]=' "$REPORT" 2>/dev/null \
        | cut -d= -f2- | nl -w2 -s'. ' | sed 's/^/  /'
}

_warnings() {
    if ! sudo -n test -r "$REPORT" 2>/dev/null; then
        echo "${C_DIM}no prior scan — run: fox audit${C_RST}"
        return 1
    fi
    local count
    count=$(sudo -n grep -c '^warning\[\]=' "$REPORT" 2>/dev/null || echo 0)
    if (( count == 0 )); then
        echo "${C_GRN}✓ no warnings from last scan${C_RST}"
        return 0
    fi
    echo "${C_BOLD}${C_YEL}Warnings (${count}):${C_RST}"
    sudo -n grep '^warning\[\]=' "$REPORT" 2>/dev/null \
        | cut -d= -f2- | nl -w2 -s'. ' | sed 's/^/  /'
}

_status() {
    if ! _have; then
        echo "  lynis:    ${C_RED}not installed${C_RST}  (fox audit --install)"
        return 0
    fi
    echo "  lynis:    ${C_GRN}$(lynis --version 2>/dev/null | head -1)${C_RST}"
    if sudo -n test -r "$REPORT" 2>/dev/null; then
        local ts
        ts=$(sudo -n stat -c %y "$REPORT" 2>/dev/null | cut -d. -f1)
        echo "  last:     $ts"
        _score
    else
        echo "  last:     ${C_DIM}never${C_RST}  (fox audit)"
    fi
}

_run_quick() {
    if ! _have; then
        echo "  ${C_DIM}lynis not installed — installing...${C_RST}"
        _install || return 1
    fi
    if ! sudo -v 2>/dev/null; then
        echo "${C_RED}sudo required to audit privileged checks${C_RST}" >&2
        return 1
    fi
    echo "${C_DIM}Running lynis (quick mode, ~30-60s)...${C_RST}"
    # --quick: skip slower checks (file integrity hash scan, malware
    # scan). --quiet: suppress per-check verbose output; we'll parse
    # the report file instead.
    sudo lynis audit system --quick --quiet --no-colors >/dev/null 2>&1
    local rc=$?
    # lynis exits non-zero on warnings — don't treat that as failure
    if [[ ! -r "$REPORT" ]] && (( rc != 0 )); then
        echo "${C_RED}lynis exited ${rc} without producing a report${C_RST}" >&2
        echo "  ${C_DIM}check: sudo tail -20 ${LOG}${C_RST}" >&2
        return 1
    fi
    echo
    _score
    echo
    # Top 5 suggestions only — full list via --suggestions.
    local sug_count
    sug_count=$(sudo -n grep -c '^suggestion\[\]=' "$REPORT" 2>/dev/null || echo 0)
    if (( sug_count > 0 )); then
        echo "${C_BOLD}Top suggestions (showing 5 of ${sug_count}):${C_RST}"
        sudo -n grep '^suggestion\[\]=' "$REPORT" | head -5 \
            | cut -d= -f2- | nl -w2 -s'. ' | sed 's/^/  /'
        if (( sug_count > 5 )); then
            echo "  ${C_DIM}... +$((sug_count - 5)) more — fox audit --suggestions${C_RST}"
        fi
    fi
    _warnings
}

_run_full() {
    if ! _have; then
        _install || return 1
    fi
    if ! sudo -v 2>/dev/null; then
        echo "${C_RED}sudo required${C_RST}" >&2
        return 1
    fi
    echo "${C_DIM}Running full lynis audit (~2-3 min, streaming)...${C_RST}"
    sudo lynis audit system --no-colors
    echo
    _score
}

case "${1:-}" in
    ""|"--quick")  _run_quick ;;
    --full)        _run_full ;;
    --score)       _score ;;
    --suggestions|--suggest) _suggestions ;;
    --warnings)    _warnings ;;
    --status)      _status ;;
    --install)     _install ;;
    --ai)          fox-ai-audit ;;
    -h|--help|help) cat <<EOF
fox audit — lynis hardening posture audit

  fox audit                quick scan (~30-60s); score + top 5 suggestions
  fox audit --full         full audit (~2-3 min), streams output
  fox audit --score        hardening_index from last run (no scan)
  fox audit --suggestions  full suggestion list from last run
  fox audit --warnings     warnings from last run
  fox audit --status       lynis version + last-run timestamp + score
  fox audit --install      install lynis (extra repo, idempotent)
  fox audit --ai           AI-powered explanation of findings

Notes:
  • Hardening index is 0-100. >=85 is excellent for a desktop / dev box;
    70-85 is normal; <70 means there are quick wins available.
  • Suggestions are advisory — read each one before acting.
  • lynis is read-only — it audits but never modifies the system.
  • Report: ${REPORT}    Log: ${LOG}
EOF
    ;;
    *) echo "unknown: $1  (try: fox audit --help)" >&2; exit 2 ;;
esac
