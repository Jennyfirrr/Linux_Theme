#!/usr/bin/env bash
# fox-honeypot — Cowrie SSH honeypot wrapper.
#
# Real attackers who get past Endlessh + brute-force lockout sometimes
# try harder. Cowrie pretends to be a real SSH server (emulates a
# basic shell + fake filesystem); every command an attacker types
# gets logged to disk + dispatched to your phone.
#
# Layout:
#   /opt/cowrie               git checkout + Python venv
#   /etc/cowrie               config (cowrie.cfg)
#   /var/log/cowrie           session logs + downloaded payloads
#   systemd unit              cowrie.service (running as cowrie user)
#
# Default port: 2222 (Cowrie itself can't bind <1024). Use
# `nft / iptables` or a socat redirect to make :22 → :2222 if you want
# the honeypot on the standard SSH port. We pair this with fox spa or
# fox knock keeping the REAL sshd on a custom port — Cowrie absorbs
# all the :22 traffic.

set -u
C_GRN=$'\e[38;5;108m'; C_YEL=$'\e[38;5;221m'; C_RED=$'\e[38;5;167m'; C_DIM=$'\e[2m'; C_RST=$'\e[0m'

INSTALL_DIR=/opt/cowrie
SERVICE=/etc/systemd/system/cowrie.service
LOG_DIR=/var/log/cowrie

_require_deps() {
    local missing=()
    for pkg in python python-virtualenv git; do
        command -v "$pkg" >/dev/null 2>&1 || missing+=("$pkg")
    done
    if (( ${#missing[@]} > 0 )); then
        echo "${C_RED}missing: ${missing[*]}${C_RST}" >&2
        echo "  install:  sudo pacman -S ${missing[*]}" >&2
        return 1
    fi
}

_enable() {
    _require_deps || return 1
    if ! id cowrie &>/dev/null; then
        sudo useradd -r -m -d /home/cowrie -s /usr/bin/nologin cowrie
        echo "  + cowrie system user created"
    fi
    if [[ ! -d "$INSTALL_DIR" ]]; then
        sudo install -d -o cowrie -g cowrie "$INSTALL_DIR"
        sudo -u cowrie git clone --depth 1 https://github.com/cowrie/cowrie.git "$INSTALL_DIR" 2>&1 | tail -3
        sudo -u cowrie bash -c "cd $INSTALL_DIR && python -m venv cowrie-env && cowrie-env/bin/pip install --quiet --upgrade pip && cowrie-env/bin/pip install --quiet -r requirements.txt"
        sudo cp "$INSTALL_DIR/etc/cowrie.cfg.dist" "$INSTALL_DIR/etc/cowrie.cfg"
        # Listen on 2222 (default). bind to 0.0.0.0 so external attackers reach us.
        sudo sed -i 's/^#listen_endpoints.*$/listen_endpoints = tcp:2222:interface=0.0.0.0/' "$INSTALL_DIR/etc/cowrie.cfg"
        sudo chown -R cowrie:cowrie "$INSTALL_DIR"
        echo "  + cowrie checked out + venv installed in $INSTALL_DIR"
    fi
    sudo install -d -o cowrie -g cowrie "$LOG_DIR"

    sudo tee "$SERVICE" >/dev/null <<EOF
[Unit]
Description=Cowrie SSH honeypot (foxml)
After=network-online.target

[Service]
Type=simple
User=cowrie
Group=cowrie
WorkingDirectory=$INSTALL_DIR
ExecStart=$INSTALL_DIR/cowrie-env/bin/twistd -y $INSTALL_DIR/cowrie.tac --pidfile=$INSTALL_DIR/cowrie.pid -n
Restart=on-failure
RestartSec=5

# Sandbox the honeypot itself (it's running attacker-supplied input).
NoNewPrivileges=true
ProtectHome=true
ProtectSystem=strict
PrivateTmp=true
ReadWritePaths=$INSTALL_DIR $LOG_DIR

[Install]
WantedBy=multi-user.target
EOF
    sudo systemctl daemon-reload
    sudo systemctl enable --now cowrie.service >/dev/null 2>&1
    sudo ufw allow 2222/tcp >/dev/null 2>&1
    if systemctl is-active --quiet cowrie; then
        echo "${C_GRN}✓ cowrie honeypot active on :2222${C_RST}"
        echo "  ${C_DIM}logs:  $LOG_DIR/cowrie.log${C_RST}"
        echo "  ${C_DIM}redirect :22 → :2222 with: sudo iptables -t nat -A PREROUTING -p tcp --dport 22 -j REDIRECT --to-port 2222${C_RST}"
    else
        echo "${C_YEL}! cowrie failed to start — check: systemctl status cowrie${C_RST}"
    fi
}

_disable() {
    sudo systemctl disable --now cowrie 2>/dev/null
    sudo ufw delete allow 2222/tcp 2>/dev/null
    echo "${C_GRN}✓ cowrie stopped (logs + install kept in $INSTALL_DIR)${C_RST}"
}

_status() {
    if systemctl is-active --quiet cowrie 2>/dev/null; then
        echo "  cowrie:  ${C_GRN}active${C_RST}"
        local n; n=$(sudo wc -l < "$LOG_DIR/cowrie.log" 2>/dev/null || echo 0)
        echo "  log lines: $n"
        local sessions
        sessions=$(sudo grep -c 'New connection' "$LOG_DIR/cowrie.log" 2>/dev/null || echo 0)
        echo "  total sessions caught: $sessions"
    else
        echo "  cowrie:  ${C_RED}inactive${C_RST}"
    fi
}

_log() {
    sudo tail -n 50 "$LOG_DIR/cowrie.log" 2>/dev/null || echo "no log yet"
}

case "${1:-}" in
    ""|status)   _status ;;
    --enable)    _enable ;;
    --disable)   _disable ;;
    log)         _log ;;
    -h|--help|help) cat <<EOF
fox honeypot — Cowrie SSH honeypot

  fox honeypot [status]    service state + session count
  fox honeypot --enable    install + start (binds :2222 by default)
  fox honeypot --disable   stop + remove ufw rule (keeps logs)
  fox honeypot log         tail recent activity

After --enable, redirect :22 → :2222 with:
  sudo iptables -t nat -A PREROUTING -p tcp --dport 22 -j REDIRECT --to-port 2222

Pair with fox spa / fox knock keeping real sshd on a custom port.
Endlessh stalls scanners; Cowrie catches the persistent ones.
EOF
    ;;
    *) echo "unknown: $1" >&2; exit 2 ;;
esac
