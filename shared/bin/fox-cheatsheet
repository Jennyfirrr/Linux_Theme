#!/usr/bin/env bash
# fox-cheatsheet — searchable keybind reference via rofi.
#
# Parses KEYBINDS.md tables (which have hand-curated descriptions) and
# pipes "KEY  →  ACTION" lines into rofi. Fuzzy-search for what you
# need; press Enter and the keybind is copied to your clipboard so you
# can paste it as a reminder, or just dismiss with Esc.
#
# Sources, in priority order:
#   1. ~/.local/share/foxml/KEYBINDS.md   (deployed by install.sh)
#   2. ~/code/Linux_Theme/KEYBINDS.md     (developer machine fallback)
#
# Usage: fox-cheatsheet                 (full set, all sections)
#        fox-cheatsheet hyprland        (filter to one section, case-insensitive)

set -euo pipefail

# ───── Locate KEYBINDS.md ──────────────────────────────────────────
KEYBINDS_FILE=""
for candidate in \
    "${HOME}/.local/share/foxml/KEYBINDS.md" \
    "${HOME}/code/Linux_Theme/KEYBINDS.md"; do
    if [[ -f "$candidate" ]]; then
        KEYBINDS_FILE="$candidate"
        break
    fi
done

if [[ -z "$KEYBINDS_FILE" ]]; then
    notify-send -u critical "fox-cheatsheet" "KEYBINDS.md not found in any expected location"
    exit 1
fi

# ───── Optional section filter ─────────────────────────────────────
FILTER="${1:-}"

# ───── Parse markdown tables ───────────────────────────────────────
# Recognizes rows of the form:
#   | `KEY` | DESCRIPTION |
# while tracking the current `## ` and `### ` headers so each entry
# carries its section context. Skips header rows (e.g. `| Key | Action |`)
# and divider rows (e.g. `|-----|--------|`).
parse_keybinds() {
    awk -v filter="${FILTER,,}" '
        /^## / {
            sub(/^## */, "")
            section_h2 = $0
            section = section_h2
            # Skip filtering once we hit a non-matching section
            in_filter = (filter == "" || tolower(section_h2) ~ filter)
            next
        }
        /^### / {
            sub(/^### */, "")
            section_h3 = $0
            section = section_h2 " · " section_h3
            next
        }
        # Match: | `key` | description |  (table data row, key in backticks)
        /^\| `[^`]+` *\|/ {
            if (!in_filter) next
            # Extract key between first pair of backticks
            key = $0
            sub(/^\| *`/, "", key)
            sub(/` *\|.*$/, "", key)
            # Extract description (everything between the second `|` and the closing `|`)
            desc = $0
            sub(/^\| *`[^`]+` *\| */, "", desc)
            sub(/ *\| *$/, "", desc)
            # Strip markdown emphasis markers from the description
            gsub(/\*\*/, "", desc)
            gsub(/`/, "", desc)
            printf "%-22s   %s\t%s\n", key, desc, section
        }
    ' "$KEYBINDS_FILE"
}

ENTRIES="$(parse_keybinds)"
if [[ -z "$ENTRIES" ]]; then
    notify-send "fox-cheatsheet" "No keybinds matched filter: ${FILTER:-<none>}"
    exit 1
fi

# ───── Pipe to rofi (matches SysHub styling) ──────────────────────
# Anchor top-left like the hub, but wider since rows are key + description.
# Inputbar stays visible so you see what you're filtering on. Vim nav via
# Ctrl+J / Ctrl+K (set in glass.rasi); bare j/k stay free for search.
ROFI_THEME="${HOME}/.config/rofi/glass.rasi"
ROFI_X="${ROFI_X:-12}"
ROFI_Y="${ROFI_Y:-40}"

THEME_STR="window {
    location: north west; anchor: north west;
    x-offset: ${ROFI_X}px; y-offset: ${ROFI_Y}px;
    width: 50%;
}
listview { lines: 18; }
inputbar { children: [prompt, entry]; }"

ROFI_ARGS=(
    -dmenu -i -no-custom -p "Cheatsheet"
    -mesg "Type to search · Enter copies the key combo · Esc cancels"
    -theme-str "$THEME_STR"
)
[[ -f "$ROFI_THEME" ]] && ROFI_ARGS=(-theme "$ROFI_THEME" "${ROFI_ARGS[@]}")

# Display columns: KEY | description (section in tooltip via -mesg)
SELECTED="$(printf '%s\n' "$ENTRIES" \
    | awk -F'\t' '{print $1}' \
    | rofi "${ROFI_ARGS[@]}" \
    || true)"

[[ -z "$SELECTED" ]] && exit 0

# Strip the description column to get just the key combo, then trim
KEY="$(echo "$SELECTED" | awk '{print $1; for(i=2;i<=NF;i++){if($i ~ /^\+$/ || $i=="Shift" || $i=="Ctrl" || $i=="Alt" || $i ~ /^[A-Za-z0-9_+]+$/) printf " %s", $i; else break}}' | xargs)"
# Fallback if heuristic fails: take the whole left column
[[ -z "$KEY" ]] && KEY="$(echo "$SELECTED" | sed -E 's/   .*$//' | xargs)"

# Copy to clipboard for paste-as-reminder, plus a notification
if command -v wl-copy >/dev/null 2>&1; then
    printf '%s' "$KEY" | wl-copy
    notify-send -t 2500 "fox-cheatsheet" "Copied: $KEY"
fi
