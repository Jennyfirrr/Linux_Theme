#!/usr/bin/env bash
# fox-audit-timer — install/manage a weekly fox doctor drift audit.
#
# Drops a systemd user timer that runs `fox doctor` weekly. If the
# warning/fail count INCREASES compared to last week, fires a
# fox-dispatch alert so you find out within days that something
# flipped (UFW disabled, fail2ban died, etc.) instead of months later.
#
# State: ~/.config/foxml/audit-baseline.txt (line count of last clean run)
#
# Usage:
#   fox audit-timer --install      enable weekly run
#   fox audit-timer --uninstall    disable
#   fox audit-timer --status
#   fox audit-timer run            run once now (used by the timer)

set -u
C_GRN=$'\e[38;5;108m'; C_YEL=$'\e[38;5;221m'; C_RED=$'\e[38;5;167m'; C_DIM=$'\e[2m'; C_RST=$'\e[0m'

UNIT_DIR="$HOME/.config/systemd/user"
SERVICE="fox-audit.service"
TIMER="fox-audit.timer"
BASELINE="$HOME/.config/foxml/audit-baseline.txt"
LAST_REPORT="$HOME/.local/share/foxml/audit-last-report.txt"

_install() {
    mkdir -p "$UNIT_DIR"
    cat > "$UNIT_DIR/$SERVICE" <<EOF
[Unit]
Description=fox-audit — weekly fox doctor drift check

[Service]
Type=oneshot
ExecStart=$(command -v fox-audit-timer) run
EOF
    cat > "$UNIT_DIR/$TIMER" <<EOF
[Unit]
Description=fox-audit weekly drift check

[Timer]
OnCalendar=weekly
Persistent=true
RandomizedDelaySec=1h

[Install]
WantedBy=timers.target
EOF
    systemctl --user daemon-reload
    systemctl --user enable --now "$TIMER"
    echo "${C_GRN}✓ fox-audit.timer enabled (weekly)${C_RST}"
    echo "  ${C_DIM}next run:  systemctl --user list-timers fox-audit.timer${C_RST}"
}

_uninstall() {
    systemctl --user disable --now "$TIMER" 2>/dev/null || true
    rm -f "$UNIT_DIR/$SERVICE" "$UNIT_DIR/$TIMER"
    systemctl --user daemon-reload 2>/dev/null || true
    echo "${C_GRN}✓ fox-audit disabled${C_RST}"
}

_status() {
    if systemctl --user is-enabled --quiet "$TIMER" 2>/dev/null; then
        echo "  timer:   ${C_GRN}enabled${C_RST}"
        systemctl --user list-timers --no-pager "$TIMER" 2>/dev/null | head -3 | sed 's/^/  /'
    else
        echo "  timer:   ${C_YEL}not installed${C_RST}"
    fi
    if [[ -f "$BASELINE" ]]; then
        echo "  baseline: $(<"$BASELINE") warning(s) at $(stat -c %y "$BASELINE" 2>/dev/null | cut -d. -f1)"
    fi
    if [[ -f "$LAST_REPORT" ]]; then
        echo "  last run: $(stat -c %y "$LAST_REPORT" 2>/dev/null | cut -d. -f1)"
    fi
}

_run() {
    mkdir -p "$(dirname "$BASELINE")" "$(dirname "$LAST_REPORT")"
    local report
    report=$(fox-doctor 2>&1)
    printf '%s\n' "$report" > "$LAST_REPORT"

    local cur_warns cur_fails
    cur_warns=$(echo "$report" | grep -cE '^[[:space:]]+! ' || true)
    cur_fails=$(echo "$report" | grep -cE '^[[:space:]]+X ' || true)

    local baseline_warns=0
    [[ -f "$BASELINE" ]] && baseline_warns=$(<"$BASELINE")

    local message=""
    if (( cur_fails > 0 )); then
        message="fox doctor: $cur_fails FAILED + $cur_warns warning(s) on $(hostname). Drift since last audit."
    elif (( cur_warns > baseline_warns )); then
        message="fox doctor: $cur_warns warning(s) (was $baseline_warns) on $(hostname). New drift."
    fi

    if [[ -n "$message" ]]; then
        # Fire dispatch alert (silent no-op if not configured).
        fox-dispatch "weekly-audit" "$message" 2>/dev/null || true
        notify-send -u normal -t 8000 "fox audit" "$message" 2>/dev/null || true
        # Don't update baseline on drift — keep it pinned at the last clean state.
    else
        # Clean run; update baseline.
        echo "$cur_warns" > "$BASELINE"
        fox-dispatch "weekly-audit" "fox doctor: clean ($cur_warns warning(s), 0 failed) on $(hostname)" 2>/dev/null || true
    fi
}

case "${1:-}" in
    --install)    _install ;;
    --uninstall)  _uninstall ;;
    --status)     _status ;;
    run)          _run ;;
    -h|--help|"") cat <<EOF
fox audit-timer — weekly fox doctor drift audit + dispatch alert

  fox audit-timer --install      enable weekly run
  fox audit-timer --uninstall    disable
  fox audit-timer --status       timer + last-baseline state
  fox audit-timer run            run once now

Drift logic: counts ! / X lines in fox doctor output. If today's
count exceeds the recorded baseline, fires fox-dispatch with the
delta. Baseline only updates on clean runs — so a regression stays
pinned until you actually fix it.
EOF
    ;;
    *) echo "unknown: $1" >&2; exit 2 ;;
esac
