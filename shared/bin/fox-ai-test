#!/usr/bin/env bash
# fox-ai-test — generate unit tests for a function or file.
#
# Usage: fox-ai-test path/to/source.cpp
#        fox-ai-test path/to/source.py
#
# Auto-detects the test framework by language + project conventions:
#   .cpp / .h / .hpp → Catch2 (FoxML C++ projects use it)
#   .py              → pytest
# Prints generated tests to stdout. Pipe to a file or paste into the
# matching tests/ directory — no auto-write to avoid clobbering.

set -u

if ! command -v ollama >/dev/null 2>&1; then
    echo "fox-ai-test: ollama not installed" >&2
    exit 1
fi

MODEL="${FOXAI_MODEL:-}"
if [[ -z "$MODEL" ]] && [[ -f "$HOME/.config/opencode/opencode.json" ]] && command -v jq >/dev/null 2>&1; then
    MODEL=$(jq -r '.model // empty' "$HOME/.config/opencode/opencode.json" 2>/dev/null | sed 's|^ollama/||')
fi
MODEL="${MODEL:-qwen2.5-coder:7b}"

if [[ $# -lt 1 || ! -f "$1" ]]; then
    echo "usage: fox-ai-test <path/to/source-file>" >&2
    exit 2
fi

src="$1"
ext="${src##*.}"
case "$ext" in
    cpp|cc|cxx|h|hpp) framework="Catch2 (use TEST_CASE / REQUIRE / SECTION)" ;;
    py)               framework="pytest (use plain `def test_*` functions, parametrize where useful)" ;;
    *)                framework="the natural test framework for $ext" ;;
esac

content=$(cat "$src")
prompt="Generate unit tests for the source below using $framework. Cover:
- Happy paths for each public function / class.
- Boundary cases (zero, negative, max, empty input).
- Error / exception paths if the API raises.
- For numeric code, include precision edge cases.
- For container code, include a single-element and a large-N case.

Output ONLY the test file content, no commentary, no markdown fences.

SOURCE (${src}):
$content"

ollama run "$MODEL" "$prompt" 2>/dev/null
