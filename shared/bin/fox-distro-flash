#!/bin/bash
# fox-distro-flash — Safe flashing utility for the FoxML ISO

ISO_FILE="/home/caramel/code/FoxML_Workstation/distro/out/FoxML-OS-$(date +%Y.%m.%d)-x86_64.iso"

# Try to find the latest ISO if the dated one doesn't exist
if [[ ! -f "$ISO_FILE" ]]; then
    ISO_FILE=$(ls -t /home/caramel/code/FoxML_Workstation/distro/out/*.iso 2>/dev/null | head -n 1)
fi

if [[ -z "$ISO_FILE" ]]; then
    echo "Error: No ISO found in distro/out/. Run 'ai-distro-build' first."
    exit 1
fi

echo "FoxML OS — USB Flasher"
echo "----------------------"
echo "ISO: $(basename "$ISO_FILE")"
echo ""

# List potential USB drives
echo "Detected USB Devices:"
lsblk -pno NAME,MODEL,SIZE,TRAN | grep "usb" || { echo "No USB drives detected."; exit 1; }
echo ""

read -p "Enter the device path to flash (e.g., /dev/sdb): " TARGET_DEV

if [[ -z "$TARGET_DEV" ]]; then
    echo "Aborted."
    exit 1
fi

if [[ ! -b "$TARGET_DEV" ]]; then
    echo "Error: $TARGET_DEV is not a valid block device."
    exit 1
fi

echo "!!! WARNING: ALL DATA ON $TARGET_DEV WILL BE PERMANENTLY DELETED !!!"
read -p "Are you absolutely sure? [y/N] " -n 1 -r
echo ""
if [[ ! $REPLY =~ ^[Yy]$ ]]; then
    echo "Aborted."
    exit 1
fi

# Ensure it's not the OS drive
if [[ "$TARGET_DEV" == "/dev/sda" || "$TARGET_DEV" == "/dev/nvme"* ]]; then
    echo "Error: Safety check failed. $TARGET_DEV looks like a system drive."
    exit 1
fi

echo "Flashing FoxML OS... This may take a few minutes."
sudo dd if="$ISO_FILE" of="$TARGET_DEV" bs=4M status=progress oflag=sync

echo ""
echo "Done! You can now boot from this USB to deploy FoxML OS."
