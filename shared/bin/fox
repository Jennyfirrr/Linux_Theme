#!/bin/bash
# Unified FoxML Command Wrapper

FOXML_DIR="$HOME/code/Linux_Theme"

if [[ ! -d "$FOXML_DIR" ]]; then
    echo "Error: FoxML directory not found at $FOXML_DIR"
    exit 1
fi

case "$1" in
    install|setup)
        shift
        # `exec` instead of running as child: install.sh overwrites
        # ~/.local/bin/fox during the shared/bin deploy loop. With a
        # regular `cd && ./install.sh`, the parent fox process keeps
        # reading from the now-rewritten file and bash spits out a
        # confusing "syntax error near unexpected token" partway
        # through install. exec replaces this process so there's no
        # stale file handle to read from.
        cd "$FOXML_DIR" && exec ./install.sh "$@"
        ;;
    swap)
        shift
        cd "$FOXML_DIR" && exec ./swap.sh "$@"
        ;;
    update|save)
        shift
        cd "$FOXML_DIR" && exec ./update.sh "$@"
        ;;
    rollback)
        shift
        cd "$FOXML_DIR" && exec ./shared/bin/fox-rollback "$@"
        ;;
    lock)
        shift
        exec fox-lock "$@"
        ;;
    doctor)
        shift
        exec fox-doctor "$@"
        ;;
    develop|dev)
        shift
        exec fox-develop "$@"
        ;;
    menu)
        shift
        exec fox-menu "$@"
        ;;
    test)
        shift
        exec fox-test "$@"
        ;;
    uninstall|remove)
        shift
        exec fox-uninstall "$@"
        ;;
    sandbox)
        shift
        exec fox-sandbox "$@"
        ;;
    init)
        shift
        exec fox-init "$@"
        ;;
    overwatch)
        shift
        exec fox-overwatch "$@"
        ;;
    ports)
        shift
        exec fox-ports "$@"
        ;;
    dispatch)
        shift
        exec fox-dispatch "$@"
        ;;
    tripwire)
        shift
        exec fox-tripwire "$@"
        ;;
    bouncer)
        shift
        exec fox-bouncer "$@"
        ;;
    sentry-audit)
        shift
        exec fox-sentry-audit "$@"
        ;;
    knock)
        shift
        exec fox-knock "$@"
        ;;
    deadman)
        shift
        exec fox-deadman "$@"
        ;;
    usb)
        shift
        exec fox-usb "$@"
        ;;
    jail)
        shift
        exec fox-jail "$@"
        ;;
    mac)
        shift
        exec fox-mac "$@"
        ;;
    vault)
        shift
        exec fox-vault "$@"
        ;;
    fingerprint|fp)
        shift
        exec fox-fingerprint "$@"
        ;;
    vpn)
        shift
        exec fox-vpn "$@"
        ;;
    offline)
        shift
        exec fox-offline "$@"
        ;;
    harden)
        shift
        exec fox-harden "$@"
        ;;
    firewall)
        shift
        exec fox-firewall "$@"
        ;;
    cafe|cafe-mode)
        shift
        exec fox-cafe "$@"
        ;;
    spa)
        shift
        exec fox-spa "$@"
        ;;
    dns-shield|dns)
        shift
        exec fox-dns-shield "$@"
        ;;
    snitch)
        shift
        exec fox-snitch "$@"
        ;;
    honeypot)
        shift
        exec fox-honeypot "$@"
        ;;
    arm|lockdown-all)
        shift
        exec fox-arm "$@"
        ;;
    proximity)
        shift
        exec fox-proximity "$@"
        ;;
    backup)
        shift
        exec fox-backup "$@"
        ;;
    honey)
        shift
        exec fox-honey "$@"
        ;;
    audit-timer)
        shift
        exec fox-audit-timer "$@"
        ;;
    build-verify)
        shift
        exec fox-build-verify "$@"
        ;;
    allowlist)
        shift
        exec fox-allowlist "$@"
        ;;
    dnssec)
        shift
        exec fox-dnssec "$@"
        ;;
    sec|security)
        shift
        exec fox-sec "$@"
        ;;
    audit|lynis)
        shift
        exec fox-audit "$@"
        ;;
    help|--help|-h)
        # `fox help <command>` → forward to the tool's own help.
        # Falls through to the full overview below when no <command>
        # is given, matching the existing behaviour.
        if [[ -n "${2:-}" ]]; then
            shift
            sub="$1"
            # Look up the binary for this subcommand; mirror the
            # routing table above for the common aliases.
            case "$sub" in
                fp|fingerprint)     exec fox-fingerprint --help ;;
                dns|dns-shield)     exec fox-dns-shield --help ;;
                cafe|cafe-mode)     exec fox-cafe --help ;;
                sec|security)       exec fox-sec --help ;;
                install|setup)      exec ./install.sh --help 2>/dev/null \
                                    || exec "$FOXML_DIR/install.sh" --help ;;
                *)
                    if command -v "fox-$sub" >/dev/null 2>&1; then
                        exec "fox-$sub" --help
                    else
                        echo "no per-command help for: $sub"
                        echo "(run \`fox help\` for the full overview)"
                        exit 2
                    fi
                    ;;
            esac
        fi
        ;&    # fall through to the overview block
    "")
        echo "FoxML CLI - Unified Theme Manager"
        echo "Usage: fox <command> [args]"
        echo ""
        echo "Core Commands:"
        echo "  install [theme]  Run the main installer (e.g., fox install FoxML_Classic --deps)"
        echo "  swap             Open the interactive theme switcher"
        echo "  update           Save current live config edits back into templates"
        echo "  rollback         Restore configs from a previous backup"
        echo "  lock             Pre-checked screen lock (dbus/awww sanity + hyprlock)"
        echo "  doctor           Diagnose config drift (nvim, hyprland, waybar, multi-monitor)"
        echo "  develop          Toggle dev mode (symlink shared/ → live config for fast iteration)"
        echo "  menu             Rofi-based launcher for all fox-* commands"
        echo "  test             Run shellcheck + roundtrip + fox-doctor (CI gate)"
        echo "  uninstall        Remove fox binaries + services + state (keeps user configs)"
        echo "  sandbox          Rofi picker for disposable firejail-wrapped apps"
        echo "  init <name>      Open workspace + tmux + nvim + index (one-touch project onboarding)"
        echo "  overwatch        Inspect/reset the waybar Hardware Overwatch baseline"
        echo "  ports            UFW port manager (list / listeners / audit / allow / deny / delete)"
        echo "  dispatch         Send a notification to phone via Discord/Telegram webhook"
        echo "  tripwire         Honeypot-file watcher (--install / --status / --uninstall)"
        echo "  bouncer          USB-block alerts while screen locked (--install / --status)"
        echo "  sentry-audit     Kernel-level honeypot via auditd (--install / --status)"
        echo "  knock            Port knocking configurator + trigger (--setup / --status / --reveal)"
        echo "  deadman          USB-tethered panic trigger (--setup / --status / --disarm)"
        echo "  usb              USBGuard wrapper (list / pending / allow / block / refresh / watch)"
        echo "  jail             Firejail manager (add/rm wrappers, list sandboxes, restart firefox)"
        echo "  mac              NetworkManager MAC randomization (global + per-SSID overrides)"
        echo "  vault            Password store (pass) wrapper — init / lock / audit"
        echo "  fingerprint      fprintd wrapper — enroll / delete / test / status"
        echo "  vpn              WireGuard manager + UFW kill-switch (up / down / killswitch)"
        echo "  offline          Run a command in a network-blackholed namespace (untrusted code sandbox)"
        echo "  harden           Toggle kernel/userspace hardening layers (hidepid/noexec/iommu/coredumps)"
        echo "  firewall         Egress filtering — fox firewall lockdown / unlock / allow <port>"
        echo "  cafe             Auto-tighten on untrusted wifi (NetworkManager dispatcher)"
        echo "  spa              Single Packet Authorization (fwknop) — replay-immune SSH gating"
        echo "  dns-shield       Local DNS sinkhole — StevenBlack blocklist via /etc/hosts"
        echo "  snitch           OpenSnitch per-app outbound firewall (--enable / --status / log)"
        echo "  honeypot         Cowrie SSH honeypot (--enable / --status / log)"
        echo "  arm              One-command lockdown — enable every opt-in defense interactively"
        echo "  proximity        Bluetooth proximity auto-lock (--setup / --status / --disable)"
        echo "  backup           GPG-encrypted tar of opt-in config (--list / --restore)"
        echo "  honey            Plant fake-credential honeytokens in repo dirs (audited)"
        echo "  audit-timer      Weekly fox doctor drift check + phone alert (--install)"
        echo "  build-verify     Reproducible-build record/verify for C++ projects"
        echo "  allowlist        fapolicyd executable allowlist (--enable / --enforce / --learn)"
        echo "  dnssec           DNSSEC strictness picker — fox dnssec 0/1/2 or off/relaxed/strict"
        echo "  sec              Unified security dashboard (alerts, posture, bans, listeners, failed auth)"
        echo "  audit            Run lynis hardening audit — score (0-100) + suggestions"
        echo ""
        echo "Per-command help: ${0##*/} help <command>   (e.g. fox help dispatch)"
        echo ""
        echo "Custom Tools (found in ~/.local/bin):"
        for cmd in "$HOME/.local/bin/"fox-* "$HOME/.local/bin/"fask "$HOME/.local/bin/"findex "$HOME/.local/bin/"fhelp; do
            if [[ -x "$cmd" && -f "$cmd" && "$(basename "$cmd")" != "fox-rollback" && "$(basename "$cmd")" != "fox" ]]; then
                base="$(basename "$cmd")"
                desc=""
                if [[ "$base" == "fask" ]]; then
                    desc="Query the FoxML Intelligence Layer (AI model)"
                elif [[ "$base" == "findex" ]]; then
                    desc="Rebuild the vector index for AI semantic search"
                else
                    desc=$(sed -n '2p' "$cmd" 2>/dev/null | grep '^#' | sed -E 's/^#[[:space:]]*[^—-]+[—-]+[[:space:]]*//')
                fi
                if [[ -n "$desc" && "$desc" != "#"* ]]; then
                    printf "  %-22s %s\n" "$base" "$desc"
                else
                    printf "  %-22s\n" "$base"
                fi
            fi
        done
        echo ""
        echo "Run 'fox help' to show this message again."
        ;;
    *)
        echo "Unknown command: $1"
        echo "Run 'fox help' for usage."
        exit 1
        ;;
esac
