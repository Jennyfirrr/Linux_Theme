#!/usr/bin/env bash
# fox-dns-shield — local DNS sinkhole using systemd-resolved.
#
# Pulls a blocklist (StevenBlack/hosts unified) and feeds it to
# systemd-resolved as a "split DNS" zone where every blocked domain
# resolves to 127.0.0.1 / ::1. Network-wide adblock + malware blocker
# with no external server.
#
# Pairs with our DoH config (DNS-over-HTTPS upstream): blocklist
# matches happen LOCALLY before the encrypted DoH query, so a known
# malware C&C domain never leaves the laptop.
#
# Usage:
#   fox dns-shield --enable        download list + install drop-in
#   fox dns-shield --refresh       re-download list (run weekly)
#   fox dns-shield --status        # of entries + last refresh
#   fox dns-shield --test <host>   check if <host> is blocked
#   fox dns-shield --disable       remove drop-in
#
# Config: ~/.config/foxml/dns-shield.conf
#   FEED_URL=https://raw.githubusercontent.com/StevenBlack/hosts/master/hosts
#   ALLOW_DOMAINS="github.com discord.com"     # always allow these

set -u
C_GRN=$'\e[38;5;108m'; C_YEL=$'\e[38;5;221m'; C_RED=$'\e[38;5;167m'; C_DIM=$'\e[2m'; C_RST=$'\e[0m'

CONF_DIR="$HOME/.config/foxml"
CONF="$CONF_DIR/dns-shield.conf"
DROPIN=/etc/systemd/resolved.conf.d/99-foxml-shield.conf
BLOCKLIST=/etc/foxml/dns-shield/blocklist.hosts

DEFAULT_FEED="https://raw.githubusercontent.com/StevenBlack/hosts/master/hosts"

_load() {
    FEED_URL="$DEFAULT_FEED"; ALLOW_DOMAINS=""
    [[ -f "$CONF" ]] || return 0
    # shellcheck disable=SC1090
    source "$CONF"
}

_refresh_list() {
    _load
    sudo install -d /etc/foxml/dns-shield
    echo "${C_DIM}downloading $FEED_URL ...${C_RST}"
    local tmp
    tmp=$(mktemp)
    if ! curl -sSfL -m 30 "$FEED_URL" -o "$tmp"; then
        echo "${C_RED}download failed${C_RST}" >&2
        rm -f "$tmp"; return 1
    fi

    # Hash-pin guard. If the new feed's SHA256 is >5% smaller than the
    # last-applied feed, refuse to apply. Catches a maintainer
    # compromise that silently sinkholes critical domains
    # (archlinux.org, fox-dispatch webhook hosts, etc.) by dropping
    # most of the legit blocklist content.
    local new_lines old_lines
    new_lines=$(wc -l <"$tmp")
    if [[ -f "$BLOCKLIST" ]]; then
        old_lines=$(wc -l <"$BLOCKLIST")
        if (( old_lines > 1000 )); then
            # Allow growth always; only flag shrinkage >5%.
            local floor=$(( old_lines * 95 / 100 ))
            if (( new_lines < floor )); then
                echo "${C_RED}⚠ feed shrank by >5% ($old_lines → $new_lines lines)${C_RST}" >&2
                echo "  refusing to splice — possible upstream tampering" >&2
                echo "  override:  FOX_DNS_SHIELD_TRUST_SHRINK=1 fox dns-shield --refresh" >&2
                if [[ "${FOX_DNS_SHIELD_TRUST_SHRINK:-}" != "1" ]]; then
                    rm -f "$tmp"
                    return 1
                fi
                echo "  ${C_YEL}(override accepted)${C_RST}" >&2
            fi
        fi
    fi
    # Extract just the blocked domains (one per line). StevenBlack format:
    #   0.0.0.0 example.com
    # Skip comments + localhost entries.
    awk '/^0\.0\.0\.0[[:space:]]/ && $2 != "0.0.0.0" {print $2}' "$tmp" | sort -u > "${tmp}.clean"
    # Strip allowlisted domains.
    for d in $ALLOW_DOMAINS; do
        sed -i "/^${d//./\\.}$/d" "${tmp}.clean"
    done
    local n
    n=$(wc -l < "${tmp}.clean")
    sudo mv "${tmp}.clean" "$BLOCKLIST"
    sudo chmod 644 "$BLOCKLIST"
    rm -f "$tmp"
    echo "${C_GRN}✓ blocklist refreshed: $n entries${C_RST}"
    date -Iseconds | sudo tee "${BLOCKLIST}.timestamp" >/dev/null
}

_apply() {
    # systemd-resolved's split-DNS doesn't natively support a flat
    # blocklist, so we sink it via a wildcard DNSSEC negative trust
    # anchor file. Cleanest approach for a personal laptop: write the
    # blocked names to /etc/hosts with 0.0.0.0 — every resolver in the
    # system (including DoH-routing resolved) checks /etc/hosts first.
    #
    # We MERGE rather than overwrite: keep any user hosts entries,
    # append our blocklist under a guarded sentinel range.
    local hosts=/etc/hosts
    sudo sed -i '/^# foxml-shield BEGIN/,/^# foxml-shield END/d' "$hosts"
    {
        echo "# foxml-shield BEGIN"
        awk '{print "0.0.0.0 " $0}' "$BLOCKLIST"
        echo "# foxml-shield END"
    } | sudo tee -a "$hosts" >/dev/null
    echo "${C_GRN}✓ blocklist spliced into /etc/hosts (resolved checks hosts first)${C_RST}"
}

_enable() {
    mkdir -p "$CONF_DIR" && chmod 700 "$CONF_DIR"
    if [[ ! -f "$CONF" ]]; then
        ( umask 077
          cat > "$CONF" <<EOF
# foxml-managed
FEED_URL=$DEFAULT_FEED
ALLOW_DOMAINS=""
EOF
        )
    fi
    _refresh_list || return 1
    _apply || return 1
    echo "${C_GRN}✓ dns-shield enabled${C_RST}"
    echo "  ${C_DIM}refresh weekly:  fox dns-shield --refresh${C_RST}"
}

_disable() {
    sudo sed -i '/^# foxml-shield BEGIN/,/^# foxml-shield END/d' /etc/hosts
    echo "${C_GRN}✓ dns-shield disabled (blocklist removed from /etc/hosts)${C_RST}"
}

_status() {
    if grep -q '^# foxml-shield BEGIN' /etc/hosts 2>/dev/null; then
        local n
        n=$(awk '/^# foxml-shield BEGIN/,/^# foxml-shield END/' /etc/hosts | wc -l)
        echo "  shield:    ${C_GRN}active${C_RST}"
        echo "  entries:   $((n-2))"
        echo "  refreshed: $(cat ${BLOCKLIST}.timestamp 2>/dev/null || echo '?')"
    else
        echo "  shield:    ${C_YEL}inactive${C_RST}"
    fi
}

_test() {
    local host="$1"
    if grep -qxF "0.0.0.0 $host" /etc/hosts 2>/dev/null; then
        echo "${C_RED}BLOCKED:${C_RST}  $host"
    else
        echo "${C_GRN}allowed:${C_RST} $host"
    fi
}

case "${1:-}" in
    ""|status)   _status ;;
    --enable)    _enable ;;
    --refresh)   _refresh_list && _apply ;;
    --disable)   _disable ;;
    --test)      [[ -n "${2:-}" ]] && _test "$2" || { echo "usage: fox dns-shield --test <host>"; exit 2; } ;;
    -h|--help|help) cat <<EOF
fox dns-shield — local DNS sinkhole (StevenBlack blocklist via /etc/hosts)

  fox dns-shield [status]    entries + last refresh
  fox dns-shield --enable    download list + splice into /etc/hosts
  fox dns-shield --refresh   re-download (run weekly via timer or manually)
  fox dns-shield --disable   remove blocklist from /etc/hosts
  fox dns-shield --test H    check whether host H is blocked

Pairs with --privacy (DoH): blocklist matches happen LOCALLY before
queries leave the laptop, so a known C&C domain never reaches your
upstream resolver.
EOF
    ;;
    *) echo "unknown: $1" >&2; exit 2 ;;
esac
