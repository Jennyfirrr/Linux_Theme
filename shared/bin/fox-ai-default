#!/usr/bin/env bash
# fox-ai-default — set / inspect the default model used by AI-native tools.
#
# Stores the choice at ~/.config/foxml/ai-model.conf. fask, findex, the
# fox-ai-* helpers, and every FoxIntel-backed C++ binary read this file
# at startup. FOXAI_MODEL=<name> in the env overrides on a per-run basis.
#
# Usage:
#   fox-ai-default              # interactive picker (lists installed models)
#   fox-ai-default <model>      # set explicitly
#   fox-ai-default --status     # show current default + installed models
#   fox-ai-default --unset      # remove the override (back to auto-fallback)
#   fox-ai-default --help
#
# Performance varies by model: smaller (7b/14b) is faster + lower-VRAM,
# larger (32b/70b) is smarter but slower.

set -u
CONF_DIR="$HOME/.config/foxml"
CONF_FILE="$CONF_DIR/ai-model.conf"
C_GRN=$'\e[38;5;108m'; C_DIM=$'\e[2m'; C_RST=$'\e[0m'

_current() {
    [[ -f "$CONF_FILE" ]] || return 0
    grep -E '^MODEL=' "$CONF_FILE" 2>/dev/null | head -1 | sed 's/^MODEL=//; s/^"//; s/"$//'
}

_have_ollama() { command -v ollama >/dev/null 2>&1; }

_installed_models() {
    _have_ollama || return 0
    ollama list 2>/dev/null | awk 'NR>1 && NF>0 {print $1}'
}

_write() {
    local model="$1"
    mkdir -p "$CONF_DIR"
    {
        printf '# Default AI model for fask / findex / fox-ai-* / FoxIntel-backed binaries.\n'
        printf '# Set by fox-ai-default. Override per-run with FOXAI_MODEL=<name>.\n'
        printf 'MODEL=%s\n' "$model"
    } > "$CONF_FILE"
    printf '  %s+%s default model → %s\n' "$C_GRN" "$C_RST" "$model"
    printf '  %s+%s config: %s\n' "$C_GRN" "$C_RST" "$CONF_FILE"
    printf '\n  %sNote:%s performance varies by model. Smaller = faster + less VRAM;\n' "$C_DIM" "$C_RST"
    printf '        larger = smarter but slower.\n'
}

_status() {
    local cur
    cur="$(_current || true)"
    if [[ -n "$cur" ]]; then
        printf '  current default: %s\n' "$cur"
    else
        printf '  current default: %s(unset — falls back to qwen2.5-coder:7b)%s\n' "$C_DIM" "$C_RST"
    fi
    printf '\n  installed models:\n'
    if _have_ollama; then
        local out
        out="$(ollama list 2>/dev/null | awk 'NR>1 && NF>0 {printf "    %s  (%s)\n", $1, $3}')"
        if [[ -n "$out" ]]; then
            printf '%s\n' "$out"
        else
            printf '    %s(none yet — try: fox install --models)%s\n' "$C_DIM" "$C_RST"
        fi
    else
        printf '    %s(ollama not installed)%s\n' "$C_DIM" "$C_RST"
    fi
}

case "${1:-}" in
    --status|-s) _status ;;
    --unset)
        rm -f "$CONF_FILE"
        printf '  %s+%s default unset — falls back to qwen2.5-coder:7b\n' "$C_GRN" "$C_RST"
        ;;
    --help|-h)
        sed -n '2,16p' "$0" | sed 's/^# \?//'
        ;;
    "")
        _have_ollama || { echo "ollama not installed — run: fox install --ai" >&2; exit 1; }
        mapfile -t models < <(_installed_models)
        if [[ ${#models[@]} -eq 0 ]]; then
            echo "no models installed — try: fox install --models" >&2
            exit 1
        fi
        cur="$(_current || true)"
        printf '  Current default: %s\n\n' "${cur:-(unset)}"
        printf '  Available models:\n'
        for i in "${!models[@]}"; do
            mark=""
            [[ "${models[$i]}" == "$cur" ]] && mark=" ${C_GRN}●${C_RST}"
            printf '  %2d) %s%s\n' "$((i+1))" "${models[$i]}" "$mark"
        done
        printf '\n'
        read -rp "  Pick [1-${#models[@]}, q to quit]: " choice
        case "$choice" in
            q|Q|"") echo "  cancelled."; exit 0 ;;
        esac
        if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= ${#models[@]} )); then
            _write "${models[$((choice-1))]}"
        else
            echo "  invalid choice." >&2; exit 1
        fi
        ;;
    -*)
        echo "fox-ai-default: unknown flag: $1" >&2
        echo "Try: fox-ai-default --help" >&2
        exit 2
        ;;
    *)
        if _have_ollama && ! _installed_models | grep -qFx "$1"; then
            printf '  ! %s not installed locally. Pull first with: ollama pull %s\n' "$1" "$1" >&2
            read -rp "  Continue anyway? [y/N] " yn
            case "${yn,,}" in
                y|yes) ;;
                *) echo "  cancelled."; exit 1 ;;
            esac
        fi
        _write "$1"
        ;;
esac
