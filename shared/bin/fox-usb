#!/usr/bin/env bash
# fox-usb — friendly wrapper around usbguard.
#
# Quick allow / block / refresh for the device allowlist that
# usbguard enforces. Without this, the install-time auto-policy is
# the ONLY allowlist — every newly bought mouse, keyboard, or USB
# drive shows up as blocked until you manually run usbguard.
#
# Usage:
#   fox usb                 list all known devices (allowed + blocked)
#   fox usb pending         just the currently-blocked ones
#   fox usb allow <id>      permanently allow device <id>
#   fox usb allow-once <id> one-shot allow until next reboot
#   fox usb block <id>      block + remember
#   fox usb refresh         re-generate policy from currently-plugged devices
#   fox usb watch           live tail of usbguard events
#   fox usb log             recent journal entries

set -u

C_BOLD=$'\e[1m'
C_DIM=$'\e[2m'
C_PEACH=$'\e[38;5;215m'
C_GRN=$'\e[38;5;108m'
C_YEL=$'\e[38;5;221m'
C_RED=$'\e[38;5;167m'
C_RST=$'\e[0m'

_check_sudo() {
    if sudo -n true 2>/dev/null; then return 0; fi
    if [[ -t 0 ]] && sudo -v 2>/dev/null; then return 0; fi
    echo "${C_RED}sudo required for usbguard operations${C_RST}" >&2
    return 1
}

_list() {
    _check_sudo || return 1
    sudo usbguard list-devices 2>/dev/null | sed 's/^/  /'
}

_pending() {
    _check_sudo || return 1
    echo "${C_BOLD}Pending (blocked) devices:${C_RST}"
    local out
    out=$(sudo usbguard list-devices -b 2>/dev/null)
    if [[ -z "$out" ]]; then
        echo "${C_GRN}  ✓ none — all plugged devices are allowed${C_RST}"
    else
        echo "$out" | sed 's/^/  /'
        echo
        echo "${C_DIM}Allow one: fox usb allow <id>     (use the integer at the start of each line)${C_RST}"
    fi
}

_allow() {
    local id="$1" mode="${2:-permanent}"
    [[ "$id" =~ ^[0-9]+$ ]] || { echo "${C_RED}id must be the integer from \`fox usb pending\`${C_RST}" >&2; return 1; }
    _check_sudo || return 1
    case "$mode" in
        permanent)
            sudo usbguard allow-device --permanent "$id" \
                && echo "${C_GRN}✓ device $id allowed (permanent)${C_RST}"
            ;;
        once)
            sudo usbguard allow-device "$id" \
                && echo "${C_GRN}✓ device $id allowed (this session only)${C_RST}"
            ;;
    esac
}

_block() {
    local id="$1"
    [[ "$id" =~ ^[0-9]+$ ]] || { echo "${C_RED}id must be the integer from \`fox usb\`${C_RST}" >&2; return 1; }
    _check_sudo || return 1
    sudo usbguard block-device --permanent "$id" \
        && echo "${C_GRN}✓ device $id blocked (permanent)${C_RST}"
}

_refresh() {
    _check_sudo || return 1
    echo "${C_BOLD}Currently plugged devices:${C_RST}"
    lsusb | sed 's/^/  /'
    echo
    echo "${C_YEL}This will regenerate /etc/usbguard/rules.conf from CURRENT devices.${C_RST}"
    echo "${C_YEL}Anything NOT plugged in right now will become blocked.${C_RST}"
    local r
    read -rp "Proceed? [y/N] " -n 1 -r r
    echo
    [[ "$r" =~ ^[Yy]$ ]] || { echo "cancelled"; return 0; }

    # Backup before regenerate.
    sudo cp /etc/usbguard/rules.conf /etc/usbguard/rules.conf.foxml-bak 2>/dev/null
    sudo usbguard generate-policy | sudo tee /etc/usbguard/rules.conf >/dev/null
    sudo chmod 600 /etc/usbguard/rules.conf
    sudo systemctl restart usbguard
    echo "${C_GRN}✓ policy regenerated from currently-plugged devices (old at .foxml-bak)${C_RST}"
}

_watch() {
    echo "${C_DIM}Tailing usbguard events (Ctrl-C to exit)...${C_RST}"
    sudo journalctl -u usbguard -f -o cat
}

_log() {
    sudo journalctl -u usbguard --no-pager -n 30 -o cat
}

case "${1:-}" in
    ""|list)        _list ;;
    pending|blocked) _pending ;;
    allow)          [[ -n "${2:-}" ]] && _allow "$2" permanent || { echo "usage: fox usb allow <id>"; exit 2; } ;;
    allow-once)     [[ -n "${2:-}" ]] && _allow "$2" once      || { echo "usage: fox usb allow-once <id>"; exit 2; } ;;
    block)          [[ -n "${2:-}" ]] && _block "$2"           || { echo "usage: fox usb block <id>"; exit 2; } ;;
    refresh)        _refresh ;;
    watch)          _watch ;;
    log)            _log ;;
    -h|--help|help) cat <<EOF
${C_BOLD}fox usb${C_RST} — friendly USBGuard wrapper

  fox usb                 list all known devices
  fox usb pending         show blocked devices needing allow/block decisions
  fox usb allow <id>      permanently allow device <id>
  fox usb allow-once <id> one-shot allow (forgotten on reboot)
  fox usb block <id>      permanently block
  fox usb refresh         regenerate policy from currently-plugged devices
  fox usb watch           live tail of usbguard journal
  fox usb log             last 30 usbguard journal entries

When you plug in a new mouse/keyboard/drive and it doesn't work,
\`fox usb pending\` will show it. \`fox usb allow <id>\` makes it permanent.
EOF
    ;;
    *) echo "unknown: $1" >&2; exit 2 ;;
esac
