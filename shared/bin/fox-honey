#!/usr/bin/env bash
# fox-honey — plant a per-repo honeytoken matched by fox-sentry-audit.
#
# fox-sentry-audit already watches ~/Documents/aws_production_keys.pem.
# This drops similar fake-credential files into your other repo dirs
# (typically ~/code/FoxML_Trader_v2/, ~/code/tick_trader/, etc.) and
# adds an auditd watch keyed `foxml_honey` for each. Any process that
# opens one of those files trips the kernel auditd → fires fox-dispatch.
#
# Usage:
#   fox honey                       list active honey files + watches
#   fox honey plant <dir> [name]    drop a honey file in <dir>; default
#                                    name: prod_keys.txt
#   fox honey remove <dir> [name]   remove a honey file + its watch
#   fox honey plant-all-trading     auto-plant in every ~/code/*trader*
#                                    + ~/code/tick* directory

set -u
C_GRN=$'\e[38;5;108m'; C_YEL=$'\e[38;5;221m'; C_RED=$'\e[38;5;167m'; C_DIM=$'\e[2m'; C_RST=$'\e[0m'

AUDIT_RULES=/etc/audit/rules.d/99-foxml.rules

_make_honey_content() {
    # Same approach as fox-sentry-audit: assemble PEM markers at
    # runtime so the repo never contains the literal pattern.
    local b1='-----BEGIN' b2='-----END' kind='RSA PRIVATE KEY'
    local body
    body=$(head -c 1024 /dev/urandom | base64 | head -c 880)
    {
        printf '%s %s-----\n' "$b1" "$kind"
        printf '# %s production credentials. Rotated quarterly.\n' "$(basename "$1")"
        printf '#  exchange-account: XCH-100123\n'
        printf '#  api-key:          XCH-LIVE-456789\n'
        printf '#  api-secret:       (see env)\n'
        printf '%s\n' "$body" | fold -w 64
        printf '%s %s-----\n' "$b2" "$kind"
    }
}

_plant() {
    local dir="$1" name="${2:-prod_keys.txt}"
    [[ -d "$dir" ]] || { echo "${C_RED}not a directory: $dir${C_RST}" >&2; return 1; }
    local path="$dir/$name"
    if [[ -f "$path" ]]; then
        echo "${C_YEL}already exists: $path (refusing to overwrite)${C_RST}"
        return 0
    fi
    if ! sudo -v 2>/dev/null; then
        echo "${C_RED}sudo required to add auditd watch${C_RST}" >&2
        return 1
    fi
    _make_honey_content "$dir" > "$path"
    chmod 600 "$path"

    # Add an auditd watch keyed foxml_honey so fox-sentry-audit picks it up.
    local rule="-w $path -p r -k foxml_honey"
    if ! sudo grep -qF "$rule" "$AUDIT_RULES" 2>/dev/null; then
        echo "$rule" | sudo tee -a "$AUDIT_RULES" >/dev/null
        sudo augenrules --load >/dev/null 2>&1 || true
    fi
    # Add to .gitignore in that dir so it doesn't accidentally get committed.
    if [[ -d "$dir/.git" ]]; then
        local gi="$dir/.gitignore"
        if ! grep -qxF "$name" "$gi" 2>/dev/null; then
            echo "$name" >> "$gi"
        fi
    fi
    echo "${C_GRN}✓ honey planted: $path${C_RST}"
    echo "  ${C_DIM}auditd watch: $rule${C_RST}"
    echo "  ${C_DIM}gitignored:   $name${C_RST}"
}

_remove() {
    local dir="$1" name="${2:-prod_keys.txt}"
    local path="$dir/$name"
    [[ -f "$path" ]] && rm -f "$path"
    if sudo -n true 2>/dev/null; then
        sudo sed -i "\|-w $path -p r -k foxml_honey|d" "$AUDIT_RULES" 2>/dev/null
        sudo augenrules --load >/dev/null 2>&1 || true
    fi
    echo "${C_GRN}✓ removed${C_RST}"
}

_list() {
    echo "${C_DIM}Active honey watches (from $AUDIT_RULES):${C_RST}"
    if sudo -n grep 'foxml_honey' "$AUDIT_RULES" 2>/dev/null; then :;
    else echo "  ${C_DIM}(sudo cold or no honey watches set)${C_RST}"; fi
}

_plant_all_trading() {
    # Heuristic: directories under ~/code that look like trading repos.
    # Patterns: *trader*, tick*, ticker*. Tweak via env: FOX_HONEY_DIRS.
    local dirs=()
    if [[ -n "${FOX_HONEY_DIRS:-}" ]]; then
        for d in $FOX_HONEY_DIRS; do dirs+=("$d"); done
    else
        shopt -s nullglob
        for d in "$HOME/code/"*[Tt]rader*  "$HOME/code/"tick* "$HOME/code/"FoxML* ; do
            [[ -d "$d" && -d "$d/.git" ]] && dirs+=("$d")
        done
        shopt -u nullglob
    fi
    if (( ${#dirs[@]} == 0 )); then
        echo "${C_YEL}no trading-pattern dirs found in ~/code/${C_RST}"
        echo "  override with:  FOX_HONEY_DIRS='~/code/dir1 ~/code/dir2' fox honey plant-all-trading"
        return 0
    fi
    for d in "${dirs[@]}"; do _plant "$d"; done
}

case "${1:-}" in
    ""|list)             _list ;;
    plant)               [[ -n "${2:-}" ]] && _plant "$2" "${3:-}" || { echo "usage: fox honey plant <dir> [name]"; exit 2; } ;;
    remove)              [[ -n "${2:-}" ]] && _remove "$2" "${3:-}" || { echo "usage: fox honey remove <dir> [name]"; exit 2; } ;;
    plant-all-trading)   _plant_all_trading ;;
    -h|--help|help) cat <<EOF
fox honey — plant per-repo honeytokens (audited by fox-sentry-audit)

  fox honey                       list active honey watches
  fox honey plant <dir> [name]    drop fake creds in <dir>;
                                  default name: prod_keys.txt
  fox honey remove <dir> [name]   delete + remove its audit rule
  fox honey plant-all-trading     auto-plant in ~/code/*trader* +
                                  ~/code/tick* + ~/code/FoxML*

Anything that reads the planted file fires fox-dispatch via the
existing fox-sentry-audit kernel watch. Honey content generated at
runtime (no PEM literal in the repo). Auto-adds to .gitignore so
the bait doesn't ship with your code.
EOF
    ;;
    *) echo "unknown: $1" >&2; exit 2 ;;
esac
