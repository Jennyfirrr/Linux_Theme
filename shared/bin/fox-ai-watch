#!/usr/bin/env bash
# fox-ai-watch — tail a log file with on-demand AI commentary.
#
# Usage: fox-ai-watch /path/to/file.log
#        fox-ai-watch --pattern 'ERROR|FATAL|panic' /path/to/file.log
#        FoxML_Trader_v2 2>&1 | fox-ai-watch -
#
# Tails the input (file or stdin), forwards every line to stdout
# verbatim, AND when a line matches --pattern, ships a window of
# context (10 lines around the match) to local Ollama and surfaces the
# AI's commentary via notify-send. Designed for FoxML_Trader_v2
# headless sessions: you keep the live log in your terminal, get
# desktop notifications only when something actionable happens.

set -u

if ! command -v ollama >/dev/null 2>&1; then
    echo "fox-ai-watch: ollama not installed" >&2
    exit 1
fi

MODEL="${FOXAI_MODEL:-}"
if [[ -z "$MODEL" ]] && [[ -f "$HOME/.config/opencode/opencode.json" ]] && command -v jq >/dev/null 2>&1; then
    MODEL=$(jq -r '.model // empty' "$HOME/.config/opencode/opencode.json" 2>/dev/null | sed 's|^ollama/||')
fi
MODEL="${MODEL:-qwen2.5-coder:7b}"

PATTERN='\b(ERROR|FATAL|panic|segfault|assert(ion)?(_| )fail|SIGSEGV|SIGABRT)\b'
SOURCE="-"
COOLDOWN=30   # min seconds between notifications, prevents spam during error bursts

while (( $# > 0 )); do
    case "$1" in
        --pattern)  PATTERN="$2"; shift ;;
        --cooldown) COOLDOWN="$2"; shift ;;
        --help|-h)  sed -n '2,11p' "$0" | sed 's/^# \?//'; exit 0 ;;
        *)          SOURCE="$1" ;;
    esac
    shift
done

# Open the line source.
if [[ "$SOURCE" == "-" ]]; then
    exec 3<&0
elif [[ -f "$SOURCE" ]]; then
    exec 3< <(tail -F "$SOURCE")
else
    echo "fox-ai-watch: $SOURCE is not a file" >&2
    exit 1
fi

last_alert=0
mapfile -t buf < <(echo)  # ring buffer
buf=()
BUF_SIZE=20

while IFS= read -r -u 3 line; do
    # Always echo through so the user sees the raw stream.
    echo "$line"
    # Maintain ring buffer of recent lines for context.
    buf+=("$line")
    while (( ${#buf[@]} > BUF_SIZE )); do
        buf=("${buf[@]:1}")
    done

    # Match → notify if past cooldown.
    if grep -qE "$PATTERN" <<<"$line"; then
        now=$(date +%s)
        if (( now - last_alert >= COOLDOWN )); then
            last_alert=$now
            context=$(printf '%s\n' "${buf[@]}")
            # Background the LLM call so we never block the tail.
            (
                summary=$(ollama run "$MODEL" "Analyse this log excerpt. One sentence: what failed. One sentence: most likely cause. Be terse.

LOG:
$context" 2>/dev/null | head -c 300)
                [[ -n "$summary" ]] && command -v notify-send >/dev/null 2>&1 && \
                    notify-send -u critical -t 12000 "fox-ai-watch" "$summary"
            ) &
        fi
    fi
done
