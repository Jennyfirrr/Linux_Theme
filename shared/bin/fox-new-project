#!/bin/bash
# fox-new-project — Bootstrap a new high-discipline coding workspace

if [[ -z "$1" ]]; then
    echo "Usage: fox-new-project <project-name>"
    exit 1
fi

PROJECT_NAME="$1"

if [[ -d "$PROJECT_NAME" ]]; then
    echo "Error: Directory $PROJECT_NAME already exists."
    exit 1
fi

mkdir -p "$PROJECT_NAME"
cd "$PROJECT_NAME" || exit 1

echo "Bootstrapping $PROJECT_NAME..."

# Init git
git init -q
echo ".agent/" >> .gitignore

# Create AGENT.md
cat <<EOF > AGENT.md
# $PROJECT_NAME — Project Mandates

## Core Mandates
- **Path Agnosticism**: Use standard environment variables or relative paths.
- **Safety**: No hardcoded secrets.
- **AI Protocol**: Use high-discipline commands (/readiness, /review, /ship, /context).

## Architecture
- Define your core architectural principles here.
EOF

# Create INVARIANTS.md
cat <<EOF > INVARIANTS.md
# $PROJECT_NAME Safety Invariants

This file defines the Load-Bearing Assumptions of the project. Breaking these rules will lead to silent drift or system failure.

## [I-01] Path Agnosticism
- **Rule**: No hardcoded absolute paths.
- **Standard**: Use XDG standards or relative paths.

## [I-02] Test Coverage
- **Rule**: Every new feature must include automated verification logic.
EOF

# Create initial CODE_MAP.md
echo "# $PROJECT_NAME — Code Map" > CODE_MAP.md
tree -L 2 >> CODE_MAP.md

# Plug in skills
fox-ai-setup-project

echo ""
echo "$PROJECT_NAME is ready for high-discipline development."
echo "   Run: cd $PROJECT_NAME && opencode \"/context\""
