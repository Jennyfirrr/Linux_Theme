#!/usr/bin/env bash
# fox-theme-tweak â€” live-update aesthetic variables in the active theme.
#
# Updates ROUNDING, BLUR_SIZE, BLUR_PASSES, GAP_IN, GAP_OUT, or BORDER_SIZE
# in the active palette.sh, re-renders templates, and reloads the UI.
#
# Usage:
#   fox-theme-tweak --rounding 12 --blur-size 4
#   fox-theme-tweak --gap-out 20
#
# Flags:
#   --rounding <px>      Set corner radius
#   --blur-size <px>     Set blur size
#   --blur-passes <n>    Set blur passes
#   --gap-in <px>        Set inner gaps
#   --gap-out <px>       Set outer gaps
#   --border-size <px>   Set border thickness
#   --render             Just re-render without changing values
#   --help

set -u
C_GRN=$'\e[38;5;108m'; C_YLW=$'\e[38;5;180m'; C_DIM=$'\e[2m'; C_RST=$'\e[0m'

SCRIPT_DIR="/home/caramel/code/Linux_Theme"
ACTIVE_FILE="$SCRIPT_DIR/.active-theme"

if [[ ! -f "$ACTIVE_FILE" ]]; then
    echo "error: no active theme found. Run ./swap.sh first." >&2
    exit 1
fi

ACTIVE_THEME=$(cat "$ACTIVE_FILE")
PALETTE_FILE="$SCRIPT_DIR/themes/$ACTIVE_THEME/palette.sh"

if [[ ! -f "$PALETTE_FILE" ]]; then
    echo "error: palette file missing: $PALETTE_FILE" >&2
    exit 1
fi

_update_val() {
    local key="$1"
    local val="$2"
    # Match key=... and replace with key=val, handling optional quotes
    if grep -q "^$key=" "$PALETTE_FILE"; then
        sed -i "s|^$key=.*|$key=$val|" "$PALETTE_FILE"
        printf "  %s+%s %s â†’ %s\n" "$C_GRN" "$C_RST" "$key" "$val"
    else
        # If it doesn't exist (legacy theme), append it under metadata
        sed -i "/# â”€â”€â”€ Theme metadata â”€â”€â”€/a $key=$val" "$PALETTE_FILE"
        printf "  %s+%s %s added â†’ %s\n" "$C_GRN" "$C_RST" "$key" "$val"
    fi
}

changed=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        --rounding)     _update_val "ROUNDING" "$2";    changed=true; shift 2 ;;
        --blur-size)    _update_val "BLUR_SIZE" "$2";   changed=true; shift 2 ;;
        --blur-passes)  _update_val "BLUR_PASSES" "$2"; changed=true; shift 2 ;;
        --gap-in)       _update_val "GAP_IN" "$2";      changed=true; shift 2 ;;
        --gap-out)      _update_val "GAP_OUT" "$2";     changed=true; shift 2 ;;
        --border-size)  _update_val "BORDER_SIZE" "$2"; changed=true; shift 2 ;;
        --render)       changed=true; shift ;;
        --help|-h)
            sed -n '2,16p' "$0" | sed 's/^# \?//'
            exit 0
            ;;
        *) echo "unknown flag: $1"; exit 1 ;;
    esac
done

if [[ "$changed" == "true" ]]; then
    echo ":: Re-rendering $ACTIVE_THEME..."
    "$SCRIPT_DIR/install.sh" "$ACTIVE_THEME" --render --yes
    echo ":: Reloading Hyprland..."
    hyprctl reload
    echo ":: Done."
else
    echo "No changes requested. Try --help."
fi
