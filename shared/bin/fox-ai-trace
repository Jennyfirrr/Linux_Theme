#!/usr/bin/env bash
# fox-ai-trace — diagnose a C++/Python backtrace with local AI.
#
# Usage: fox-ai-trace            # read from stdin
#        fox-ai-trace crash.log  # read from file
#        gdb -batch -ex bt ./prog core | fox-ai-trace
#
# Best when piped a full backtrace (gdb bt, addr2line output, Python
# traceback, or systemd-coredumpctl info dump). The model identifies the
# crashing frame, the likely cause, and suggests fixes. Optimised for
# FoxML's C++ trading engines where many crashes are race conditions,
# fixed-point overflow, or NaN propagation.

set -u

if ! command -v ollama >/dev/null 2>&1; then
    echo "fox-ai-trace: ollama not installed" >&2
    exit 1
fi

MODEL="${FOXAI_MODEL:-}"
if [[ -z "$MODEL" ]] && [[ -f "$HOME/.config/opencode/opencode.json" ]] && command -v jq >/dev/null 2>&1; then
    MODEL=$(jq -r '.model // empty' "$HOME/.config/opencode/opencode.json" 2>/dev/null | sed 's|^ollama/||')
fi
MODEL="${MODEL:-qwen2.5-coder:7b}"

if [[ $# -gt 0 && -f "$1" ]]; then
    trace=$(cat "$1")
elif [[ ! -t 0 ]]; then
    trace=$(cat)
else
    echo "fox-ai-trace: pipe a backtrace in, or pass a file path" >&2
    exit 2
fi

prompt='You are debugging a crash in a high-performance C++ trading system or Python tool. Given the backtrace below, produce a concise diagnosis:

1. Crashing frame — which function and what likely went wrong.
2. Root-cause hypotheses — ranked by likelihood. For C++ crashes consider: data race, lock-free queue underflow, fixed-point overflow, NaN propagation, dangling reference, OOM, dlopen failure. For Python: imports, encoding, blocking I/O on async, type mismatch.
3. Suggested next steps — what to inspect, what to log, what to bisect.

Format with short headings + bullet points. Skip the obvious ("crash in main"). Be direct.

BACKTRACE:
'"$trace"

ollama run "$MODEL" "$prompt" 2>/dev/null
