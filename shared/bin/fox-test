#!/usr/bin/env bash
# fox-test — health gate for a FoxML checkout.
#
# Runs three checks in sequence:
#   1. shellcheck (severity=error) on shared/bin + shared/hyprland_scripts
#   2. tests/roundtrip.sh — render→deploy→update is a no-op on templates/
#   3. fox-doctor — config drift (nvim, hyprland, waybar, multi-monitor)
#
# Exits 0 only when all three pass. Use as a CI gate or a pre-commit
# sanity check. Suppresses interactive prompts where possible.

set -u

FOXML_DIR="${FOXML_DIR:-$HOME/code/Linux_Theme}"
if [[ ! -d "$FOXML_DIR" ]]; then
    echo "fox-test: $FOXML_DIR not found (set FOXML_DIR if your checkout lives elsewhere)" >&2
    exit 1
fi

fail=0
report() {
    local status="$1" label="$2"
    if (( status == 0 )); then
        printf '  \033[32m+\033[0m %s\n' "$label"
    else
        printf '  \033[31mX\033[0m %s\n' "$label"
        fail=$((fail + 1))
    fi
}

printf '\033[1m::\033[0m fox-test — health checks for %s\n' "$FOXML_DIR"

# ─── shellcheck ────────────────────────────────────────────────────
if command -v shellcheck >/dev/null 2>&1; then
    printf '\n\033[2m── shellcheck (severity=error) ──\033[0m\n'
    sc_out=$(shellcheck --severity=error \
        "$FOXML_DIR/shared/bin/"* \
        "$FOXML_DIR/shared/hyprland_scripts/"*.sh \
        "$FOXML_DIR/shared/waybar_scripts/"*.sh \
        "$FOXML_DIR/install.sh" \
        "$FOXML_DIR/render.sh" \
        "$FOXML_DIR/mappings.sh" \
        2>&1 || true)
    if [[ -z "$sc_out" ]]; then
        report 0 "shellcheck (no errors)"
    else
        printf '%s\n' "$sc_out" | head -40
        report 1 "shellcheck reported errors"
    fi
else
    printf '\n\033[2m── shellcheck ──\033[0m\n'
    printf '  \033[33m!\033[0m shellcheck not installed — skipped\n'
fi

# ─── tests/roundtrip.sh ────────────────────────────────────────────
if [[ -x "$FOXML_DIR/tests/roundtrip.sh" ]]; then
    printf '\n\033[2m── tests/roundtrip.sh ──\033[0m\n'
    if "$FOXML_DIR/tests/roundtrip.sh" >/tmp/fox-test-roundtrip.log 2>&1; then
        report 0 "roundtrip (render → deploy → update is a no-op)"
    else
        tail -20 /tmp/fox-test-roundtrip.log
        report 1 "roundtrip reported drift (see /tmp/fox-test-roundtrip.log)"
    fi
fi

# ─── fox-doctor ────────────────────────────────────────────────────
if command -v fox-doctor >/dev/null 2>&1; then
    printf '\n\033[2m── fox-doctor ──\033[0m\n'
    if doctor_out=$(fox-doctor 2>&1); then
        # fox-doctor emits its own structured output; exit code is what
        # matters here. Surface the final Result line only.
        result=$(printf '%s\n' "$doctor_out" | grep -E '^Result:' | tail -1 | sed -E 's/\x1B\[[0-9;]*[a-zA-Z]//g')
        if [[ "$result" == *"all checks passed"* ]]; then
            report 0 "fox-doctor (${result#Result: })"
        else
            report 0 "fox-doctor (${result#Result: })  — non-fatal warnings"
        fi
    else
        printf '%s\n' "$doctor_out" | tail -20
        report 1 "fox-doctor reported failures"
    fi
fi

printf '\n'
if (( fail == 0 )); then
    printf '\033[1;32mResult:\033[0m all checks passed\n'
    exit 0
else
    printf '\033[1;31mResult:\033[0m %d check(s) failed\n' "$fail"
    exit 1
fi
