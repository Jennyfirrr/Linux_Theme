#!/usr/bin/env bash
# fox-snitch — OpenSnitch (application-layer egress firewall).
#
# OpenSnitch prompts you the first time any app tries to make an
# outbound connection. Decisions are saved as rules; later attempts
# are silently allowed/denied. Two-tier wrapper:
#   • --enable installs opensnitch + opensnitch-ui + a sensible
#     ruleset so trusted system tools (pacman/git/ssh/curl/dnf/
#     systemd-resolved) are pre-allowed → no prompt storm on day 1.
#   • Application binaries you actually launch (browsers, code, etc.)
#     ask once and remember.
#
# Pairs nicely with fox firewall lockdown: UFW does the kernel-level
# block on unallowed ports, OpenSnitch does the per-app whitelist on
# the allowed ports. Defense in depth.

set -u
C_GRN=$'\e[38;5;108m'; C_YEL=$'\e[38;5;221m'; C_RED=$'\e[38;5;167m'; C_DIM=$'\e[2m'; C_RST=$'\e[0m'

RULES_DIR=/etc/opensnitchd/rules
AUTOSTART="$HOME/.config/autostart/opensnitch_ui.desktop"

_require() {
    if ! command -v opensnitchd >/dev/null 2>&1; then
        echo "${C_RED}opensnitch not installed${C_RST}" >&2
        echo "  install:  yay -S opensnitch opensnitch-ui  (or paru)" >&2
        return 1
    fi
}

_seed_rules() {
    sudo install -d "$RULES_DIR"
    # Allow common system tools without prompting.
    local pre_allow=(
        "/usr/bin/pacman"
        "/usr/bin/yay"
        "/usr/bin/paru"
        "/usr/bin/git"
        "/usr/bin/gh"
        "/usr/bin/ssh"
        "/usr/bin/curl"
        "/usr/bin/wget"
        "/usr/lib/systemd/systemd-resolved"
        "/usr/lib/systemd/systemd-timesyncd"
        "/usr/bin/chronyd"
        "/usr/bin/dhcpcd"
        "/usr/bin/NetworkManager"
        "/usr/bin/ollama"
    )
    for bin in "${pre_allow[@]}"; do
        [[ -e "$bin" ]] || continue
        local name; name=$(basename "$bin" | tr -cd 'A-Za-z0-9_-')
        local rule="$RULES_DIR/000-foxml-allow-${name}.json"
        sudo tee "$rule" >/dev/null <<EOF
{
  "created": "$(date -Iseconds)",
  "updated": "$(date -Iseconds)",
  "name": "foxml-allow-${name}",
  "enabled": true,
  "precedence": false,
  "action": "allow",
  "duration": "always",
  "operator": {
    "type": "simple",
    "sensitive": false,
    "operand": "process.path",
    "data": "$bin"
  }
}
EOF
    done
    echo "  + seeded ${#pre_allow[@]} allow rules for system binaries"
}

_enable() {
    _require || return 1
    _seed_rules
    sudo systemctl enable --now opensnitchd >/dev/null 2>&1
    # User GUI autostart so prompts actually surface.
    mkdir -p "$(dirname "$AUTOSTART")"
    cat > "$AUTOSTART" <<EOF
[Desktop Entry]
Type=Application
Name=OpenSnitch UI
Exec=opensnitch-ui
Icon=opensnitch
Categories=System;Security;
EOF
    if sudo systemctl is-active --quiet opensnitchd; then
        echo "${C_GRN}✓ opensnitchd active. Launch the UI: opensnitch-ui &${C_RST}"
        echo "  ${C_DIM}prompts go through the GUI; system binaries pre-allowed${C_RST}"
    else
        echo "${C_YEL}! opensnitchd failed to start — check: systemctl status opensnitchd${C_RST}"
    fi
}

_disable() {
    sudo systemctl disable --now opensnitchd >/dev/null 2>&1
    rm -f "$AUTOSTART"
    echo "${C_GRN}✓ opensnitchd stopped + autostart removed (rules kept for re-enable)${C_RST}"
}

_status() {
    if systemctl is-active --quiet opensnitchd 2>/dev/null; then
        echo "  daemon:  ${C_GRN}active${C_RST}"
    else
        echo "  daemon:  ${C_RED}inactive${C_RST}"
    fi
    if pgrep -x opensnitch-ui >/dev/null 2>&1; then
        echo "  ui:      ${C_GRN}running${C_RST}"
    else
        echo "  ui:      ${C_YEL}not running (launch: opensnitch-ui &)${C_RST}"
    fi
    if [[ -d "$RULES_DIR" ]]; then
        local n; n=$(sudo ls -1 "$RULES_DIR" 2>/dev/null | wc -l)
        echo "  rules:   $n"
    fi
}

_log() {
    sudo journalctl -u opensnitchd --no-pager -n 50 -o cat
}

case "${1:-}" in
    ""|status)   _status ;;
    --enable)    _enable ;;
    --disable)   _disable ;;
    log)         _log ;;
    -h|--help|help) cat <<EOF
fox snitch — OpenSnitch (per-app outbound firewall)

  fox snitch [status]    daemon + UI + rule count
  fox snitch --enable    install + seed rules + autostart UI
  fox snitch --disable   stop daemon, remove autostart (rules kept)
  fox snitch log         recent daemon journal

Pair with: fox firewall lockdown (UFW deny-out + allowlist of ports).
EOF
    ;;
    *) echo "unknown: $1" >&2; exit 2 ;;
esac
