#!/bin/bash
# FoxML AI Status — Waybar module for OpenCode model status

CONFIG_FILE="$HOME/.config/opencode/opencode.json"

if [[ ! -f "$CONFIG_FILE" ]]; then
    echo '{"text": "  OFF", "tooltip": "OpenCode config not found", "class": "offline"}'
    exit 0
fi

# Use jq for robust extraction
MODEL_FULL=$(jq -r '.model // empty' "$CONFIG_FILE")
if [[ -z "$MODEL_FULL" || "$MODEL_FULL" == "null" ]]; then
    echo '{"text": "  OFF", "tooltip": "No model set in config", "class": "offline"}'
    exit 0
fi

# Strip provider prefix (e.g., ollama/)
MODEL_NAME="${MODEL_FULL#*/}"

# Extract Size (e.g. 7b, 14B)
SIZE=$(echo "$MODEL_NAME" | grep -ioP '\d+[bB]' | head -n1 | tr '[:lower:]' '[:upper:]')

if [[ -n "$SIZE" ]]; then
    # User requested concise display (e.g. "7B")
    DISPLAY_TAG="$SIZE"
else
    # Fallback to a truncated version of the name if no size detected
    DISPLAY_TAG="${MODEL_NAME:0:8}"
fi

# Determine icon and label
VRAM_INFO=""
VRAM_PERCENT=0
if command -v nvidia-smi &>/dev/null; then
    VRAM_RAW=$(nvidia-smi --query-gpu=memory.used,memory.total --format=csv,noheader,nounits 2>/dev/null | tr -d ' ')
    if [[ -n "$VRAM_RAW" ]]; then
        VRAM_USED=${VRAM_RAW%,*}
        VRAM_TOTAL=${VRAM_RAW#*,}
        if [[ "$VRAM_TOTAL" -gt 0 ]]; then
            VRAM_PERCENT=$(( VRAM_USED * 100 / VRAM_TOTAL ))
            VRAM_INFO=" (VRAM: ${VRAM_PERCENT}%)"
        fi
    fi
fi

# Categorize current load for the tooltip
LOAD_LABEL="Safe"
[[ $VRAM_PERCENT -gt 50 ]] && LOAD_LABEL="Moderate"
[[ $VRAM_PERCENT -gt 85 ]] && LOAD_LABEL="Heavy"
[[ $VRAM_PERCENT -gt 95 ]] && LOAD_LABEL="CRITICAL"

ICON=" "
LABEL="$DISPLAY_TAG$VRAM_INFO"
CLASS="smart"

# Apply tier-based coloring based on size
if [[ -n "$SIZE" ]]; then
    NUM_SIZE=$(echo "$SIZE" | tr -dc '0-9')
    if [[ -n "$NUM_SIZE" ]]; then
        if [[ "$NUM_SIZE" -le 8 ]]; then
            CLASS="fast"
        elif [[ "$NUM_SIZE" -le 20 ]]; then
            CLASS="smart"
        else
            CLASS="expert"
        fi
    fi
fi

echo "{\"text\": \"$ICON $LABEL\", \"tooltip\": \"Model: $MODEL_NAME\\nStatus: $LOAD_LABEL$VRAM_INFO\", \"class\": \"$CLASS\"}"
