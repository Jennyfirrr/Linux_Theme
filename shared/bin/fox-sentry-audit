#!/usr/bin/env bash
# fox-sentry-audit â€” kernel-level honeypot tailer.
#
# Watches journald for auditd events tagged `key="foxml_honey"` and
# fires fox-dispatch on every read access. This complements
# fox-tripwire (which uses userspace inotifywait): auditd's watch is
# enforced by the kernel and can't be bypassed by a process toggling
# inotify masks or detaching from the watcher's mount namespace.
#
# Audit rule (added by install_security): a `-w <honey path> -p r -k
# foxml_honey` line in /etc/audit/rules.d/99-foxml.rules. Every read
# triggers a SYSCALL record in the journal with that key.
#
# Install / uninstall:
#   fox-sentry-audit --install
#   fox-sentry-audit --uninstall
#   fox-sentry-audit --status
#   fox-sentry-audit run     (used by systemd unit)

set -u

CONF_DIR="$HOME/.config/foxml"
HONEY_STATE="$CONF_DIR/sentry-audit.path"
SERVICE_NAME="fox-sentry-audit.service"
DEFAULT_HONEY="$HOME/Documents/aws_production_keys.pem"

C_GRN=$'\e[38;5;108m'
C_YEL=$'\e[38;5;221m'
C_RED=$'\e[38;5;167m'
C_RST=$'\e[0m'

_make_honey() {
    local path="${1:-$DEFAULT_HONEY}"
    mkdir -p "$(dirname "$path")"
    # Realistic-looking AWS / Azure / GCP credential file. The reason
    # this works as a honeypot: any *legitimate* tool has no reason to
    # open ~/Documents/aws_production_keys.pem unprompted. Attackers
    # grepping for secrets / dumping common paths will trip it.
    cat > "$path" <<'EOF'
-----BEGIN RSA PRIVATE KEY-----
# AWS Production root keys. Rotated quarterly.
#  account-id: 123456789012
#  region:     us-east-1
#  user:       prod-deploy-svc
MIIEpAIBAAKCAQEAxyTSZeUVcQyP3kF4kQ9w9j9Vw5MZ7yPjL4XHkN7xdvW5RuqB
...truncated...
-----END RSA PRIVATE KEY-----
# Backup: see ~/.config/aws/credentials and SSM parameter store
EOF
    chmod 600 "$path"
    echo "$path" > "$HONEY_STATE"
    chmod 600 "$HONEY_STATE"
    echo "$path"
}

act_install() {
    if ! command -v auditctl >/dev/null 2>&1; then
        echo "${C_RED}auditd not installed â€” pacman -S audit${C_RST}" >&2
        return 1
    fi
    local path="${1:-$DEFAULT_HONEY}"
    if [[ -f "$HONEY_STATE" ]]; then
        local existing
        existing=$(<"$HONEY_STATE")
        if [[ -f "$existing" ]]; then
            path="$existing"
            echo "${C_YEL}honey already present at $path${C_RST}"
        fi
    fi
    [[ -f "$path" ]] || { _make_honey "$path"; echo "${C_GRN}âś“ honey created at $path${C_RST}"; }

    # Persistent audit rule. Live + survives reboot via augenrules.
    local rules=/etc/audit/rules.d/99-foxml.rules
    if ! sudo grep -q "key=foxml_honey" "$rules" 2>/dev/null; then
        echo "-w $path -p r -k foxml_honey" | sudo tee -a "$rules" >/dev/null
        sudo augenrules --load >/dev/null 2>&1 || true
        echo "${C_GRN}âś“ auditd rule added: -w $path -p r -k foxml_honey${C_RST}"
    else
        echo "${C_YEL}audit rule already present${C_RST}"
    fi

    # Systemd user unit. Tails the kernel journal for the key.
    local unit_dir="$HOME/.config/systemd/user"
    mkdir -p "$unit_dir"
    cat > "$unit_dir/$SERVICE_NAME" <<EOF
[Unit]
Description=fox-sentry-audit â€” kernel-level honeypot tailer
After=default.target

[Service]
Type=simple
ExecStart=$(command -v fox-sentry-audit) run
Restart=on-failure
RestartSec=10

[Install]
WantedBy=default.target
EOF
    systemctl --user daemon-reload
    systemctl --user enable --now "$SERVICE_NAME"
    echo "${C_GRN}âś“ $SERVICE_NAME enabled + started${C_RST}"
    echo
    echo "  honey path:  $path"
    echo "  audit rule:  -w $path -p r -k foxml_honey"
    echo "  log:         journalctl --user -u $SERVICE_NAME -f"
}

act_uninstall() {
    systemctl --user disable --now "$SERVICE_NAME" 2>/dev/null || true
    rm -f "$HOME/.config/systemd/user/$SERVICE_NAME"
    systemctl --user daemon-reload 2>/dev/null || true
    # Remove audit rule.
    local rules=/etc/audit/rules.d/99-foxml.rules
    if [[ -f "$rules" ]]; then
        sudo sed -i '/key=foxml_honey/d' "$rules" 2>/dev/null
        sudo augenrules --load >/dev/null 2>&1 || true
    fi
    # Remove honey file.
    if [[ -f "$HONEY_STATE" ]]; then
        local p
        p=$(<"$HONEY_STATE")
        rm -f "$p" "$HONEY_STATE"
    fi
    echo "${C_GRN}âś“ fox-sentry-audit uninstalled${C_RST}"
}

act_status() {
    if systemctl --user is-active --quiet "$SERVICE_NAME"; then
        echo "  service:  ${C_GRN}active${C_RST}"
    else
        echo "  service:  ${C_RED}inactive${C_RST}"
    fi
    if [[ -f "$HONEY_STATE" ]]; then
        local p
        p=$(<"$HONEY_STATE")
        echo "  honey:    $p"
    else
        echo "  honey:    ${C_YEL}<not installed>${C_RST}"
    fi
    echo "  audit rules:"
    sudo -n grep "foxml_honey" /etc/audit/rules.d/99-foxml.rules 2>/dev/null | sed 's/^/    /' \
        || echo "    ${C_YEL}(re-prime sudo to inspect)${C_RST}"
    echo "  log:      journalctl --user -u $SERVICE_NAME --no-pager -n 30"
}

act_run() {
    local last_alert=0
    local ALERT_COOLDOWN=30

    # Stream audit-tagged events. The kernel audit framework writes to
    # the journal (via auditd or systemd-journald-audit.socket). Filter
    # on the key= field for our honeypot.
    journalctl --no-pager --since=now -f -o cat _TRANSPORT=audit 2>/dev/null \
        | grep --line-buffered 'key="foxml_honey"' \
        | while read -r line; do
            local now
            now=$(date +%s)
            (( now - last_alert < ALERT_COOLDOWN )) && continue
            last_alert=$now

            # Parse pid + comm + auid + uid from the SYSCALL line.
            local pid uid auid comm
            pid=$(grep -oP 'pid=\K[0-9]+' <<<"$line" | head -1)
            uid=$(grep -oP 'uid=\K[0-9]+' <<<"$line" | head -1)
            auid=$(grep -oP 'auid=\K[0-9]+' <<<"$line" | head -1)
            comm=$(grep -oP 'comm="\K[^"]+' <<<"$line" | head -1)

            local msg="kernel-audit honey trip: pid=${pid:-?} uid=${uid:-?} auid=${auid:-?} comm=${comm:-?}"
            echo "$(date -Iseconds) $msg" >&2
            fox-dispatch "HONEY TRIPPED (kernel audit)" "$msg" 2>/dev/null \
                || notify-send -u critical -t 12000 "fox-sentry-audit" "$msg"
        done
}

case "${1:-}" in
    --install)    shift; act_install "${1:-}" ;;
    --uninstall)  act_uninstall ;;
    --status)     act_status ;;
    run)          act_run ;;
    -h|--help|"") cat <<EOF
fox-sentry-audit â€” kernel-level honeypot watcher (auditd-based)

  fox-sentry-audit --install [path]   create honey + audit rule + service
                                       default path: ~/Documents/aws_production_keys.pem
  fox-sentry-audit --uninstall        remove honey + rule + service
  fox-sentry-audit --status           show service state + honey path
  fox-sentry-audit run                run in foreground (used by systemd)

Pairs with fox-tripwire (userspace inotifywait) for two-layer watch:
inotifywait is fast and easy; auditd is kernel-level and can't be
bypassed by userspace ptrace games.
EOF
    ;;
    *) echo "unknown: $1" >&2; exit 2 ;;
esac
