#!/usr/bin/env bash
# fox-deadman — USB-tethered panic trigger.
#
# Register a specific USB device. When that device is unplugged
# (yanked because someone grabs the laptop while it's tethered to your
# wrist), udev fires panic.sh.
#
# Usage:
#   fox deadman --setup       interactive: register a plugged-in USB
#   fox deadman --status      show registered device + udev rule state
#   fox deadman --disarm      remove the rule (un-tether)
#   fox deadman --test        simulate trip by running panic.sh
#                              (CAREFUL — actually runs panic.sh!)
#
# The udev rule is in /etc/udev/rules.d/99-foxml-deadman.rules and
# matches on the device's USB serial number (stable across re-plugs of
# the same drive, unique to that drive).
#
# Safety:
#   • A 5-second confirm window in the unplug handler — if you re-plug
#     within 5s, panic.sh doesn't fire. Mitigates accidental yanks.
#   • You can disarm at any time via fox deadman --disarm.
#   • The handler is invoked by udev as root, so panic.sh runs with
#     full ability to drop network + wipe state.
#
# IMPORTANT: only enable this when you actually have the USB tethered.
# Otherwise normal removals (transferring files, charging a phone) will
# panic the system.

set -u

CONF_DIR="$HOME/.config/foxml"
CONF="$CONF_DIR/deadman.conf"
RULES=/etc/udev/rules.d/99-foxml-deadman.rules
HANDLER=/usr/local/bin/foxml-deadman-trip

C_BOLD=$'\e[1m'
C_DIM=$'\e[2m'
C_GRN=$'\e[38;5;108m'
C_YEL=$'\e[38;5;221m'
C_RED=$'\e[38;5;167m'
C_RST=$'\e[0m'

_list_usb_drives() {
    # Enumerate currently-plugged USB block devices with vendor:product:serial.
    for dev in /dev/disk/by-id/usb-*; do
        [[ -e "$dev" ]] || continue
        local name=$(basename "$dev")
        # Strip "usb-" prefix and "-part*" suffix for readability.
        name="${name#usb-}"
        name="${name%-part*}"
        echo "  • $name  →  $(readlink -f "$dev")"
    done
}

_pick_usb() {
    echo "${C_BOLD}Currently plugged USB devices:${C_RST}"
    _list_usb_drives
    echo
    echo "Type the FULL by-id name you want to register (e.g. 'SanDisk_Cruzer_4C530001...'):"
    read -rp "  > " choice
    echo "$choice"
}

act_setup() {
    if [[ ! -d /etc/udev/rules.d ]]; then
        echo "${C_RED}udev not available${C_RST}" >&2
        return 1
    fi
    echo "${C_BOLD}fox deadman — setup${C_RST}"
    echo "${C_DIM}Plug in the USB you want to use as the dead-man tether NOW.${C_RST}"
    echo "${C_DIM}Press Enter when it's connected:${C_RST}"
    read -r _

    local id_name
    id_name=$(_pick_usb)
    if [[ -z "$id_name" ]] || [[ ! -e "/dev/disk/by-id/usb-${id_name}" ]]; then
        echo "${C_RED}device not found at /dev/disk/by-id/usb-${id_name}${C_RST}" >&2
        return 1
    fi

    # Extract the USB serial — the stable identifier across re-plugs.
    # by-id name format: usb-<VENDOR>_<MODEL>_<SERIAL>-<num>
    local serial
    serial=$(udevadm info --query=property --name="/dev/disk/by-id/usb-${id_name}" 2>/dev/null \
        | awk -F= '/^ID_SERIAL_SHORT=/{print $2; exit}')
    if [[ -z "$serial" ]]; then
        echo "${C_RED}couldn't extract serial — device might not be a standard USB mass-storage device${C_RST}" >&2
        return 1
    fi

    # Save config (user-readable, 0600).
    mkdir -p "$CONF_DIR" && chmod 700 "$CONF_DIR"
    ( umask 077
      cat > "$CONF" <<EOF
# foxml-managed — dead-man tether
SERIAL=$serial
ID_NAME=$id_name
REGISTERED=$(date -Iseconds)
EOF
    )
    chmod 600 "$CONF"

    # Write the udev rule + trip handler.
    sudo tee "$HANDLER" >/dev/null <<EOF
#!/bin/sh
# foxml-managed — udev calls this on dead-man USB unplug.
# 5-second confirm window: if device returns, abort.
sleep 5
for d in /dev/disk/by-id/usb-*; do
    if [ "\$(udevadm info --query=property --name="\$d" 2>/dev/null | awk -F= '/^ID_SERIAL_SHORT=/{print \$2; exit}')" = "$serial" ]; then
        logger -t foxml-deadman "device re-plugged within 5s — aborting trip"
        exit 0
    fi
done
logger -t foxml-deadman "DEAD-MAN UNPLUG — firing panic"
# Run panic.sh as the target user so it has session access.
TARGET_USER="${USER}"
TARGET_UID=\$(id -u "\$TARGET_USER")
PANIC=/home/\$TARGET_USER/.config/hypr/scripts/panic.sh
if [ -x "\$PANIC" ]; then
    su -l "\$TARGET_USER" -c "XDG_RUNTIME_DIR=/run/user/\$TARGET_UID DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/\$TARGET_UID/bus \$PANIC" &
fi
# Defensive system-level actions even if user-side panic fails:
nmcli networking off 2>/dev/null || true
EOF
    sudo chmod 0755 "$HANDLER"

    sudo tee "$RULES" >/dev/null <<EOF
# foxml-managed — dead-man tether (USB serial $serial)
ACTION=="remove", SUBSYSTEM=="block", ENV{ID_SERIAL_SHORT}=="$serial", RUN+="$HANDLER"
EOF
    sudo udevadm control --reload-rules >/dev/null 2>&1

    echo
    echo "${C_GRN}✓ dead-man armed${C_RST}"
    echo "    serial:        $serial"
    echo "    udev rule:     $RULES"
    echo "    trip handler:  $HANDLER"
    echo "    config:        $CONF (0600)"
    echo
    echo "  Behavior: unplugging this USB → 5s grace → panic.sh + nmcli off"
    echo "  Disarm anytime: fox deadman --disarm"
}

act_status() {
    if [[ -f "$RULES" && -f "$CONF" ]]; then
        echo "  status:  ${C_GRN}armed${C_RST}"
        local serial
        serial=$(awk -F= '/^SERIAL=/{print $2}' "$CONF" 2>/dev/null)
        echo "  serial:  ${serial:-?}"
        echo "  rule:    $RULES"
        # Probe if device is currently present.
        local present="no"
        for d in /dev/disk/by-id/usb-* 2>/dev/null; do
            [[ -e "$d" ]] || continue
            local s
            s=$(udevadm info --query=property --name="$d" 2>/dev/null \
                | awk -F= '/^ID_SERIAL_SHORT=/{print $2; exit}')
            [[ "$s" == "$serial" ]] && present="yes"
        done
        if [[ "$present" == "yes" ]]; then
            echo "  device:  ${C_GRN}plugged in${C_RST}"
        else
            echo "  device:  ${C_RED}NOT PLUGGED IN — system will trip on next udev event${C_RST}"
            echo "           run: fox deadman --disarm  if you're not currently tethered"
        fi
    else
        echo "  status:  ${C_YEL}not configured${C_RST}"
        echo "  set up:  fox deadman --setup"
    fi
}

act_disarm() {
    sudo rm -f "$RULES" "$HANDLER"
    sudo udevadm control --reload-rules >/dev/null 2>&1
    rm -f "$CONF"
    echo "${C_GRN}✓ dead-man disarmed (rule + handler + config removed)${C_RST}"
}

act_test() {
    echo "${C_YEL}This will run panic.sh for real. Type 'YES' to confirm:${C_RST}"
    read -rp "  > " r
    [[ "$r" == "YES" ]] || { echo "cancelled"; return 0; }
    if [[ -x "$HOME/.config/hypr/scripts/panic.sh" ]]; then
        exec "$HOME/.config/hypr/scripts/panic.sh"
    else
        echo "panic.sh not found"
        return 1
    fi
}

case "${1:-}" in
    --setup)    act_setup ;;
    --status)   act_status ;;
    --disarm)   act_disarm ;;
    --test)     act_test ;;
    -h|--help|"") cat <<EOF
fox deadman — USB-tethered panic trigger

  fox deadman --setup     register a plugged-in USB as the tether
  fox deadman --status    show armed state + whether the USB is present
  fox deadman --disarm    remove the udev rule (un-tether)
  fox deadman --test      run panic.sh now (asks confirmation)

How it works:
  Registers a udev rule that fires on the USB's stable serial number.
  5-second grace window: re-plug within 5s = no trip.
  On trip: panic.sh as you + 'nmcli networking off' as root.

When to use:
  Crowded coffee shop, conference, anywhere you set the laptop down.
  Tether the USB to your wrist or belt. If someone grabs the laptop,
  the USB pulls out and the laptop drops the network + wipes state
  before they reach the door.

WARNING:
  Don't arm this and then yank the USB normally. It triggers panic.sh.
  Always --disarm before unplugging for normal reasons.
EOF
    ;;
    *) echo "unknown: $1" >&2; exit 2 ;;
esac
