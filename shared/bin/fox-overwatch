#!/usr/bin/env bash
# fox-overwatch — explain what the waybar overwatch widget is alerting on,
#                 and (optionally) reset the baseline.
#
# The waybar hw_overwatch.sh module runs every 15s and flags:
#   • new listening sockets on non-loopback addresses
#   • new short-lived root processes
#   • NVIDIA GPU usage by unknown processes
# State is a one-line snapshot in $XDG_RUNTIME_DIR/foxml-overwatch.state
# that the module diffs against each tick.
#
# Usage:
#   fox overwatch              # human-readable current snapshot + sudo-rich detail
#   fox overwatch --reset      # accept current state as the new baseline (clears alert)
#   fox overwatch --watch      # live tail — re-run every 5s

set -u

STATE_DIR="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"
STATE="$STATE_DIR/foxml-overwatch.state"

C_BOLD=$'\e[1m'
C_DIM=$'\e[2m'
C_PEACH=$'\e[38;5;215m'
C_YEL=$'\e[38;5;221m'
C_GRN=$'\e[38;5;108m'
C_RED=$'\e[38;5;167m'
C_RST=$'\e[0m'

usage() {
    cat <<EOF
${C_BOLD}fox overwatch${C_RST} — inspect waybar Hardware Overwatch state

Usage:
  fox overwatch              show current listeners, new root procs, GPU procs
  fox overwatch --reset      treat current state as healthy baseline
  fox overwatch --watch      refresh every 5s (Ctrl-C to exit)
  fox overwatch --raw        dump $STATE verbatim
  fox overwatch -h           this help
EOF
}

# -- detection helpers -----------------------------------------------------

show_listeners() {
    echo "${C_BOLD}── Listening sockets (non-loopback) ──${C_RST}"
    local have_sudo=0
    if sudo -n true 2>/dev/null; then have_sudo=1; fi

    if (( have_sudo )); then
        sudo ss -tlnp 2>/dev/null \
            | awk 'NR==1 || ($4 !~ /^127\./ && $4 !~ /^\[::1\]/ && $4 !~ /^\*:/)'
    else
        echo "${C_DIM}(re-prime sudo for process names: sudo -v)${C_RST}"
        ss -tln 2>/dev/null \
            | awk 'NR==1 || ($4 !~ /^127\./ && $4 !~ /^\[::1\]/ && $4 !~ /^\*:/)'
    fi
    echo
}

show_state_diff() {
    echo "${C_BOLD}── What overwatch is currently flagging ──${C_RST}"
    if [[ ! -f "$STATE" ]]; then
        echo "${C_DIM}(no state file at $STATE — module hasn't run yet)${C_RST}"
        echo
        return
    fi
    local snapshot
    snapshot=$(awk '/^LISTEN:/{print substr($0,8)}' "$STATE" | tr '|' '\n' | sort -u)
    if [[ -z "$snapshot" ]]; then
        echo "${C_DIM}(baseline is empty — next listener detected will be flagged as 'new')${C_RST}"
    else
        echo "${C_DIM}known-good baseline (LISTEN):${C_RST}"
        echo "$snapshot" | sed 's/^/  /'
    fi
    echo
}

show_recent_root() {
    echo "${C_BOLD}── Recent root processes (<30s alive, not on allow-list) ──${C_RST}"
    local out
    out=$(ps -eo pid,euser,etime,comm 2>/dev/null \
        | awk '$2=="root" {
                  t=$3; n=split(t, a, /[-:]/)
                  if (n==2 && a[1]+0 == 0 && a[2]+0 < 30) print
               }' \
        | grep -vE ' (sudo|polkitd|sshd|cron|systemd[^ ]*|kworker(/[^ ]*)?|kdmflush[^ ]*|udevd|udevadm|rcu_[^ ]*|ksoftirqd[^ ]*|migration[^ ]*)$')
    if [[ -z "$out" ]]; then
        echo "${C_GRN}  ✓ nothing in window${C_RST}"
    else
        echo "$out"
    fi
    echo
}

show_gpu() {
    if ! command -v nvidia-smi >/dev/null 2>&1; then
        return
    fi
    echo "${C_BOLD}── NVIDIA compute processes ──${C_RST}"
    local out
    out=$(nvidia-smi --query-compute-apps=pid,process_name,used_memory --format=csv,noheader 2>/dev/null)
    if [[ -z "$out" ]]; then
        echo "${C_GRN}  ✓ no GPU compute processes${C_RST}"
    else
        echo "$out" | sed 's/^/  /'
    fi
    echo
}

# -- actions ---------------------------------------------------------------

action_reset() {
    if [[ ! -f "$STATE" ]]; then
        echo "${C_YEL}no state file yet — nothing to reset${C_RST}"
        exit 0
    fi
    # Capture current LISTEN snapshot exactly the way hw_overwatch.sh does,
    # so the next tick sees zero new listeners.
    local current
    current=$(ss -tlnp 2>/dev/null \
        | awk 'NR>1 && $4 !~ /^127\./ && $4 !~ /^\[::1\]/ && $4 !~ /^\*:/ {
                  match($0, /users:\(\("[^"]+"/)
                  proc=substr($0, RSTART+8, RLENGTH-9)
                  print $4 "\t" proc
              }' \
        | sort -u)
    printf 'LISTEN:%s\n' "$(printf '%s' "$current" | tr '\n' '|')" > "$STATE"
    echo "${C_GRN}✓ baseline reset — current listeners are now the known-good state${C_RST}"
    echo
    echo "$current" | sed 's/^/  /'
}

action_watch() {
    while true; do
        clear
        echo "${C_PEACH}fox overwatch — live (Ctrl-C to exit)${C_RST}"
        echo "${C_DIM}refreshing every 5s$C_RST"
        echo
        main_report
        sleep 5
    done
}

main_report() {
    show_state_diff
    show_listeners
    show_recent_root
    show_gpu
}

# -- entry -----------------------------------------------------------------

case "${1:-}" in
    -h|--help)  usage; exit 0 ;;
    --reset)    action_reset; exit 0 ;;
    --watch)    action_watch ;;
    --raw)
        [[ -f "$STATE" ]] && cat "$STATE" || echo "(no state file)"
        exit 0
        ;;
    "" )        main_report ;;
    *)
        echo "unknown flag: $1"
        usage
        exit 2
        ;;
esac
