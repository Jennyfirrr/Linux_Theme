#!/usr/bin/env bash
# fox-ai-cmd — natural language → shell command via local Ollama.
#
# Usage: fox-ai-cmd "find all .cpp files modified in the last hour and grep
#                    for trailing whitespace"
#        echo "..." | fox-ai-cmd
#
# Prints the suggested command and prompts before running. Override the
# model via FOXAI_MODEL=qwen2.5:7b. Defaults to whatever the user-level
# opencode.json points at, then falls back to qwen2.5-coder:7b.

set -u

if ! command -v ollama >/dev/null 2>&1; then
    echo "fox-ai-cmd: ollama not installed" >&2
    exit 1
fi

# Pick a model. Honour env, then opencode's chosen default, then a
# reasonable coder fallback.
MODEL="${FOXAI_MODEL:-}"
if [[ -z "$MODEL" ]] && [[ -f "$HOME/.config/opencode/opencode.json" ]] && command -v jq >/dev/null 2>&1; then
    MODEL=$(jq -r '.model // empty' "$HOME/.config/opencode/opencode.json" 2>/dev/null | sed 's|^ollama/||')
fi
MODEL="${MODEL:-qwen2.5-coder:7b}"

# Read prompt from arg or stdin.
if [[ $# -gt 0 ]]; then
    prompt="$*"
else
    prompt=$(cat)
fi
[[ -z "$prompt" ]] && { echo "fox-ai-cmd: empty prompt" >&2; exit 2; }

system='You are a shell command generator. Given a user description in plain English, output ONLY the bash/zsh command that accomplishes the task, with no commentary, no markdown fences, no explanation. If the task requires multiple commands, separate them with `&&` or `;`. Prefer concise pipelines. Assume Arch Linux + Wayland + Hyprland environment. Use modern coreutils (fd, rg, bat, eza) when applicable.'

full_prompt="$system

User request: $prompt

Shell command:"

cmd=$(ollama run "$MODEL" "$full_prompt" 2>/dev/null \
    | sed -E '/^```/d; /^$/d' \
    | head -n 5)

if [[ -z "$cmd" ]]; then
    echo "fox-ai-cmd: model returned nothing" >&2
    exit 1
fi

printf '\n  \033[1mSuggested:\033[0m\n'
printf '%s\n' "$cmd" | sed 's/^/    /'
echo

read -r -p "  Run? [y/N/edit] " yn
case "$yn" in
    y|Y)         eval "$cmd" ;;
    e|edit)      read -e -i "$cmd" -p "  > " edited && eval "$edited" ;;
    *)           echo "  not running." ;;
esac
