#!/usr/bin/env bash
# fox-menu — rofi launcher for fox-* CLI commands.
#
# Scans ~/.local/bin/fox-* (and fask/findex/fhelp) and presents a fuzzy-
# searchable menu. Description is the comment immediately after the
# shebang in each script's source (the same "fox-X — description" line
# the fox help dump already parses). On selection, the command runs in
# a new kitty window — most fox-* tools are CLI-interactive.
#
# Usage: fox-menu

set -euo pipefail

# Collect (name, description) tuples. Skip self + the umbrella wrapper.
declare -a entries=()
for cmd in "$HOME/.local/bin/"fox-* "$HOME/.local/bin/"fask "$HOME/.local/bin/"findex "$HOME/.local/bin/"fhelp "$HOME/.local/bin/"fox-tail; do
    [[ -x "$cmd" && -f "$cmd" ]] || continue
    name=$(basename "$cmd")
    case "$name" in
        fox-menu|fox|fox-rollback) continue ;;
    esac
    # Pull the description line: pattern "# name — description" or
    # "# name -- description". Falls back to "(no description)".
    desc=""
    if [[ "$name" == "fask" ]]; then
        desc="Query the FoxML Intelligence Layer (AI model)"
    elif [[ "$name" == "findex" ]]; then
        desc="Rebuild the vector index for AI semantic search"
    elif file "$cmd" 2>/dev/null | grep -q text; then
        desc=$(sed -n '2p' "$cmd" 2>/dev/null \
            | sed -E 's/^#[[:space:]]*[^—-]+[—-]+[[:space:]]*//')
    fi
    [[ -z "$desc" || "$desc" == "#"* ]] && desc="(no description)"
    entries+=("$(printf '%-22s  %s' "$name" "$desc")")
done

if (( ${#entries[@]} == 0 )); then
    notify-send -u critical "fox-menu" "no fox-* commands found in ~/.local/bin"
    exit 1
fi

# Sort for stable order. printf %s\n keeps each entry on one line.
IFS=$'\n' sorted=($(sort <<<"${entries[*]}"))
unset IFS

# Rofi prompt. Match the project's rofi look (theme is picked up from
# ~/.config/rofi/config.rasi automatically; no extra flags needed).
sel=$(printf '%s\n' "${sorted[@]}" | rofi -dmenu -i -p "fox" -no-fixed-num-lines)
[[ -z "$sel" ]] && exit 0

# First whitespace-separated token is the command name.
cmd=$(awk '{print $1}' <<<"$sel")
[[ -x "$HOME/.local/bin/$cmd" ]] || exit 1

# Spawn in a fresh kitty so the command has a TTY and the user can
# observe / interact. Detach so rofi closes immediately.
if command -v kitty >/dev/null 2>&1; then
    setsid -f kitty --title "fox: ${cmd}" -- "$cmd" >/dev/null 2>&1 || true
else
    setsid -f "$cmd" >/dev/null 2>&1 || true
fi
