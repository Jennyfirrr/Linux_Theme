{
  "layer": "top",
  "position": "top",
  "height": 52,
  "margin": "12 12 0 12",

  "modules-left": [
    "custom/logo",
    "hyprland/workspaces"
  ],

  "modules-center": [],

  "modules-right": [
    "custom/cpu",
    "memory",
    "custom/gpu",
    "custom/disk",
    "network",
    "pulseaudio",
    "backlight",
    "battery",
    "clock",
    "tray"
  ],

  "hyprland/workspaces": {
    "format": "{name}",
    "disable-scroll": false,
    "all-outputs": true,
    "persistent-workspaces": {
        "*": [1, 2, 3, 4, 5, 6, 7, 8, 9]
    }
  },

  "custom/cpu": {
    "exec": "~/.config/waybar/scripts/cpu.sh",
    "return-type": "json",
    "interval": 5,
    "tooltip": false
  },

  "memory": {
    "format": "RAM {used:0.1f}/{total:0.0f}g",
    "interval": 5,
    "states": {
      "warning": 75,
      "critical": 90
    },
    "tooltip-format": "RAM: {used:0.1f}g / {total:0.1f}g ({percentage}%)\nSwap: {swapUsed:0.1f}g / {swapTotal:0.1f}g"
  },

  "custom/gpu": {
    "exec": "~/.config/waybar/scripts/gpu.sh",
    "return-type": "json",
    "interval": 5,
    "tooltip": false
  },

  "custom/disk": {
    "exec": "~/.config/waybar/scripts/disk.sh",
    "return-type": "json",
    "interval": 60
  },

  "network": {
    "format-wifi": "󰖩  {essid} {signalStrength}%",
    "format-ethernet": "󰈀  {ipaddr}",
    "format-disconnected": "󰖪  offline",
    "tooltip-format": "{ifname}\n{ipaddr}",
    "family": "ipv4"
  },

  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "󰝟  mute",
    "format-icons": {
      "headphones": "󰋋",
      "default": ["󰕿", "󰖀", "󰕾"]
    },
    "on-click": "pavucontrol"
  },

  "backlight": {
    "format": "󰃟  {percent}%",
    "interval": 2
  },

  "battery": {
    "format": "{icon} {capacity}%",
    "format-charging": "󰂄  {capacity}%",
    "format-icons": ["󰁺", "󰁼", "󰁾", "󰂀", "󰁹"],
    "interval": 10,
    "states": {
      "warning": 25,
      "critical": 10
    }
  },

  "clock": {
    "format": "  {:%a %b %d  %I:%M %p}",
    "tooltip-format": "{:%A, %B %d, %Y}\nWeek %V"
  },

  "tray": {
    "icon-size": 16,
    "spacing": 8
  },

  "custom/logo": {
    "format": "󰣇",
    "tooltip": "Launcher",
    "on-click": "bash -lc 'command -v wheel && wheel || rofi -show drun'"
  }
}
