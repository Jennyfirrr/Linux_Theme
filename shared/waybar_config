{
  "layer": "top",
  "position": "top",
  "height": __HEIGHT__,
  "margin": "__MARGIN_BAR__",

  "modules-left": [
    "custom/logo",
    "hyprland/workspaces"
  ],

  "modules-center": [
    "custom/project_name"
  ],

  "modules-right": [
    "custom/weather",
    "custom/net_speed",
    "custom/cpu",
    "memory",
    "custom/gpu",
    "custom/disk",
    "custom/updates",
    "network",
    "pulseaudio",
    "backlight",
    "power-profiles-daemon",
    "battery",
    "idle_inhibitor",
    "clock",
    "tray"
  ],

  "hyprland/workspaces": {
    "format": "{name}",
    "disable-scroll": false,
    "all-outputs": true,
    "persistent-workspaces": {
        "*": [1, 2, 3, 4, 5, 6, 7, 8, 9]
    }
  },

  "custom/cpu": {
    "exec": "~/.config/waybar/scripts/cpu.sh",
    "return-type": "json",
    "interval": 5,
    "tooltip": false
  },

  "memory": {
    "format": "RAM {used:0.1f}/{total:0.0f}g",
    "interval": 5,
    "states": {
      "warning": 75,
      "critical": 90
    },
    "tooltip-format": "RAM: {used:0.1f}g / {total:0.1f}g ({percentage}%)\nSwap: {swapUsed:0.1f}g / {swapTotal:0.1f}g"
  },

  "custom/gpu": {
    "exec": "~/.config/waybar/scripts/gpu.sh",
    "return-type": "json",
    "interval": 5,
    "tooltip": false
  },

  "custom/disk": {
    "exec": "~/.config/waybar/scripts/disk.sh",
    "return-type": "json",
    "interval": 60
  },

  "network": {
    "format-wifi": "󰖩  {essid} {signalStrength}%",
    "format-ethernet": "󰈀  {ipaddr}",
    "format-disconnected": "󰖪  offline",
    "tooltip-format": "{ifname}\n{ipaddr}",
    "family": "ipv4"
  },

  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "󰝟  mute",
    "format-icons": {
      "headphones": "󰋋",
      "default": ["󰕿", "󰖀", "󰕾"]
    },
    "on-click": "pavucontrol"
  },

  "backlight": {
    "format": "󰃟  {percent}%",
    "interval": 2
  },

  "battery": {
    "format": "{icon} {capacity}%",
    "format-charging": "󰂄  {capacity}%",
    "format-icons": ["󰁺", "󰁼", "󰁾", "󰂀", "󰁹"],
    "interval": 10,
    "tooltip-format": "{capacity}% — {time} left\n{power:0.1f} W",
    "tooltip-format-charging": "{capacity}% — charging, {time} until full\n{power:0.1f} W",
    "tooltip-format-full": "{capacity}% — full",
    "states": {
      "warning": 25,
      "critical": 10
    }
  },

  "power-profiles-daemon": {
    "format": "{icon}",
    "format-icons": {
      "default": "BAL",
      "performance": "PERF",
      "balanced": "BAL",
      "power-saver": "SAVE"
    },
    "tooltip-format": "Power profile: {profile}\nClick to cycle: balanced → performance → power-saver",
    "on-click": "~/.config/waybar/scripts/ppd_cycle.sh"
  },

  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "AWAKE",
      "deactivated": "○"
    },
    "tooltip-format-activated": "Idle inhibited — click to release",
    "tooltip-format-deactivated": "Click to keep screen awake"
  },

  "custom/updates": {
    "exec": "~/.config/waybar/scripts/updates.sh",
    "return-type": "json",
    "interval": 1800,
    "on-click": "kitty -e bash -lc 'checkupdates | less; exec zsh' &"
  },

  "clock": {
    "format": "  {:%a %b %d  %I:%M %p}",
    "tooltip-format": "{:%A, %B %d, %Y}\nWeek %V"
  },

  "tray": {
    "icon-size": __TRAY_ICON__,
    "spacing": 8
  },

  "custom/logo": {
    "format": "󰣇",
    "tooltip": "Launcher",
    "on-click": "bash -lc 'command -v wheel && wheel || rofi -show drun'"
  },

  "custom/weather": {
    "exec": "~/.config/waybar/scripts/weather.sh",
    "return-type": "json",
    "interval": 1800,
    "tooltip": true
  },

  "custom/net_speed": {
    "exec": "~/.config/waybar/scripts/net_speed.sh",
    "return-type": "json",
    "interval": 2,
    "tooltip": true
  },

  "custom/project_name": {
    "exec": "~/.config/waybar/scripts/project_name.sh",
    "return-type": "json",
    "interval": 5,
    "tooltip": true
  }
}
