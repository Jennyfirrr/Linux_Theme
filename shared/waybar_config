{
  "layer": "top",
  "position": "top",
  "height": __HEIGHT__,
  "margin": "__MARGIN_BAR__",

  "modules-left": [
    "custom/logo",
    "hyprland/workspaces"
  ],

  "modules-center": [],

  "modules-right": [
    "custom/net_speed",
    "custom/cpu",
    "memory",
    "custom/disk",
    "power-profiles-daemon",
    "custom/battery",
    "idle_inhibitor",
    "custom/clock",
    "custom/system_health",
    "tray"
  ],

  "custom/system_health": {
    "exec": "~/.config/waybar/scripts/system_health.sh",
    "return-type": "json",
    "interval": 10,
    "tooltip": true
  },

  "hyprland/workspaces": {
    "format": "{name}",
    "disable-scroll": false,
    "all-outputs": true,
    "persistent-workspaces": {
        "*": [1, 2, 3, 4, 5, 6, 7, 8, 9]
    }
  },

  "custom/cpu": {
    "exec": "~/.config/waybar/scripts/cpu.sh",
    "return-type": "json",
    "interval": 5,
    "tooltip": true
  },

  "memory": {
    "format": "RAM {used:0.1f}/{total:0.0f}g",
    "interval": 5,
    "states": {
      "warning": 75,
      "critical": 90
    },
    "tooltip-format": "RAM: {used:0.1f}g / {total:0.1f}g ({percentage}%)\nSwap: {swapUsed:0.1f}g / {total:0.1f}g"
  },

  "custom/disk": {
    "exec": "~/.config/waybar/scripts/disk.sh",
    "return-type": "json",
    "interval": 60
  },

  "power-profiles-daemon": {
    "format": "{icon}",
    "format-icons": {
      "default": "BAL",
      "performance": "PERF",
      "balanced": "BAL",
      "power-saver": "SAVE"
    },
    "tooltip-format": "Power profile: {profile}\nClick to cycle: balanced → performance → power-saver",
    "on-click": "~/.config/waybar/scripts/ppd_cycle.sh"
  },

  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "AWAKE",
      "deactivated": "○"
    },
    "tooltip-format-activated": "Idle inhibited — click to release",
    "tooltip-format-deactivated": "Click to keep screen awake"
  },

  "tray": {
    "icon-size": __TRAY_ICON__,
    "spacing": 8
  },

  "custom/logo": {
    "format": "󰣇",
    "tooltip": "Launcher",
    "on-click": "bash -lc 'command -v wheel && wheel || rofi -show drun'"
  },

  "custom/net_speed": {
    "exec": "~/.config/waybar/scripts/net_speed.sh",
    "return-type": "json",
    "interval": 2,
    "tooltip": true
  },

  "custom/media": {
    "exec": "~/.config/waybar/scripts/media.sh",
    "return-type": "json",
    "interval": 2,
    "on-click": "playerctl play-pause",
    "on-scroll-up": "playerctl next",
    "on-scroll-down": "playerctl previous",
    "tooltip": true
  },

  "custom/battery": {
    "exec": "~/.config/waybar/scripts/battery.sh",
    "return-type": "json",
    "interval": 5,
    "tooltip": true,
    "on-click": "pavucontrol"
  },

  "custom/clock": {
    "exec": "~/.config/waybar/scripts/clock.sh",
    "return-type": "json",
    "interval": 60,
    "tooltip": true,
    "on-click": "kitty -e bash -lc 'checkupdates | less; exec zsh' &"
  }
}
