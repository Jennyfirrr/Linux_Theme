configuration {
    modi: "drun,run,window";
    show-icons: true;
    terminal: "kitty";

    /* Keybindings */
    kb-row-up: "Up,Alt+k";
    kb-row-down: "Down,Alt+j";
    kb-accept-entry: "Return,KP_Enter,Alt+l";
    kb-mode-next: "Shift+Right,Control+Tab,Alt+h";
}

@theme "~/.config/rofi/glass.rasi"
