{
  "layer": "top",
  "position": "top",
  "height": __HEIGHT__,
  "margin": "__MARGIN_BAR__",

  "modules-left": [
    "group/launcher"
  ],

  "modules-center": [],

  "modules-right": [
    "custom/clock"
  ],

  "group/launcher": {
    "orientation": "horizontal",
    "modules": [
        "custom/logo",
        "hyprland/workspaces"
    ]
  },

  "custom/logo": {
    "format": "🦊",
    "tooltip": "SysHub",
    "on-click": "~/.config/hypr/scripts/toggle_rofi.sh ~/.config/hypr/scripts/hub.sh"
  },

  "hyprland/workspaces": {
    "format": "{name} {windows}",
    "format-window-separator": " ",
    "window-rewrite-default": "󰘔",
    "window-rewrite": {
        "class<firefox>": "󰈹",
        "class<kitty>": "󰄛",
        "class<discord>": "󰙯",
        "class<steam>": "󰓓",
        "class<yazi>": "󰇥",
        "class<thunar>": "󰝰",
        "class<rofi>": "󰀻",
        "class<cursor>": "󰨞",
        "class<btopterm>": "󰑮"
    },
    "disable-scroll": false,
    "all-outputs": false,
    "persistent-workspaces": {
        "*": [1, 2, 3, 4, 5, 6, 7, 8, 9]
    }
  },

  "custom/clock": {
    "exec": "~/.config/waybar/scripts/clock.sh",
    "return-type": "json",
    "interval": 60,
    "tooltip": true
  }
}
