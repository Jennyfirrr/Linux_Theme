.git
.git/
.active-theme

# OpenCode Skills (Private)
claude-skills/

# OpenCode project-local config — install.sh regenerates from a static
# template, but earlier versions wrote $HOME-absolute paths and private-
# workspace names into this file. Keep it out of the repo regardless.
.opencode/

# Agent permission grants — Claude Code / OpenCode write this file
# with absolute paths to whatever the user has allowed. Per-machine
# state, contains $HOME paths and private-workspace names. Not for
# the repo.
.agent/settings.local.json

# Claude Code session state (claude.ai's local IDE config)
.claude/

# Plans (Personal design and scratchpad)
plans/

# Editor backups — local safety nets, not for the repo
*.bak
*.bak[0-9]*
*~

# Render output — regenerated on every install
rendered/

# AI Session Context — generated by fox-tail, not for the repo
.foxml_context.md

# Compiled fox-intel binaries — install.sh rebuilds them
src/fox-intel/fask
src/fox-intel/findex
src/fox-intel/libfox-intel.a

# fox-* native binaries + their .o / .a build artefacts.
# The repo ships sources; install.sh runs `make` to produce these.
src/*/*.o
src/*/core/*.o
src/*/modules/*.o
src/*/tests/test_*
src/fox-install/fox-install
src/fox-render/fox-render-fast
src/fox-pulse/fox-pulse
src/fox-vault/fox-vault
src/fox-ai-*/fox-ai-*
!src/fox-ai-*/fox-ai-*.cpp
!src/fox-ai-*/fox-ai-*.hpp
!src/fox-ai-*/fox-ai-*.h
src/fox-ask/fox-ask
!src/fox-ask/fox-ask.cpp

# Vendored nlohmann json header — bootstrap.sh / install.sh wrapper
# fetches it on first build. Don't commit a 25k-line vendored copy.
src/fox-intel/json.hpp
.aider*
